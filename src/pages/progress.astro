const clientScript = `
  const BASE_PATH = ${JSON.stringify(import.meta.env.BASE_URL)};
  const texts = ${JSON.stringify(texts)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const ui = ${JSON.stringify(uiText)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = ${JSON.stringify(targetLanguageBadges)};
  const progressLabels = ${JSON.stringify(progressLabels)};
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const TEXT_PROGRESS_KEY = 'typingProgress';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const SELF_ASSESSMENT_KEY = 'typingSelfAssessment';
  const PINNED_TEXTS_KEY = 'typingPinnedTexts';
  const PINNED_PRACTICE_TARGETS_KEY = 'typingPinnedPracticeTargets';
  const EXPRESSION_STATUSES = ['new', 'review', 'learned'];
  let historyExpanded = false;

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function readObject(key) {
    try {
      const parsed = JSON.parse(safeReadStorage(key) || '{}');
      return parsed && typeof parsed === 'object' && !Array.isArray(parsed) ? parsed : {};
    } catch {
      return {};
    }
  }

  function readArray(key) {
    try {
      const parsed = JSON.parse(safeReadStorage(key) || '[]');
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  }

  function getAppHref(path) {
    const base = BASE_PATH || '/';
    const normalizedBase = base.endsWith('/') ? base : base + '/';
    return normalizedBase + String(path).replace(/^\\//, '');
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return typeof stored === 'string' && uiLanguages.includes(stored) ? stored : 'en';
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatNumber(value) {
    return Number.isFinite(value) ? String(Math.round(value)) : '—';
  }

  function formatPercent(value) {
    return Number.isFinite(value) ? Math.round(value) + '%' : '—';
  }

  function formatDate(value, lang) {
    const date = new Date(value || '');
    if (Number.isNaN(date.getTime())) {
      return '—';
    }
    return new Intl.DateTimeFormat(lang, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(date);
  }

  function formatShortDate(value, lang) {
    const date = new Date(value || '');
    if (Number.isNaN(date.getTime())) {
      return '—';
    }
    return new Intl.DateTimeFormat(lang, { month: 'short', day: 'numeric' }).format(date);
  }

  function getDateKey(value) {
    const date = new Date(value || '');
    if (Number.isNaN(date.getTime())) {
      return '';
    }
    return date.getFullYear() + '-'
      + String(date.getMonth() + 1).padStart(2, '0') + '-'
      + String(date.getDate()).padStart(2, '0');
  }

  function isValidSpeed(value, language) {
    const speed = Number(value);
    if (!Number.isFinite(speed) || speed <= 0) {
      return false;
    }
    return language === 'ja' ? speed <= 1000 : speed <= 250;
  }

  function average(values) {
    const valid = values.filter((value) => Number.isFinite(value));
    return valid.length ? valid.reduce((sum, value) => sum + value, 0) / valid.length : null;
  }

  function getTextById(textId) {
    return texts.find((item) => item.id === textId) || null;
  }

  function getExpressionStorageKey(expression, language) {
    return language + '::' + (expression.storageKey || expression.phrase);
  }

  function getExpressionStatus(expression, language, statuses) {
    const stored = statuses[getExpressionStorageKey(expression, language)]
      || statuses[expression.storageKey]
      || statuses[language + '::' + expression.phrase]
      || statuses[expression.phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getUniqueExpressions() {
    const seen = new Set();
    const expressions = [];
    texts.forEach((text) => {
      text.expressions.forEach((expression) => {
        const key = getExpressionStorageKey(expression, text.language);
        if (!seen.has(key)) {
          seen.add(key);
          expressions.push({ ...expression, language: text.language, textId: text.id });
        }
      });
    });
    return expressions;
  }

  function getExpressionCounts(statuses, language = null) {
    return getUniqueExpressions().reduce((counts, expression) => {
      if (language && expression.language !== language) {
        return counts;
      }
      const status = getExpressionStatus(expression, expression.language, statuses);
      counts[status] += 1;
      return counts;
    }, { new: 0, review: 0, learned: 0 });
  }

  function normalizePracticeTarget(target) {
    if (!target || typeof target !== 'object' || typeof target.textId !== 'string') {
      return null;
    }
    if (target.practiceType === 'translation' && uiLanguages.includes(target.practiceTranslation)) {
      return { textId: target.textId, practiceType: 'translation', practiceTranslation: target.practiceTranslation };
    }
    return { textId: target.textId, practiceType: 'original', practiceTranslation: null };
  }

  function getPracticeTargetKey(target) {
    return target.textId + '::' + target.practiceType + '::' + (target.practiceTranslation || '');
  }

  function getPinnedPracticeTargets() {
    const targets = readArray(PINNED_TEXTS_KEY)
      .filter((id) => typeof id === 'string')
      .map((textId) => ({ textId, practiceType: 'original', practiceTranslation: null }));

    readArray(PINNED_PRACTICE_TARGETS_KEY).forEach((item) => {
      const target = normalizePracticeTarget(item);
      if (target) {
        targets.push(target);
      }
    });

    const seen = new Set();
    return targets.filter((target) => {
      const text = getTextById(target.textId);
      if (!text) {
        return false;
      }
      if (target.practiceType === 'translation') {
        const field = target.practiceTranslation === 'ja' ? 'translationJa' : target.practiceTranslation === 'en' ? 'translationEn' : 'translationNo';
        if (!field || !text[field]) {
          return false;
        }
      }
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
  }

  function getPracticeHref(target) {
    if (target.practiceType === 'translation' && target.practiceTranslation) {
      return getAppHref('text/' + encodeURIComponent(target.textId) + '?practiceTranslation=' + encodeURIComponent(target.practiceTranslation));
    }
    return getAppHref('text/' + encodeURIComponent(target.textId));
  }

  function getProgressData() {
    const textProgress = readObject(TEXT_PROGRESS_KEY);
    const expressionStatuses = readObject(EXPRESSION_STATUS_KEY);
    const selfAssessments = readObject(SELF_ASSESSMENT_KEY);
    const expressionCounts = getExpressionCounts(expressionStatuses);
    const practicedTexts = texts
      .map((text) => ({ text, entry: textProgress[text.id] || null }))
      .filter(({ entry }) => entry && Number.isFinite(entry.completedCount) && entry.completedCount > 0);
    const totalPractices = practicedTexts.reduce((sum, { entry }) => sum + entry.completedCount, 0);
    const validWpm = practicedTexts
      .filter(({ text, entry }) => text.language !== 'ja' && isValidSpeed(entry.bestWpm, text.language))
      .map(({ entry }) => Number(entry.bestWpm));
    const validCpm = practicedTexts
      .filter(({ text, entry }) => text.language === 'ja' && isValidSpeed(entry.bestWpm, text.language))
      .map(({ entry }) => Number(entry.bestWpm));

    return {
      textProgress,
      expressionStatuses,
      selfAssessments,
      expressionCounts,
      practicedTexts,
      totalPractices,
      averageWpm: average(validWpm),
      averageCpm: average(validCpm),
      pinnedTargets: getPinnedPracticeTargets(),
    };
  }

  function getAllPracticeRows(data) {
    const rows = Object.values(data.selfAssessments)
      .filter((entry) => entry && typeof entry === 'object' && typeof entry.textId === 'string')
      .map((assessment) => {
        const text = getTextById(assessment.textId);
        const progress = data.textProgress[assessment.textId] || {};
        const targetLanguage = assessment.targetLanguage || text?.language || 'no';
        return {
          text,
          title: text?.title || assessment.textId,
          language: targetLanguage,
          practiceType: assessment.mode === 'translation' ? 'translation' : 'original',
          accuracy: Number.isFinite(progress.bestAccuracy) ? progress.bestAccuracy : null,
          speed: isValidSpeed(progress.bestWpm, targetLanguage) ? progress.bestWpm : null,
          mistakes: null,
          selfAssessment: assessment.level || '',
          reviewTarget: Boolean(assessment.reviewTarget),
          practicedAt: assessment.assessedAt || progress.lastPracticedAt || '',
        };
      });

    const assessedTextIds = new Set(rows.map((row) => row.text?.id).filter(Boolean));
    data.practicedTexts.forEach(({ text, entry }) => {
      if (assessedTextIds.has(text.id)) {
        return;
      }
      rows.push({
        text,
        title: text.title,
        language: text.language,
        practiceType: 'original',
        accuracy: Number.isFinite(entry.bestAccuracy) ? entry.bestAccuracy : null,
        speed: isValidSpeed(entry.bestWpm, text.language) ? entry.bestWpm : null,
        mistakes: null,
        selfAssessment: '',
        reviewTarget: false,
        practicedAt: entry.lastPracticedAt || '',
      });
    });

    return rows.sort((a, b) => (Date.parse(b.practicedAt || '') || 0) - (Date.parse(a.practicedAt || '') || 0));
  }

  function renderMetricBar(value, maxValue = 100) {
    const safeValue = Number.isFinite(value) ? Math.max(0, Math.min(value, maxValue)) : 0;
    const width = maxValue > 0 ? Math.round((safeValue / maxValue) * 100) : 0;
    return '<span class="progress-mini-bar" aria-hidden="true"><span style="width: ' + width + '%"></span></span>';
  }

  function formatSelfAssessment(level, labels) {
    if (!['perfect', 'good', 'shaky', 'again'].includes(level)) {
      return '<span class="progress-assessment-badge progress-assessment-badge--empty">—</span>';
    }
    return '<span class="progress-assessment-badge progress-assessment-badge--' + escapeHtml(level) + '">' + escapeHtml(labels[level] || level) + '</span>';
  }

  function renderOverview(data, labels) {
    const stats = [
      [labels.totalPractices, data.totalPractices],
      [labels.learnedExpressions, data.expressionCounts.learned],
      [labels.reviewingExpressions, data.expressionCounts.review],
      [labels.newExpressions, data.expressionCounts.new],
      [labels.averageWpm, data.averageWpm],
      [labels.averageCpm, data.averageCpm],
      [labels.pinnedTargets, data.pinnedTargets.length],
    ];
    document.getElementById('progress-overview-grid').innerHTML = stats.map(([label, value]) => (
      '<article class="progress-stat-card"><span>' + escapeHtml(label) + '</span><strong>' + formatNumber(value) + '</strong></article>'
    )).join('');
  }

  function renderActivityCalendar(data, labels, lang) {
    const rows = getAllPracticeRows(data);
    const counts = new Map();
    rows.forEach((row) => {
      const key = getDateKey(row.practicedAt);
      if (key) {
        counts.set(key, (counts.get(key) || 0) + 1);
      }
    });

    const today = new Date();
    const days = [];
    for (let offset = 29; offset >= 0; offset -= 1) {
      const date = new Date(today);
      date.setHours(12, 0, 0, 0);
      date.setDate(today.getDate() - offset);
      const key = getDateKey(date.toISOString());
      const count = counts.get(key) || 0;
      days.push({
        date,
        count,
        intensity: count >= 4 ? 4 : count,
      });
    }

    const activeDays = days.filter((day) => day.count > 0).length;
    const totalRecentPractices = days.reduce((sum, day) => sum + day.count, 0);
    const maxCount = Math.max(...days.map((day) => day.count), 0);
    const calendar = document.getElementById('progress-calendar');
    const summary = document.getElementById('progress-calendar-summary');
    const emptyState = document.getElementById('progress-calendar-empty');
    const description = document.getElementById('progress-calendar-description');
    const legendLess = document.getElementById('progress-calendar-legend-less');
    const legendMore = document.getElementById('progress-calendar-legend-more');
    description.textContent = labels.activityDescription;
    legendLess.textContent = labels.less;
    legendMore.textContent = labels.more;
    summary.innerHTML = '<span>' + escapeHtml(labels.last30Days) + '</span><strong>' + activeDays + '</strong><span>' + escapeHtml(labels.activeDays) + '</span><strong>' + totalRecentPractices + '</strong><span>' + escapeHtml(labels.totalPractices) + '</span>';
    calendar.innerHTML = days.map((day) => {
      const label = formatShortDate(day.date.toISOString(), lang) + ': ' + day.count;
      return '<span class="progress-calendar__day" data-intensity="' + day.intensity + '" title="' + escapeHtml(label) + '" aria-label="' + escapeHtml(label) + '"></span>';
    }).join('');
    emptyState.textContent = labels.emptyActivity;
    emptyState.hidden = maxCount > 0;
  }

  function renderTrend(data, labels) {
    const rows = getAllPracticeRows(data).slice(0, 8);
    const recentAccuracy = average(rows.map((row) => Number.isFinite(row.accuracy) ? row.accuracy : null));
    const recentWpm = average(rows.filter((row) => row.language !== 'ja').map((row) => Number.isFinite(row.speed) ? row.speed : null));
    const recentCpm = average(rows.filter((row) => row.language === 'ja').map((row) => Number.isFinite(row.speed) ? row.speed : null));
    const trend = document.getElementById('progress-trend');
    const hasData = Number.isFinite(recentAccuracy) || Number.isFinite(recentWpm) || Number.isFinite(recentCpm);
    if (!hasData) {
      trend.innerHTML = '<p class="progress-empty-state">' + escapeHtml(labels.emptyTrend) + '</p>';
      return;
    }
    trend.innerHTML = [
      [labels.recentAverageAccuracy, formatPercent(recentAccuracy), renderMetricBar(recentAccuracy, 100)],
      [labels.recentAverageWpm, formatNumber(recentWpm), renderMetricBar(recentWpm, 120)],
      [labels.recentAverageCpm, formatNumber(recentCpm), renderMetricBar(recentCpm, 600)],
    ].map(([label, value, bar]) => (
      '<article class="progress-trend-card"><span>' + escapeHtml(label) + '</span><strong>' + escapeHtml(value) + '</strong>' + bar + '</article>'
    )).join('');
  }

  function getAttentionItems(data, labels) {
    const rows = getAllPracticeRows(data);
    const pinnedKeys = new Set(data.pinnedTargets.map(getPracticeTargetKey));
    const items = [];
    rows.forEach((row) => {
      if (!row.text) {
        return;
      }
      const target = {
        textId: row.text.id,
        practiceType: row.practiceType,
        practiceTranslation: row.practiceType === 'translation' ? row.language : null,
      };
      const reasons = [];
      if (row.selfAssessment === 'again') {
        reasons.push(labels.reviewAgain);
      } else if (row.selfAssessment === 'shaky') {
        reasons.push(labels.reviewShaky);
      }
      if (Number.isFinite(row.accuracy) && row.accuracy < 90) {
        reasons.push(labels.lowAccuracy);
      }
      if (Number.isFinite(row.mistakes) && row.mistakes >= 5) {
        reasons.push(labels.highMistakes);
      }
      if (pinnedKeys.has(getPracticeTargetKey(target))) {
        reasons.push(labels.pinned);
      }
      if (reasons.length) {
        items.push({ row, target, reasons });
      }
    });

    data.pinnedTargets.forEach((target) => {
      const key = getPracticeTargetKey(target);
      if (items.some((item) => getPracticeTargetKey(item.target) === key)) {
        return;
      }
      const text = getTextById(target.textId);
      if (!text) {
        return;
      }
      items.push({
        target,
        reasons: [labels.pinned],
        row: {
          text,
          title: text.title,
          language: target.practiceType === 'translation' ? target.practiceTranslation : text.language,
          practiceType: target.practiceType,
          accuracy: null,
          speed: null,
          selfAssessment: '',
          practicedAt: '',
        },
      });
    });
    return items.slice(0, 8);
  }

  function renderAttention(data, labels, lang) {
    const container = document.getElementById('progress-attention-list');
    const items = getAttentionItems(data, labels);
    if (!items.length) {
      container.innerHTML = '<p class="progress-empty-state">' + escapeHtml(labels.noAttention) + '</p>';
      return;
    }
    container.innerHTML = items.map(({ row, target, reasons }) => {
      const speedUnit = row.language === 'ja' ? 'CPM' : 'WPM';
      return '<article class="progress-attention-card">'
        + '<span class="language-badge language-badge--' + escapeHtml(row.language) + '">' + escapeHtml(targetLanguageBadges[row.language] || row.language) + '</span>'
        + '<div class="progress-attention-card__main">'
        + '<strong>' + escapeHtml(row.title) + '</strong>'
        + '<div class="progress-attention-card__meta">'
        + '<span>' + escapeHtml(row.practiceType === 'translation' ? labels.translation : labels.original) + '</span>'
        + '<span>' + reasons.map(escapeHtml).join(' / ') + '</span>'
        + '<span>' + formatPercent(row.accuracy) + '</span>'
        + '<span>' + (Number.isFinite(row.speed) ? Math.round(row.speed) + ' ' + speedUnit : '—') + '</span>'
        + '<time>' + escapeHtml(formatDate(row.practicedAt, lang)) + '</time>'
        + '</div>'
        + '</div>'
        + '<a class="secondary-button" href="' + escapeHtml(getPracticeHref(target)) + '">' + escapeHtml(labels.practice) + '</a>'
        + '</article>';
    }).join('');
  }

  function renderHistory(data, labels, lang) {
    const rows = getAllPracticeRows(data);
    const container = document.getElementById('progress-history');
    const toggle = document.getElementById('progress-history-toggle');
    if (!rows.length) {
      container.innerHTML = '<p class="progress-empty-state">' + escapeHtml(labels.emptyHistory) + '</p>';
      toggle.hidden = true;
      return;
    }
    const visibleRows = historyExpanded ? rows : rows.slice(0, 3);
    container.innerHTML = visibleRows.map((row) => {
      const speedUnit = row.language === 'ja' ? 'CPM' : 'WPM';
      return '<article class="progress-history-row">'
        + '<span class="language-badge language-badge--' + escapeHtml(row.language) + '">' + escapeHtml(targetLanguageBadges[row.language] || row.language) + '</span>'
        + '<strong>' + escapeHtml(row.title) + '</strong>'
        + '<div class="progress-history-row__meta">'
        + '<span>' + escapeHtml(row.practiceType === 'translation' ? labels.translation : labels.original) + '</span>'
        + '<span>' + formatPercent(row.accuracy) + '</span>'
        + '<span>' + (Number.isFinite(row.speed) ? Math.round(row.speed) + ' ' + speedUnit : '—') + '</span>'
        + formatSelfAssessment(row.selfAssessment, labels)
        + '<time>' + escapeHtml(formatDate(row.practicedAt, lang)) + '</time>'
        + '</div>'
        + '</article>';
    }).join('');
    toggle.hidden = rows.length <= 3;
    toggle.textContent = historyExpanded ? labels.showLess : labels.showMore;
    toggle.setAttribute('aria-expanded', historyExpanded ? 'true' : 'false');
  }

  function renderLanguageTable(data, labels) {
    document.getElementById('progress-language-grid').innerHTML = uiLanguages.map((language) => {
      const languageTexts = data.practicedTexts.filter(({ text }) => text.language === language);
      const practiceCount = languageTexts.reduce((sum, { entry }) => sum + entry.completedCount, 0);
      const averageAccuracy = average(languageTexts.map(({ entry }) => Number.isFinite(entry.bestAccuracy) && entry.bestAccuracy > 0 ? entry.bestAccuracy : null));
      const speeds = languageTexts
        .filter(({ entry }) => isValidSpeed(entry.bestWpm, language))
        .map(({ entry }) => Number(entry.bestWpm));
      const counts = getExpressionCounts(data.expressionStatuses, language);
      const averageSpeed = average(speeds);
      const speedUnit = language === 'ja' ? 'CPM' : 'WPM';
      return '<tr class="language-progress-row">'
        + '<th scope="row" class="language-progress-cell language-progress-cell--name"><span class="language-badge language-badge--' + escapeHtml(language) + '">' + escapeHtml(targetLanguageBadges[language]) + '</span><span>' + escapeHtml(languageNames[language]?.[language] || language) + '</span></th>'
        + '<td class="language-progress-cell" data-label="' + escapeHtml(labels.textsPracticed) + '">' + languageTexts.length + '</td>'
        + '<td class="language-progress-cell" data-label="' + escapeHtml(labels.totalPracticeCount) + '">' + practiceCount + '</td>'
        + '<td class="language-progress-cell" data-label="' + escapeHtml(labels.averageAccuracy) + '">' + formatPercent(averageAccuracy) + '</td>'
        + '<td class="language-progress-cell" data-label="' + escapeHtml(labels.speed) + '">' + (Number.isFinite(averageSpeed) ? Math.round(averageSpeed) + ' ' + speedUnit : '—') + '</td>'
        + '<td class="language-progress-cell" data-label="' + escapeHtml(labels.reviewingExpressions) + '">' + counts.review + '</td>'
        + '<td class="language-progress-cell" data-label="' + escapeHtml(labels.learnedExpressions) + '">' + counts.learned + '</td>'
        + '</tr>';
    }).join('');
  }

  function renderPinned(data, labels) {
    const section = document.getElementById('progress-pinned-section');
    const container = document.getElementById('progress-pinned');
    if (!data.pinnedTargets.length) {
      section.hidden = true;
      container.innerHTML = '';
      return;
    }
    section.hidden = false;
    container.innerHTML = ['original', 'translation'].map((type) => {
      const items = data.pinnedTargets.filter((target) => target.practiceType === type);
      if (!items.length) {
        return '';
      }
      return '<div class="progress-pinned-group"><h3>' + escapeHtml(type === 'translation' ? labels.pinnedTranslation : labels.pinnedOriginal) + '</h3>'
        + '<div class="progress-pinned-list">'
        + items.map((target) => {
          const text = getTextById(target.textId);
          const language = target.practiceType === 'translation' ? target.practiceTranslation : text.language;
          return '<article class="progress-pinned-card"><div><strong>' + escapeHtml(text.title) + '</strong><span>' + escapeHtml(targetLanguageBadges[language] || language) + '</span></div><a class="secondary-button" href="' + escapeHtml(getPracticeHref(target)) + '">' + escapeHtml(labels.practice) + '</a></article>';
        }).join('')
        + '</div></div>';
    }).join('');
  }

  function renderProgressPage() {
    const lang = getSavedUiLanguage();
    const labels = progressLabels[lang] || progressLabels.en;
    const data = getProgressData();
    const uiLanguageSelect = document.getElementById('ui-language-select');
    document.documentElement.lang = lang;
    document.title = labels.title + ' · Polyglotyping';
    if (uiLanguageSelect) {
      uiLanguageSelect.value = lang;
    }
    document.getElementById('progress-title').textContent = labels.title;
    document.getElementById('progress-subtitle').textContent = labels.subtitle;
    document.querySelectorAll('[data-progress-label]').forEach((element) => {
      const value = labels[element.dataset.progressLabel];
      if (value) {
        element.textContent = value;
      }
    });
    document.querySelectorAll('[data-i18n]').forEach((element) => {
      const value = ui[lang]?.[element.dataset.i18n];
      if (typeof value === 'string') {
        element.textContent = value;
      }
    });
    renderOverview(data, labels);
    renderActivityCalendar(data, labels, lang);
    renderTrend(data, labels);
    renderAttention(data, labels, lang);
    renderHistory(data, labels, lang);
    renderLanguageTable(data, labels);
    renderPinned(data, labels);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const historyToggle = document.getElementById('progress-history-toggle');
    if (uiLanguageSelect) {
      uiLanguageSelect.addEventListener('change', () => {
        const nextLanguage = uiLanguages.includes(uiLanguageSelect.value) ? uiLanguageSelect.value : 'en';
        safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, nextLanguage);
        renderProgressPage();
      });
    }
    if (historyToggle) {
      historyToggle.addEventListener('click', () => {
        historyExpanded = !historyExpanded;
        renderProgressPage();
      });
    }
    renderProgressPage();
  });
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{progressLabels[defaultUiLang].title} · Polyglotyping</title>
  </head>
  <body>
    <SiteHeader active="progress" basePath={import.meta.env.BASE_URL} />
    <main class="page-shell page-layout progress-page">
      <section class="hero-card page-hero progress-hero">
        <div>
          <span class="section-kicker">Progress</span>
          <h1 class="page-hero__title" id="progress-title">{progressLabels[defaultUiLang].title}</h1>
          <p class="page-hero__subtitle" id="progress-subtitle">{progressLabels[defaultUiLang].subtitle}</p>
        </div>
      </section>

      <section class="progress-section" aria-labelledby="progress-overview-title">
        <div class="progress-section__header">
          <div>
            <h2 id="progress-overview-title" data-progress-label="overview">{progressLabels[defaultUiLang].overview}</h2>
            <p class="progress-section__description" data-progress-label="overviewSummary">{progressLabels[defaultUiLang].overviewSummary}</p>
          </div>
        </div>
        <div class="progress-grid progress-overview" id="progress-overview-grid"></div>
      </section>

      <div class="progress-insight-grid">
        <section class="progress-section progress-calendar-section" aria-labelledby="progress-activity-title">
          <div class="progress-section__header">
            <div>
              <h2 id="progress-activity-title" data-progress-label="activity">{progressLabels[defaultUiLang].activity}</h2>
              <p class="progress-section__description" id="progress-calendar-description">{progressLabels[defaultUiLang].activityDescription}</p>
            </div>
            <div class="progress-calendar-summary" id="progress-calendar-summary"></div>
          </div>
          <div class="progress-calendar" id="progress-calendar" aria-label="Practice activity"></div>
          <div class="progress-calendar-legend" aria-hidden="true">
            <span id="progress-calendar-legend-less">{progressLabels[defaultUiLang].less}</span>
            <span class="progress-calendar__day" data-intensity="0"></span>
            <span class="progress-calendar__day" data-intensity="1"></span>
            <span class="progress-calendar__day" data-intensity="2"></span>
            <span class="progress-calendar__day" data-intensity="3"></span>
            <span class="progress-calendar__day" data-intensity="4"></span>
            <span id="progress-calendar-legend-more">{progressLabels[defaultUiLang].more}</span>
          </div>
          <p class="progress-empty-state" id="progress-calendar-empty" hidden>{progressLabels[defaultUiLang].emptyActivity}</p>
        </section>

        <section class="progress-section progress-trend-section" aria-labelledby="progress-trend-title">
          <div class="progress-section__header">
            <h2 id="progress-trend-title" data-progress-label="recentTrend">{progressLabels[defaultUiLang].recentTrend}</h2>
          </div>
          <div class="progress-trend" id="progress-trend"></div>
        </section>
      </div>

      <section class="progress-section" aria-labelledby="progress-attention-title">
        <div class="progress-section__header">
          <h2 id="progress-attention-title" data-progress-label="needsAttention">{progressLabels[defaultUiLang].needsAttention}</h2>
        </div>
        <div class="progress-attention-list" id="progress-attention-list"></div>
      </section>

      <section class="progress-section" aria-labelledby="progress-history-title">
        <div class="progress-section__header">
          <h2 id="progress-history-title" data-progress-label="practiceHistory">{progressLabels[defaultUiLang].practiceHistory}</h2>
        </div>
        <div class="progress-history" id="progress-history"></div>
        <button
          class="secondary-button progress-history-toggle"
          id="progress-history-toggle"
          type="button"
          aria-expanded="false"
          hidden
        >
          {progressLabels[defaultUiLang].showMore}
        </button>
      </section>

      <section class="progress-section" aria-labelledby="progress-language-title">
        <div class="progress-section__header">
          <h2 id="progress-language-title" data-progress-label="byLanguage">{progressLabels[defaultUiLang].byLanguage}</h2>
        </div>
        <div class="language-progress-table-wrap">
          <table class="language-progress-table">
            <thead>
              <tr>
                <th scope="col" data-progress-label="language">{progressLabels[defaultUiLang].language}</th>
                <th scope="col" data-progress-label="textsPracticed">{progressLabels[defaultUiLang].textsPracticed}</th>
                <th scope="col" data-progress-label="totalPracticeCount">{progressLabels[defaultUiLang].totalPracticeCount}</th>
                <th scope="col" data-progress-label="averageAccuracy">{progressLabels[defaultUiLang].averageAccuracy}</th>
                <th scope="col" data-progress-label="speed">{progressLabels[defaultUiLang].speed}</th>
                <th scope="col" data-progress-label="reviewingExpressions">{progressLabels[defaultUiLang].reviewingExpressions}</th>
                <th scope="col" data-progress-label="learnedExpressions">{progressLabels[defaultUiLang].learnedExpressions}</th>
              </tr>
            </thead>
            <tbody id="progress-language-grid"></tbody>
          </table>
        </div>
      </section>

      <section
        class="progress-section"
        id="progress-pinned-section"
        aria-labelledby="progress-pinned-title"
        hidden
      >
        <div class="progress-section__header">
          <h2 id="progress-pinned-title" data-progress-label="pinnedPractice">{progressLabels[defaultUiLang].pinnedPractice}</h2>
        </div>
        <div id="progress-pinned"></div>
      </section>
    </main>

    <script type="module" set:html={clientScript}></script>
  </body>
</html>
