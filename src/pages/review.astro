---
import '../styles/global.scss';
import texts from '../data/texts.json' assert { type: 'json' };
import {
  uiLanguages,
  uiLanguageNames,
  uiText,
  languageNames,
  type UILang,
} from '../i18n/ui';

const defaultUiLang: UILang = 'en';
const expressions = Array.from(
  texts.reduce((map, item) => {
    item.expressions.forEach((expression) => {
      const expressionKey = `${item.language}::${expression.phrase}`;
      if (!map.has(expressionKey)) {
        map.set(expressionKey, { ...expression, language: item.language, textId: item.id });
      }
    });
    return map;
  }, new Map<string, { phrase: string; formInText?: string; ja: string; en: string; language: string; textId: string }>())
  .values()
);

const clientScript = `
  const expressions = ${JSON.stringify(expressions)};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = {
    no: '🇳🇴 Norsk',
    en: '🇬🇧 English',
    ja: '🇯🇵 日本語',
  };
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const TARGET_LANGUAGE_STORAGE_KEY = 'typingSiteTargetLanguage';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const EXPRESSION_PROGRESS_KEY = 'expressionProgress';
  const EXPRESSION_STATUSES = ['new', 'review', 'learned'];

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveExpressionStatuses(data) {
    safeWriteStorage(EXPRESSION_STATUS_KEY, JSON.stringify(data));
  }

  function loadExpressionProgress() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_PROGRESS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return typeof stored === 'string' && uiLanguages.includes(stored) ? stored : 'en';
  }

  function getSavedTargetLanguage() {
    const stored = safeReadStorage(TARGET_LANGUAGE_STORAGE_KEY);
    return stored === 'all' || uiLanguages.includes(stored) ? stored : 'no';
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function getExpressionStorageKey(expression) {
    return expression.language + '::' + expression.phrase;
  }

  function getExpressionStatus(expression) {
    const all = loadExpressionStatuses();
    const stored = all[getExpressionStorageKey(expression)] || all[expression.phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getExpressionStatusLabel(status, labels) {
    if (status === 'review') {
      return labels.expressionStatusReview;
    }
    if (status === 'learned') {
      return labels.expressionStatusLearned;
    }
    return labels.expressionStatusNew;
  }

  function getExpressionPractice(expression) {
    const progress = loadExpressionProgress();
    const entry = progress[getExpressionStorageKey(expression)] || progress[expression.phrase] || {};
    const practiceCount = Number.isFinite(entry.practiceCount) ? entry.practiceCount : 0;
    return {
      practiceCount,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : '',
    };
  }

  function getPracticeLevel(count) {
    if (count >= 5) {
      return '3';
    }
    if (count >= 3) {
      return '2';
    }
    if (count >= 1) {
      return '1';
    }
    return '0';
  }

  function getPracticeLabel(count, labels) {
    if (count <= 0) {
      return labels.expressionNotPracticed;
    }
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  document.addEventListener('DOMContentLoaded', () => {
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const reviewTitle = document.getElementById('review-title');
    const reviewGrid = document.getElementById('review-grid');
    const emptyState = document.getElementById('review-empty-state');
    const sortSelect = document.getElementById('review-sort');
    const filterSelect = document.getElementById('review-filter');
    const targetLanguageSelect = document.getElementById('review-target-language');

    function renderUiText(lang) {
      const labels = getUiText(lang);
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n;
        const value = labels[key];
        if (typeof value === 'string') {
          el.textContent = value;
        }
      });
      document.querySelectorAll('[data-i18n-target-language]').forEach((option) => {
        const value = option.dataset.i18nTargetLanguage;
        option.textContent = value === 'all' ? labels.allLanguages : languageNames[value]?.[lang] || value;
      });

      uiLanguageSelect.value = lang;
      reviewTitle.textContent = labels.reviewPageTitle;
      renderReviewItems();
    }

    function setExpressionStatus(expression, status) {
      const all = loadExpressionStatuses();
      all[getExpressionStorageKey(expression)] = status;
      saveExpressionStatuses(all);
      renderReviewItems();
    }

    function renderReviewItems() {
      const labels = getUiText(uiLanguageSelect.value);
      const selectedFilter = filterSelect.value;
      const selectedSort = sortSelect.value;
      const selectedTargetLanguage = targetLanguageSelect.value;
      const reviewItems = expressions
        .filter((expression) => selectedTargetLanguage === 'all' || expression.language === selectedTargetLanguage)
        .filter((expression) => selectedFilter === 'all' || getExpressionStatus(expression) === selectedFilter)
        .sort((a, b) => {
          const aPractice = getExpressionPractice(a);
          const bPractice = getExpressionPractice(b);
          if (selectedSort === 'least-practiced') {
            return aPractice.practiceCount - bPractice.practiceCount || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'recently-practiced') {
            return Date.parse(bPractice.lastPracticedAt || '1970-01-01') - Date.parse(aPractice.lastPracticedAt || '1970-01-01') || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'az') {
            return a.phrase.localeCompare(b.phrase);
          }
          return bPractice.practiceCount - aPractice.practiceCount || a.phrase.localeCompare(b.phrase);
        });

      reviewGrid.innerHTML = reviewItems.map((expression) => {
        const status = getExpressionStatus(expression);
        const label = getExpressionStatusLabel(status, labels);
        const { practiceCount } = getExpressionPractice(expression);
        const isHighRepetition = status === 'review' && practiceCount >= 10;
        const expressionKey = getExpressionStorageKey(expression);
        return ''
          + '<article class="expression-card review-expression-card" data-review-card data-expression-key="' + escapeHtml(expressionKey) + '" data-text-id="' + escapeHtml(expression.textId) + '" data-target-language="' + escapeHtml(expression.language) + '" data-status="' + status + '" data-practice-level="' + getPracticeLevel(practiceCount) + '" data-high-repetition="' + (isHighRepetition ? 'true' : 'false') + '">'
          + '<div class="expression-header">'
          + '<div class="expression-title-stack"><strong>' + escapeHtml(expression.phrase) + '</strong><span class="language-badge" data-target-language="' + escapeHtml(expression.language) + '">' + escapeHtml(targetLanguageBadges[expression.language]) + '</span></div>'
          + '<span class="status-button status-pill" data-status="' + status + '">' + escapeHtml(label) + '</span>'
          + '</div>'
          + '<p class="expression-practice review-card-practice"><span>' + escapeHtml(getPracticeLabel(practiceCount, labels)) + '</span><span class="high-repetition-label">' + escapeHtml(labels.highRepetition) + '</span></p>'
          + '<div class="review-card-meta">'
          + (expression.formInText && expression.formInText !== expression.phrase ? '<span class="expression-text-form"><span>' + escapeHtml(labels.expressionTextForm) + '</span>: ' + escapeHtml(expression.formInText) + '</span>' : '')
          + '</div>'
          + '<div class="review-card-meaning">'
          + '<p>' + escapeHtml(expression.ja) + '</p>'
          + '<p>' + escapeHtml(expression.en) + '</p>'
          + '</div>'
          + '<div class="review-card-actions">'
          + '<button class="secondary-button" type="button" data-review-action="keep" data-expression-key="' + escapeHtml(expressionKey) + '">' + escapeHtml(labels.keepReviewing) + '</button>'
          + '<button class="learned-button" type="button" data-review-action="learned" data-expression-key="' + escapeHtml(expressionKey) + '">' + escapeHtml(labels.markAsLearned) + '</button>'
          + '</div>'
          + '</article>';
      }).join('');

      emptyState.hidden = reviewItems.length > 0;

      reviewGrid.querySelectorAll('[data-review-card]').forEach((card) => {
        card.addEventListener('click', () => {
          window.location.href = '/text/' + card.dataset.textId;
        });
      });

      reviewGrid.querySelectorAll('[data-review-action]').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          const nextStatus = button.dataset.reviewAction === 'learned' ? 'learned' : 'review';
          const expression = expressions.find((item) => getExpressionStorageKey(item) === button.dataset.expressionKey);
          if (expression) {
            setExpressionStatus(expression, nextStatus);
          }
        });
      });
    }

    const savedUiLanguage = getSavedUiLanguage();
    const savedTargetLanguage = getSavedTargetLanguage();
    targetLanguageSelect.value = savedTargetLanguage;
    renderUiText(savedUiLanguage);

    sortSelect.addEventListener('change', renderReviewItems);
    filterSelect.addEventListener('change', renderReviewItems);
    targetLanguageSelect.addEventListener('change', (event) => {
      const lang = event.target.value === 'all' || uiLanguages.includes(event.target.value) ? event.target.value : 'no';
      safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, lang);
      targetLanguageSelect.value = lang;
      renderReviewItems();
    });

    uiLanguageSelect.addEventListener('change', (event) => {
      const lang = event.target.value;
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      renderUiText(lang);
    });
  });
`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{uiText[defaultUiLang].reviewPageTitle} · Read & Type</title>
  </head>
  <body>
    <main class="page-shell text-page">
      <section class="hero-card page-top">
        <div>
          <h1 class="text-title" id="review-title" data-i18n="reviewPageTitle">{uiText[defaultUiLang].reviewPageTitle}</h1>
          <p data-i18n="usefulExpressions">{uiText[defaultUiLang].usefulExpressions}</p>
        </div>
        <div class="top-actions">
          <a class="nav-link" href="/" data-i18n="title">{uiText[defaultUiLang].title}</a>
          <div class="language-switcher">
            <label for="ui-language-select" data-i18n="language">{uiText[defaultUiLang].language}</label>
            <select id="ui-language-select">
              {uiLanguages.map((lang) => (
                <option value={lang}>{uiLanguageNames[lang]}</option>
              ))}
            </select>
          </div>
        </div>
      </section>

      <section class="expressions-card">
        <div class="review-controls">
          <div class="filter-group">
            <label for="review-target-language" data-i18n="language">{uiText[defaultUiLang].language}</label>
            <select id="review-target-language">
              <option value="all" data-i18n-target-language="all">{uiText[defaultUiLang].allLanguages}</option>
              {uiLanguages.map((lang) => (
                <option value={lang} data-i18n-target-language={lang}>{languageNames[lang][defaultUiLang]}</option>
              ))}
            </select>
          </div>
          <div class="filter-group">
            <label for="review-filter" data-i18n="filterLabel">{uiText[defaultUiLang].filterLabel}</label>
            <select id="review-filter">
              <option value="review" data-i18n="expressionStatusReview">{uiText[defaultUiLang].expressionStatusReview}</option>
              <option value="learned" data-i18n="expressionStatusLearned">{uiText[defaultUiLang].expressionStatusLearned}</option>
              <option value="new" data-i18n="expressionStatusNew">{uiText[defaultUiLang].expressionStatusNew}</option>
              <option value="all" data-i18n="filterAll">{uiText[defaultUiLang].filterAll}</option>
            </select>
          </div>
          <div class="filter-group">
            <label for="review-sort" data-i18n="sortLabel">{uiText[defaultUiLang].sortLabel}</label>
            <select id="review-sort">
              <option value="most-practiced" data-i18n="sortMostPracticed">{uiText[defaultUiLang].sortMostPracticed}</option>
              <option value="least-practiced" data-i18n="sortLeastPracticed">{uiText[defaultUiLang].sortLeastPracticed}</option>
              <option value="recently-practiced" data-i18n="sortRecentlyPracticed">{uiText[defaultUiLang].sortRecentlyPracticed}</option>
              <option value="az" data-i18n="sortAlphabetical">{uiText[defaultUiLang].sortAlphabetical}</option>
            </select>
          </div>
        </div>
        <div id="review-grid" class="expressions-grid"></div>
        <p id="review-empty-state" class="empty-state" data-i18n="noReviewItems">{uiText[defaultUiLang].noReviewItems}</p>
      </section>
    </main>

    <script type="module" set:html={clientScript}></script>
  </body>
</html>
