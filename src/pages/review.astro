---
import '../styles/global.scss';
import SiteHeader from '../components/SiteHeader.astro';
import texts from '../data/texts.json' assert { type: 'json' };
import {
  uiLanguages,
  uiText,
  languageNames,
  type UILang,
} from '../i18n/ui';

const defaultUiLang: UILang = 'en';
const appBasePath = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const appHref = (path: string) => `${appBasePath}${path.replace(/^\//, '')}`;
const reviewModeDescriptions = {
  no: {
    cardList: 'Se kortene i dette utvalget',
    flashcards: 'Ta en 5-spørsmålskviss med dette utvalget',
  },
  en: {
    cardList: 'See the cards in this set',
    flashcards: 'Take a 5-question quiz with this set',
  },
  ja: {
    cardList: 'カードを見て管理する',
    flashcards: 'この条件で5問クイズする',
  },
} as const;
type ReviewExpression = {
  phrase: string;
  storageKey?: string;
  formInText?: string;
  ja: string;
  en: string;
  no?: string;
  example?: string;
  exampleJa?: string;
  exampleEn?: string;
  exampleNo?: string;
  language: string;
  textId: string;
  textTitle: string;
  text: string;
  level: string;
};

const expressions = Array.from(
  texts.reduce((map, item) => {
    item.expressions.forEach((expression) => {
      const expressionKey = `${item.language}::${expression.phrase}`;
      if (!map.has(expressionKey)) {
        map.set(expressionKey, {
          ...expression,
          language: item.language,
          textId: item.id,
          textTitle: item.title,
          text: item.text,
          level: item.level,
        });
      }
    });
    return map;
  }, new Map<string, ReviewExpression>())
  .values()
);

const clientScript = `
  const BASE_PATH = ${JSON.stringify(import.meta.env.BASE_URL)};
  const expressions = ${JSON.stringify(expressions)};
  const sourceTexts = ${JSON.stringify(texts.map((item) => ({ id: item.id, title: item.title })))};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = {
    no: 'NO',
    en: 'EN',
    ja: 'JA',
  };
  const targetLanguageOptionLabels = {
    no: 'Norsk',
    en: 'English',
    ja: '日本語',
  };
  const reviewModeDescriptions = ${JSON.stringify(reviewModeDescriptions)};
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const TARGET_LANGUAGE_STORAGE_KEY = 'typingSiteTargetLanguage';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const EXPRESSION_PROGRESS_KEY = 'expressionProgress';
  const EXPRESSION_QUIZ_STATS_KEY = 'expressionQuizStats';
  const EXPRESSION_STATUSES = ['new', 'review', 'learned'];
  const levelSortRank = {
    a1: 0,
    a2: 1,
    b1: 2,
    b2: 3,
    c1: 4,
    natural: 5,
  };
  const sourceTextTitles = Object.fromEntries(sourceTexts.map((item) => [item.id, item.title]));
  const legacyLevelMap = {
    basic: 'a1',
    useful: 'a2',
    daily: 'b1',
    advanced: 'b2',
    natural: 'natural',
  };

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function getAppHref(path) {
    const base = BASE_PATH || '/';
    const normalizedBase = base.endsWith('/') ? base : base + '/';
    const normalizedPath = String(path).replace(/^\\//, '');
    return normalizedBase + normalizedPath;
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveExpressionStatuses(data) {
    safeWriteStorage(EXPRESSION_STATUS_KEY, JSON.stringify(data));
  }

  function loadExpressionProgress() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_PROGRESS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function loadExpressionQuizStats() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_QUIZ_STATS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveExpressionQuizStats(data) {
    safeWriteStorage(EXPRESSION_QUIZ_STATS_KEY, JSON.stringify(data));
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return typeof stored === 'string' && uiLanguages.includes(stored) ? stored : 'en';
  }

  function normalizeTargetLanguageValue(value) {
    if (value === 'all') {
      return 'all';
    }
    if (typeof value !== 'string') {
      return 'no';
    }
    const normalized = value.toLowerCase();
    return uiLanguages.includes(normalized) ? normalized : 'no';
  }

  function getSavedTargetLanguage() {
    const stored = safeReadStorage(TARGET_LANGUAGE_STORAGE_KEY);
    return normalizeTargetLanguageValue(stored);
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function getLanguageTitle(value, lang) {
    return languageNames[value]?.[lang] || value;
  }

  function getLanguageBadgeHtml(value, lang) {
    const label = targetLanguageBadges[value] || value;
    const title = getLanguageTitle(value, lang);
    return '<span class="language-badge language-badge--' + escapeHtml(value) + '" data-target-language="' + escapeHtml(value) + '" title="' + escapeHtml(title) + '" aria-label="' + escapeHtml(title) + '">' + escapeHtml(label) + '</span>';
  }

  function normalizeLevelKey(level) {
    if (legacyLevelMap[level]) {
      return legacyLevelMap[level];
    }
    return levelSortRank[level] !== undefined ? level : 'natural';
  }

  function getExpressionStorageKey(expression) {
    return expression.language + '::' + (expression.storageKey || expression.phrase);
  }

  function getExpressionStatus(expression) {
    const all = loadExpressionStatuses();
    const stored = all[getExpressionStorageKey(expression)] || all[expression.storageKey] || all[expression.language + '::' + expression.phrase] || all[expression.phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getExpressionStatusLabel(status, labels) {
    if (status === 'review') {
      return labels.expressionStatusReview;
    }
    if (status === 'learned') {
      return labels.expressionStatusLearned;
    }
    return labels.expressionStatusNew;
  }

  function getExpressionPractice(expression) {
    const progress = loadExpressionProgress();
    const entry = progress[getExpressionStorageKey(expression)] || progress[expression.storageKey] || progress[expression.language + '::' + expression.phrase] || progress[expression.phrase] || {};
    const practiceCount = Number.isFinite(entry.practiceCount) ? entry.practiceCount : 0;
    return {
      practiceCount,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : '',
    };
  }

  function getPracticeLevel(count) {
    if (count >= 5) {
      return '3';
    }
    if (count >= 3) {
      return '2';
    }
    if (count >= 1) {
      return '1';
    }
    return '0';
  }

  function getPracticeLabel(count, labels) {
    if (count <= 0) {
      return labels.expressionNotPracticed;
    }
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function getExplanationLanguageOrder(lang) {
    return [lang, ...uiLanguages.filter((item) => item !== lang)];
  }

  function getLocalizedExpressionMeanings(expression, lang) {
    return getExplanationLanguageOrder(lang)
      .map((language) => ({ language, value: expression[language] }))
      .filter((entry) => typeof entry.value === 'string' && entry.value.trim());
  }

  function getExpressionExampleMap(expression) {
    return {
      default: typeof expression.example === 'string' ? expression.example : '',
      ja: typeof expression.exampleJa === 'string' ? expression.exampleJa : '',
      en: typeof expression.exampleEn === 'string' ? expression.exampleEn : '',
      no: typeof expression.exampleNo === 'string' ? expression.exampleNo : '',
    };
  }

  function getLocalizedExpressionExamples(expression) {
    const examples = getExpressionExampleMap(expression);
    const order = ['default', ...uiLanguages.filter((language) => language !== expression.language)];
    return order
      .map((language) => ({ language, value: examples[language] }))
      .filter((entry, index, array) => typeof entry.value === 'string' && entry.value.trim() && array.findIndex((item) => item.value === entry.value) === index);
  }

  function renderReviewExampleSection(expression, labels, uiLang) {
    const examples = getLocalizedExpressionExamples(expression);
    if (!examples.length) {
      return '';
    }

    return ''
      + '<div class="review-card-examples" data-review-examples>'
      + '<button class="example-toggle" type="button" data-review-example-toggle aria-expanded="false" aria-label="' + escapeHtml(labels.showExpressionExample) + '" data-show-label="' + escapeHtml(labels.showExpressionExample) + '" data-hide-label="' + escapeHtml(labels.hideExpressionExample) + '"><span>' + escapeHtml(labels.expressionExample) + '</span><span class="example-toggle__icon" aria-hidden="true">⌄</span></button>'
      + '<div class="expression-example-list review-example-list example-section" hidden>'
      + '<span class="expression-example-label">' + escapeHtml(labels.expressionExample) + '</span>'
      + examples.map((entry) => '<p>' + (entry.language !== 'default' ? getLanguageBadgeHtml(entry.language, uiLang) + ' ' : '') + escapeHtml(entry.value) + '</p>').join('')
      + '</div>'
      + '</div>';
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  document.addEventListener('DOMContentLoaded', () => {
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const reviewTitle = document.getElementById('review-title');
    const reviewGrid = document.getElementById('review-grid');
    const reviewModeButtons = Array.from(document.querySelectorAll('[data-review-mode]'));
    const flashcardOverlay = document.getElementById('flashcard-overlay');
    const flashcardStage = document.getElementById('flashcard-stage');
    const flashcardEmptyState = document.getElementById('flashcard-empty-state');
    const flashcardProgress = document.getElementById('flashcard-progress');
    const flashcardClose = document.getElementById('flashcard-close');
    const emptyState = document.getElementById('review-empty-state');
    const sortSelect = document.getElementById('review-sort');
    const statusFilterButton = document.getElementById('review-filter-button');
    const statusFilterMenu = document.getElementById('review-filter-menu');
    const statusFilterOptions = Array.from(document.querySelectorAll('[data-review-filter-option]'));
    const statusFilterButtonLabel = document.getElementById('review-filter-button-label');
    const statusFilterButtonCount = document.getElementById('review-filter-button-count');
    const targetLanguageSelect = document.getElementById('review-target-language');
    const targetLanguageButton = document.getElementById('review-target-language-button');
    const targetLanguageMenu = document.getElementById('review-target-language-menu');
    const targetLanguageOptions = Array.from(document.querySelectorAll('[data-target-language-option]'));
    const targetLanguageButtonLabel = document.getElementById('review-target-language-button-label');
    const sortButton = document.getElementById('review-sort-button');
    const sortMenu = document.getElementById('review-sort-menu');
    const sortOptions = Array.from(document.querySelectorAll('[data-sort-option]'));
    const sortButtonLabel = document.getElementById('review-sort-button-label');
    const reviewSummaryTotalValue = document.getElementById('review-summary-total-value');
    const reviewSummaryStatusValue = document.getElementById('review-summary-status-value');
    const reviewSummarySortValue = document.getElementById('review-summary-sort-value');
    let selectedFilter = 'review';
    let reviewMode = 'list';
    let flashcardIndex = 0;
    let flashcardSessionStart = 0;
    let flashcardSessionQueue = [];
    let flashcardRetryKeys = new Set();
    let flashcardCurrentChoices = [];
    let flashcardCurrentKey = '';
    let flashcardSelectedAnswer = '';
    let flashcardResult = null;
    let flashcardSessionStats = { correct: 0, wrong: 0, learned: 0 };
    let flashcardSessionComplete = false;
    const FLASHCARD_SESSION_SIZE = 5;

    function getTargetLanguageLabel(value, lang) {
      const labels = getUiText(lang);
      return value === 'all' ? labels.allLanguages : targetLanguageOptionLabels[value] || value;
    }

    function getSortLabel(value, labels) {
      if (value === 'least-practiced') {
        return labels.sortLeastPracticed;
      }
      if (value === 'recently-practiced') {
        return labels.sortRecentlyPracticed;
      }
      if (value === 'easiest') {
        return labels.sortEasiestFirst;
      }
      if (value === 'hardest') {
        return labels.sortHardestFirst;
      }
      if (value === 'az') {
        return labels.sortAlphabetical;
      }
      return labels.sortMostPracticed;
    }

    function updateSelectDropdownUi(select, options, buttonLabel, getLabel) {
      const selectedValue = select.value;
      options.forEach((option) => {
        const value = option.dataset.dropdownValue;
        const isSelected = value === selectedValue;
        option.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        option.querySelector('[data-filter-option-label]').textContent = getLabel(value);
      });
      buttonLabel.textContent = getLabel(selectedValue);
    }

    function closeSelectDropdown(button, menu) {
      button.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
    }

    function openSelectDropdown(button, menu, options, selectedValue) {
      button.setAttribute('aria-expanded', 'true');
      menu.hidden = false;
      const selectedOption = options.find((option) => option.dataset.dropdownValue === selectedValue) || options[0];
      selectedOption?.focus();
    }

    function setupSelectDropdown({ select, button, menu, options, buttonLabel, getLabel, onChange }) {
      const close = () => closeSelectDropdown(button, menu);
      const update = () => updateSelectDropdownUi(select, options, buttonLabel, getLabel);
      const chooseValue = (value) => {
        select.value = value;
        close();
        update();
        onChange(value);
      };

      button.addEventListener('click', () => {
        if (menu.hidden) {
          openSelectDropdown(button, menu, options, select.value);
        } else {
          close();
        }
      });
      button.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openSelectDropdown(button, menu, options, select.value);
        }
      });
      options.forEach((option, index) => {
        option.addEventListener('click', () => {
          chooseValue(option.dataset.dropdownValue);
        });
        option.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            chooseValue(option.dataset.dropdownValue);
          }
          if (event.key === 'Escape') {
            event.preventDefault();
            close();
            button.focus();
          }
          if (event.key === 'ArrowDown') {
            event.preventDefault();
            options[(index + 1) % options.length].focus();
          }
          if (event.key === 'ArrowUp') {
            event.preventDefault();
            options[(index - 1 + options.length) % options.length].focus();
          }
        });
      });
      document.addEventListener('click', (event) => {
        if (!button.contains(event.target) && !menu.contains(event.target)) {
          close();
        }
      });

      return { update, close };
    }

    function renderUiText(lang) {
      const labels = getUiText(lang);
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n;
        const value = labels[key];
        if (typeof value === 'string') {
          el.textContent = value;
        }
      });
      document.querySelectorAll('[data-i18n-target-language]').forEach((option) => {
        const value = option.dataset.i18nTargetLanguage;
        option.textContent = getTargetLanguageLabel(value, lang);
      });

      uiLanguageSelect.value = lang;
      reviewTitle.textContent = labels.reviewPageTitle;
      reviewModeButtons.forEach((button) => {
        const description = reviewModeDescriptions[lang] || reviewModeDescriptions.en;
        if (button.dataset.reviewMode === 'flashcards') {
          const titleNode = button.querySelector('[data-review-mode-label]');
          const hintNode = button.querySelector('[data-review-mode-hint]');
          if (titleNode) {
            titleNode.textContent = labels.reviewModeFlashcards;
          }
          if (hintNode) {
            hintNode.textContent = description.flashcards;
          }
        } else {
          const titleNode = button.querySelector('[data-review-mode-label]');
          const hintNode = button.querySelector('[data-review-mode-hint]');
          if (titleNode) {
            titleNode.textContent = labels.reviewModeCardList;
          }
          if (hintNode) {
            hintNode.textContent = description.cardList;
          }
        }
      });
      if (flashcardClose) {
        flashcardClose.setAttribute('aria-label', labels.flashcardClose);
        flashcardClose.title = labels.flashcardClose;
      }
      targetLanguageDropdown.update();
      sortDropdown.update();
      renderReviewItems();
      updateReviewModeUi();
    }

    function getStatusFilterLabel(status, labels) {
      if (status === 'all') {
        return labels.filterAll;
      }
      return getExpressionStatusLabel(status, labels);
    }

    function getExpressionsForSelectedTargetLanguage() {
      const selectedTargetLanguage = targetLanguageSelect.value;
      return expressions.filter((expression) => selectedTargetLanguage === 'all' || expression.language === selectedTargetLanguage);
    }

    function getStatusCounts() {
      const counts = { new: 0, review: 0, learned: 0, all: 0 };
      getExpressionsForSelectedTargetLanguage().forEach((expression) => {
        const status = getExpressionStatus(expression);
        if (counts[status] !== undefined) {
          counts[status] += 1;
        }
        counts.all += 1;
      });
      return counts;
    }

    function closeStatusFilter() {
      statusFilterButton.setAttribute('aria-expanded', 'false');
      statusFilterMenu.hidden = true;
    }

    function openStatusFilter() {
      statusFilterButton.setAttribute('aria-expanded', 'true');
      statusFilterMenu.hidden = false;
      const selectedOption = statusFilterOptions.find((option) => option.dataset.reviewFilterOption === selectedFilter) || statusFilterOptions[0];
      selectedOption?.focus();
    }

    function updateStatusFilterUi() {
      const labels = getUiText(uiLanguageSelect.value);
      const counts = getStatusCounts();
      statusFilterOptions.forEach((option) => {
        const status = option.dataset.reviewFilterOption;
        const isSelected = status === selectedFilter;
        option.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        option.querySelector('[data-filter-option-label]').textContent = getStatusFilterLabel(status, labels);
        option.querySelector('[data-filter-option-count]').textContent = counts[status] || 0;
      });
      statusFilterButtonLabel.textContent = getStatusFilterLabel(selectedFilter, labels);
      statusFilterButtonCount.textContent = counts[selectedFilter] || 0;
      if (reviewSummaryTotalValue) {
        reviewSummaryTotalValue.textContent = counts.all || 0;
      }
      if (reviewSummaryStatusValue) {
        reviewSummaryStatusValue.textContent = getStatusFilterLabel(selectedFilter, labels);
      }
      if (reviewSummarySortValue) {
        reviewSummarySortValue.textContent = getSortLabel(sortSelect.value, labels);
      }
    }

    function setStatusFilter(status) {
      selectedFilter = ['review', 'learned', 'new', 'all'].includes(status) ? status : 'review';
      closeStatusFilter();
      if (isFlashcardOpen()) {
        resetFlashcardSession(0);
      }
      renderReviewItems();
    }

    function saveExpressionStatus(expression, status) {
      const all = loadExpressionStatuses();
      all[getExpressionStorageKey(expression)] = status;
      saveExpressionStatuses(all);
    }

    function setExpressionStatus(expression, status) {
      if (!EXPRESSION_STATUSES.includes(status)) {
        return;
      }
      saveExpressionStatus(expression, status);
      const expressionKey = getExpressionStorageKey(expression);
      const card = Array.from(reviewGrid.querySelectorAll('[data-review-card]'))
        .find((item) => item.dataset.expressionKey === expressionKey);
      if (card) {
        updateReviewCardStatus(card, expression, status);
      } else {
        updateStatusFilterUi();
      }
    }

    function getNextExpressionStatus(status) {
      if (status === 'new') {
        return 'review';
      }
      if (status === 'review') {
        return 'learned';
      }
      return 'new';
    }

    function updateReviewCardStatus(card, expression, status) {
      const labels = getUiText(uiLanguageSelect.value);
      const { practiceCount } = getExpressionPractice(expression);
      const statusPill = card.querySelector('.status-pill');
      card.dataset.status = status;
      card.dataset.highRepetition = status === 'review' && practiceCount >= 10 ? 'true' : 'false';
      if (statusPill) {
        statusPill.dataset.status = status;
        statusPill.textContent = getExpressionStatusLabel(status, labels);
      }
      updateStatusFilterUi();
    }

    function cycleExpressionStatus(expression, card) {
      const nextStatus = getNextExpressionStatus(getExpressionStatus(expression));
      saveExpressionStatus(expression, nextStatus);
      updateReviewCardStatus(card, expression, nextStatus);
    }

    function getFilteredReviewItems(statusMode = selectedFilter) {
      const selectedSort = sortSelect.value;
      const selectedTargetLanguage = targetLanguageSelect.value;
      return expressions
        .filter((expression) => selectedTargetLanguage === 'all' || expression.language === selectedTargetLanguage)
        .filter((expression) => {
          if (statusMode === 'all') {
            return true;
          }
          if (['new', 'review', 'learned'].includes(statusMode)) {
            return getExpressionStatus(expression) === statusMode;
          }
          return getExpressionStatus(expression) !== 'learned';
        })
        .sort((a, b) => {
          const aPractice = getExpressionPractice(a);
          const bPractice = getExpressionPractice(b);
          if (selectedSort === 'least-practiced') {
            return aPractice.practiceCount - bPractice.practiceCount || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'recently-practiced') {
            return Date.parse(bPractice.lastPracticedAt || '1970-01-01') - Date.parse(aPractice.lastPracticedAt || '1970-01-01') || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'easiest') {
            return levelSortRank[normalizeLevelKey(a.level)] - levelSortRank[normalizeLevelKey(b.level)] || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'hardest') {
            return levelSortRank[normalizeLevelKey(b.level)] - levelSortRank[normalizeLevelKey(a.level)] || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'az') {
            return a.phrase.localeCompare(b.phrase);
          }
          return bPractice.practiceCount - aPractice.practiceCount || a.phrase.localeCompare(b.phrase);
        });
    }

    function getFlashcardCandidateItems() {
      return getFilteredReviewItems(selectedFilter);
    }

    function renderReviewItems() {
      const labels = getUiText(uiLanguageSelect.value);
      updateStatusFilterUi();
      const reviewItems = getFilteredReviewItems();

      reviewGrid.innerHTML = reviewItems.map((expression) => {
        const status = getExpressionStatus(expression);
        const label = getExpressionStatusLabel(status, labels);
        const { practiceCount } = getExpressionPractice(expression);
        const isHighRepetition = status === 'review' && practiceCount >= 10;
        const expressionKey = getExpressionStorageKey(expression);
        const meanings = getLocalizedExpressionMeanings(expression, uiLanguageSelect.value);
        const examples = renderReviewExampleSection(expression, labels, uiLanguageSelect.value);
        return ''
          + '<article class="expression-card review-expression-card review-card" data-review-card data-expression-key="' + escapeHtml(expressionKey) + '" data-text-id="' + escapeHtml(expression.textId) + '" data-target-language="' + escapeHtml(expression.language) + '" data-status="' + status + '" data-practice-level="' + getPracticeLevel(practiceCount) + '" data-high-repetition="' + (isHighRepetition ? 'true' : 'false') + '">'
          + '<div class="review-card__body">'
          + '<div class="expression-header">'
          + '<div class="expression-title-stack"><strong>' + escapeHtml(expression.phrase) + '</strong></div>'
          + '<div class="review-card__status-area">'
          + '<span class="status-button status-pill review-card__status-badge" data-status="' + status + '">' + escapeHtml(label) + '</span>'
          + '<span class="review-card__practice-count">' + escapeHtml(getPracticeLabel(practiceCount, labels)) + '</span>'
          + '</div>'
          + '</div>'
          + '<div class="review-card-meta">'
          + (expression.formInText && expression.formInText !== expression.phrase ? '<span class="expression-text-form"><span>' + escapeHtml(labels.expressionTextForm) + '</span>: ' + escapeHtml(expression.formInText) + '</span>' : '')
          + '</div>'
          + '<div class="review-card-meaning">'
          + meanings.map((entry) => '<p>' + getLanguageBadgeHtml(entry.language, uiLanguageSelect.value) + ' ' + escapeHtml(entry.value) + '</p>').join('')
          + '</div>'
          + examples
          + '</div>'
          + '<div class="review-card-actions review-card__actions">'
          + '<button class="secondary-button" type="button" data-review-open-text data-text-id="' + escapeHtml(expression.textId) + '">' + escapeHtml(labels.practiceThisText) + '</button>'
          + '</div>'
          + '</article>';
      }).join('');

      emptyState.hidden = reviewItems.length > 0;

      reviewGrid.querySelectorAll('[data-review-card]').forEach((card) => {
        card.addEventListener('click', () => {
          const expression = expressions.find((item) => getExpressionStorageKey(item) === card.dataset.expressionKey);
          if (expression) {
            cycleExpressionStatus(expression, card);
          }
        });
      });

      reviewGrid.querySelectorAll('[data-review-examples]').forEach((section) => {
        section.addEventListener('click', (event) => {
          event.stopPropagation();
        });
      });

      reviewGrid.querySelectorAll('[data-review-example-toggle]').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          const exampleList = button.parentElement?.querySelector('.review-example-list');
          if (!exampleList) {
            return;
          }
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          button.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
          button.setAttribute('aria-label', isExpanded ? button.dataset.showLabel : button.dataset.hideLabel);
          button.classList.toggle('is-open', !isExpanded);
          const icon = button.querySelector('.example-toggle__icon');
          if (icon) {
            icon.textContent = isExpanded ? '⌄' : '⌃';
          }
          exampleList.hidden = isExpanded;
        });
      });

      reviewGrid.querySelectorAll('[data-review-open-text]').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          window.location.href = getAppHref('text/' + encodeURIComponent(button.dataset.textId));
        });
      });

      if (isFlashcardOpen()) {
        renderFlashcard();
      }
    }

    function getExpressionContextNeedle(expression) {
      const candidates = [
        expression.formInText,
        expression.phrase,
        expression.storageKey,
      ];
      return candidates.find((value) => typeof value === 'string' && value.trim() && expression.text.includes(value)) || '';
    }

    function getExpressionContextText(expression) {
      const source = typeof expression.text === 'string' && expression.text.trim()
        ? expression.text
        : expression.example || expression.formInText || expression.phrase;
      const needle = getExpressionContextNeedle(expression);
      if (!needle) {
        return source.length > 150 ? source.slice(0, 147).trimEnd() + '...' : source;
      }
      const sentences = source.match(/[^.!?。！？]+[.!?。！？]?/g) || [source];
      const sentence = sentences.find((item) => item.includes(needle)) || source;
      if (sentence.length <= 150) {
        return sentence.trim();
      }
      const index = sentence.indexOf(needle);
      const start = Math.max(0, index - 46);
      const end = Math.min(sentence.length, index + needle.length + 70);
      return (start > 0 ? '...' : '') + sentence.slice(start, end).trim() + (end < sentence.length ? '...' : '');
    }

    function getExpressionContextHtml(expression) {
      const context = getExpressionContextText(expression);
      const needle = getExpressionContextNeedle(expression);
      if (!needle) {
        return escapeHtml(context);
      }
      const index = context.indexOf(needle);
      if (index < 0) {
        return escapeHtml(context);
      }
      return escapeHtml(context.slice(0, index))
        + '<mark class="flashcard-context-highlight">' + escapeHtml(context.slice(index, index + needle.length)) + '</mark>'
        + escapeHtml(context.slice(index + needle.length));
    }

    function getQuizMeaningLanguageOrder(uiLang) {
      return [uiLang, 'ja', 'en', 'no']
        .filter((value, index, array) => value && array.indexOf(value) === index);
    }

    function getMeaningInLanguage(expression, lang) {
      const value = expression[lang];
      return typeof value === 'string' && value.trim() ? value.trim() : '';
    }

    function getAvailableMeaningLanguages(pool, requiredCount = 4) {
      return ['ja', 'en', 'no'].filter((lang) => {
        const meanings = new Set();
        pool.forEach((expression) => {
          const meaning = getMeaningInLanguage(expression, lang);
          if (meaning) {
            meanings.add(meaning);
          }
        });
        return meanings.size >= requiredCount;
      });
    }

    function getQuizChoiceLanguage(expression, uiLang, pool) {
      const candidatePool = [...pool, ...expressions]
        .filter((item, index, array) => array.findIndex((candidate) => getExpressionStorageKey(candidate) === getExpressionStorageKey(item)) === index);
      const languageOrder = [
        ...getQuizMeaningLanguageOrder(uiLang),
        ...getAvailableMeaningLanguages(candidatePool),
      ].filter((value, index, array) => value && array.indexOf(value) === index);
      return languageOrder.find((lang) => {
        const correct = getMeaningInLanguage(expression, lang);
        if (!correct) {
          return false;
        }
        const wrongChoices = new Set();
        candidatePool.forEach((item) => {
          if (getExpressionStorageKey(item) === getExpressionStorageKey(expression)) {
            return;
          }
          const meaning = getMeaningInLanguage(item, lang);
          if (meaning && meaning !== correct) {
            wrongChoices.add(meaning);
          }
        });
        return wrongChoices.size >= 3;
      }) || '';
    }

    function shuffleItems(items) {
      const copy = [...items];
      for (let index = copy.length - 1; index > 0; index -= 1) {
        const swapIndex = Math.floor(Math.random() * (index + 1));
        [copy[index], copy[swapIndex]] = [copy[swapIndex], copy[index]];
      }
      return copy;
    }

    function getFlashcardChoices(expression, uiLang, pool) {
      const choiceLanguage = getQuizChoiceLanguage(expression, uiLang, pool);
      if (!choiceLanguage) {
        return [];
      }
      const correct = getMeaningInLanguage(expression, choiceLanguage);
      const expressionKey = getExpressionStorageKey(expression);
      const preferredPool = pool.filter((item) => getExpressionStorageKey(item) !== expressionKey);
      const fallbackPool = expressions.filter((item) => getExpressionStorageKey(item) !== expressionKey);
      const wrongChoices = [];

      [...preferredPool, ...fallbackPool].forEach((item) => {
        const meaning = getMeaningInLanguage(item, choiceLanguage);
        if (meaning && meaning !== correct && !wrongChoices.includes(meaning)) {
          wrongChoices.push(meaning);
        }
      });

      const choices = [
        { text: correct, isCorrect: true },
        ...wrongChoices.slice(0, 3).map((text) => ({ text, isCorrect: false })),
      ];

      return shuffleItems(choices);
    }

    function updateExpressionQuizStats(expression, isCorrect) {
      const allStats = loadExpressionQuizStats();
      const key = getExpressionStorageKey(expression);
      const previous = allStats[key] && typeof allStats[key] === 'object' ? allStats[key] : {};
      const next = {
        correctStreak: isCorrect ? Number(previous.correctStreak || 0) + 1 : 0,
        totalCorrect: Number(previous.totalCorrect || 0) + (isCorrect ? 1 : 0),
        totalWrong: Number(previous.totalWrong || 0) + (isCorrect ? 0 : 1),
        lastResult: isCorrect ? 'correct' : 'wrong',
        lastAnsweredAt: new Date().toISOString(),
      };
      allStats[key] = next;
      saveExpressionQuizStats(allStats);
      return next;
    }

    function getFlashcardPriorityWeight(expression, quizStats) {
      const key = getExpressionStorageKey(expression);
      const stats = quizStats[key] && typeof quizStats[key] === 'object' ? quizStats[key] : {};
      const status = getExpressionStatus(expression);
      const lastAnsweredTime = Date.parse(stats.lastAnsweredAt || '');
      const answeredRecently = Number.isFinite(lastAnsweredTime) && Date.now() - lastAnsweredTime <= 7 * 24 * 60 * 60 * 1000;
      let weight = 1;
      if (answeredRecently && stats.lastResult === 'wrong') {
        weight += 5;
      }
      if (Number(stats.correctStreak || 0) === 2) {
        weight += 4;
      }
      if (status === 'new') {
        weight += 3;
      } else if (status === 'review') {
        weight += 2;
      }
      return weight;
    }

    function takeWeightedRandomItems(items, count) {
      const quizStats = loadExpressionQuizStats();
      const remaining = [...items];
      const selected = [];
      while (remaining.length && selected.length < count) {
        const weightedItems = remaining.map((item) => ({
          item,
          weight: getFlashcardPriorityWeight(item, quizStats),
        }));
        const totalWeight = weightedItems.reduce((sum, entry) => sum + entry.weight, 0);
        let randomWeight = Math.random() * totalWeight;
        let selectedIndex = 0;
        for (let index = 0; index < weightedItems.length; index += 1) {
          randomWeight -= weightedItems[index].weight;
          if (randomWeight <= 0) {
            selectedIndex = index;
            break;
          }
        }
        selected.push(remaining[selectedIndex]);
        remaining.splice(selectedIndex, 1);
      }
      return selected;
    }

    function resetFlashcardAnswerState() {
      flashcardCurrentChoices = [];
      flashcardCurrentKey = '';
      flashcardSelectedAnswer = '';
      flashcardResult = null;
    }

    function resetFlashcardSession(start = flashcardSessionStart) {
      const reviewItems = getFlashcardCandidateItems();
      const eligibleItems = reviewItems.filter((expression) => getQuizChoiceLanguage(expression, uiLanguageSelect.value, reviewItems));
      flashcardSessionStart = eligibleItems.length ? start % eligibleItems.length : 0;
      const sessionSize = Math.min(FLASHCARD_SESSION_SIZE, eligibleItems.length);
      flashcardSessionQueue = takeWeightedRandomItems(eligibleItems, sessionSize);
      flashcardIndex = 0;
      flashcardRetryKeys = new Set();
      flashcardSessionStats = { correct: 0, wrong: 0, learned: 0 };
      flashcardSessionComplete = false;
      resetFlashcardAnswerState();
    }

    function getFlashcardSessionItems() {
      const reviewItems = getFlashcardCandidateItems();
      if (flashcardSessionStart >= reviewItems.length) {
        flashcardSessionStart = 0;
      }
      if (!flashcardSessionQueue.length && reviewItems.length) {
        resetFlashcardSession(flashcardSessionStart);
      }
      return flashcardSessionQueue;
    }

    function isFlashcardOpen() {
      return flashcardOverlay && !flashcardOverlay.hidden;
    }

    function closeFlashcards() {
      reviewMode = 'list';
      resetFlashcardAnswerState();
      flashcardSessionComplete = false;
      if (flashcardOverlay) {
        flashcardOverlay.hidden = true;
      }
      updateReviewModeUi();
    }

    function openFlashcards() {
      reviewMode = 'flashcards';
      resetFlashcardSession(0);
      if (flashcardOverlay) {
        flashcardOverlay.hidden = false;
      }
      updateReviewModeUi();
      renderFlashcard();
    }

    function renderFlashcardCompletion(labels, reviewItems) {
      if (flashcardProgress) {
        flashcardProgress.hidden = true;
      }
      flashcardStage.hidden = false;
      const learnedCount = flashcardSessionStats.learned;
      const hasMistakes = flashcardSessionStats.wrong > 0;
      flashcardStage.innerHTML = ''
        + '<div class="flashcard-session-complete">'
        + '<strong>' + escapeHtml(labels.flashcardSessionComplete) + '</strong>'
        + '<p class="flashcard-session-subtitle">' + escapeHtml(labels.flashcardSessionSubtitle) + '</p>'
        + '<div class="flashcard-session-stats">'
        + '<article class="flashcard-session-stat">'
        + '<span>' + escapeHtml(labels.flashcardResultCorrect) + '</span>'
        + '<strong>' + flashcardSessionStats.correct + '</strong>'
        + '</article>'
        + '<article class="flashcard-session-stat">'
        + '<span>' + escapeHtml(labels.flashcardResultWrong) + '</span>'
        + '<strong>' + flashcardSessionStats.wrong + '</strong>'
        + '</article>'
        + '<article class="flashcard-session-stat' + (learnedCount > 0 ? ' is-learned' : '') + '">'
        + '<span>' + escapeHtml(labels.flashcardResultLearned) + '</span>'
        + '<strong>' + learnedCount + '</strong>'
        + '</article>'
        + '</div>'
        + '<p class="flashcard-session-message">' + escapeHtml(hasMistakes ? labels.flashcardSessionRetryNotice : labels.flashcardSessionPerfect) + '</p>'
        + '<div class="flashcard-complete-actions">'
        + '<button class="primary-button" type="button" data-flashcard-continue>' + escapeHtml(labels.flashcardContinueSession) + '</button>'
        + '<button class="secondary-button" type="button" data-flashcard-exit>' + escapeHtml(labels.flashcardBackToReview) + '</button>'
        + '</div>'
        + '</div>';
      flashcardStage.querySelector('[data-flashcard-continue]')?.addEventListener('click', () => {
        resetFlashcardSession((flashcardSessionStart + FLASHCARD_SESSION_SIZE) % Math.max(reviewItems.length, 1));
        renderFlashcard();
      });
      flashcardStage.querySelector('[data-flashcard-exit]')?.addEventListener('click', closeFlashcards);
    }

    function renderFlashcard() {
      const labels = getUiText(uiLanguageSelect.value);
      const reviewItems = getFlashcardCandidateItems();
      const sessionItems = getFlashcardSessionItems();
      if (!sessionItems.length) {
        resetFlashcardSession(0);
        if (flashcardStage) {
          flashcardStage.innerHTML = '';
          flashcardStage.hidden = true;
        }
        if (flashcardEmptyState) {
          flashcardEmptyState.hidden = false;
        }
        if (flashcardProgress) {
          flashcardProgress.textContent = '0 / 0';
        }
        return;
      }

      if (flashcardSessionComplete) {
        if (flashcardEmptyState) {
          flashcardEmptyState.hidden = true;
        }
        renderFlashcardCompletion(labels, reviewItems);
        return;
      }

      flashcardIndex = Math.max(0, Math.min(flashcardIndex, sessionItems.length - 1));
      const expression = sessionItems[flashcardIndex];
      const status = getExpressionStatus(expression);
      const contextHtml = getExpressionContextHtml(expression);
      const expressionKey = getExpressionStorageKey(expression);
      const quizChoiceKey = expressionKey + '::' + uiLanguageSelect.value;
      if (flashcardCurrentKey !== quizChoiceKey || !flashcardCurrentChoices.length) {
        flashcardCurrentKey = quizChoiceKey;
        flashcardCurrentChoices = getFlashcardChoices(expression, uiLanguageSelect.value, reviewItems);
        flashcardSelectedAnswer = '';
        flashcardResult = null;
      }
      const correctChoice = flashcardCurrentChoices.find((choice) => choice.isCorrect);
      const hasEnoughChoices = flashcardCurrentChoices.length === 4;
      const currentPosition = Math.min(flashcardIndex + 1, sessionItems.length);
      const sessionTotal = Math.max(sessionItems.length, 1);
      const sentenceFormDiffers = Boolean(expression.formInText && expression.formInText !== expression.phrase);
      if (flashcardEmptyState) {
        flashcardEmptyState.hidden = true;
      }
      if (flashcardProgress) {
        flashcardProgress.hidden = false;
        flashcardProgress.textContent = currentPosition + ' / ' + sessionTotal;
      }

      flashcardStage.hidden = false;
      flashcardStage.innerHTML = ''
        + '<article class="flashcard" data-expression-key="' + escapeHtml(getExpressionStorageKey(expression)) + '" data-target-language="' + escapeHtml(expression.language) + '" data-status="' + escapeHtml(status) + '">'
        + '<div class="flashcard-card">'
        + '<div class="flashcard-meta">' + getLanguageBadgeHtml(expression.language, uiLanguageSelect.value) + '</div>'
        + '<p class="flashcard-context">' + contextHtml + '</p>'
        + '<div class="flashcard-question">'
        + '<span>' + escapeHtml(labels.flashcardChooseMeaning) + '</span>'
        + '<strong>' + escapeHtml(expression.phrase) + '</strong>'
        + '</div>'
        + '<div class="flashcard-choice-grid">'
        + flashcardCurrentChoices.map((choice, index) => {
          const isSelected = flashcardSelectedAnswer === choice.text;
          const resultClass = flashcardResult === null
            ? ''
            : choice.isCorrect
              ? ' is-correct'
              : isSelected
                ? ' is-wrong'
                : '';
          return '<button class="flashcard-choice' + resultClass + '" type="button" data-flashcard-choice="' + index + '"' + (flashcardResult !== null || !hasEnoughChoices ? ' disabled' : '') + '>'
            + escapeHtml(choice.text)
            + '</button>';
        }).join('')
        + '</div>'
        + (flashcardResult !== null
          ? '<div class="flashcard-answer-result" data-result="' + (flashcardResult ? 'correct' : 'wrong') + '">'
            + '<strong>' + escapeHtml(flashcardResult ? labels.flashcardCorrect : labels.flashcardWrong) + '</strong>'
            + '<p>' + escapeHtml(labels.flashcardCorrect) + ': ' + escapeHtml(correctChoice?.text || '') + '</p>'
            + (!flashcardResult && flashcardSelectedAnswer ? '<p>' + escapeHtml(labels.flashcardWrong) + ': ' + escapeHtml(flashcardSelectedAnswer) + '</p>' : '')
            + '<p class="flashcard-detail"><span>' + escapeHtml(labels.flashcardBaseForm) + '</span> ' + escapeHtml(expression.phrase) + '</p>'
            + (sentenceFormDiffers
              ? '<p class="flashcard-detail"><span>' + escapeHtml(labels.expressionTextForm) + '</span> ' + escapeHtml(expression.formInText) + '</p>'
              : '')
            + '</div>'
          : '')
        + '<div class="flashcard-controls">'
        + (flashcardResult !== null
          ? '<button class="primary-button" type="button" data-flashcard-next>' + escapeHtml(labels.flashcardNext) + '</button>'
          : '')
        + '</div>'
        + (hasEnoughChoices ? '' : '<p class="empty-state">' + escapeHtml(labels.noReviewItems) + '</p>')
        + '</article>';

      flashcardStage.querySelectorAll('[data-flashcard-choice]').forEach((button) => {
        button.addEventListener('click', () => {
          const choice = flashcardCurrentChoices[Number(button.dataset.flashcardChoice)];
          if (!choice || flashcardResult !== null) {
            return;
          }
          const currentStatus = getExpressionStatus(expression);
          const quizStats = updateExpressionQuizStats(expression, choice.isCorrect);
          flashcardSelectedAnswer = choice.text;
          flashcardResult = choice.isCorrect;
          if (choice.isCorrect) {
            flashcardSessionStats.correct += 1;
            const nextStatus = quizStats.correctStreak >= 3
              ? 'learned'
              : currentStatus === 'new'
                ? 'review'
                : currentStatus;
            if (nextStatus === 'learned' && currentStatus !== 'learned') {
              flashcardSessionStats.learned += 1;
            }
            setExpressionStatus(expression, nextStatus);
          } else {
            flashcardSessionStats.wrong += 1;
            setExpressionStatus(expression, 'review');
            if (!flashcardRetryKeys.has(expressionKey)) {
              flashcardRetryKeys.add(expressionKey);
              flashcardSessionQueue.push(expression);
            }
          }
          renderFlashcard();
      });
      });

      flashcardStage.querySelector('[data-flashcard-next]')?.addEventListener('click', () => {
        resetFlashcardAnswerState();
        if (flashcardIndex >= flashcardSessionQueue.length - 1) {
          flashcardSessionComplete = true;
        } else {
          flashcardIndex += 1;
        }
        renderReviewItems();
      });
    }

    function updateReviewModeUi() {
      reviewModeButtons.forEach((button) => {
        const isActive = button.dataset.reviewMode === reviewMode;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
      if (isFlashcardOpen()) {
        renderFlashcard();
      }
    }

    const savedUiLanguage = getSavedUiLanguage();
    const savedTargetLanguage = getSavedTargetLanguage();
    targetLanguageSelect.value = savedTargetLanguage;
    const targetLanguageDropdown = setupSelectDropdown({
      select: targetLanguageSelect,
      button: targetLanguageButton,
      menu: targetLanguageMenu,
      options: targetLanguageOptions,
      buttonLabel: targetLanguageButtonLabel,
      getLabel: (value) => getTargetLanguageLabel(value, uiLanguageSelect.value),
      onChange: (value) => {
        const lang = normalizeTargetLanguageValue(value);
        safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, lang);
        targetLanguageSelect.value = lang;
        targetLanguageDropdown.update();
        if (isFlashcardOpen()) {
          resetFlashcardSession(0);
        }
        renderReviewItems();
      },
    });
    const sortDropdown = setupSelectDropdown({
      select: sortSelect,
      button: sortButton,
      menu: sortMenu,
      options: sortOptions,
      buttonLabel: sortButtonLabel,
      getLabel: (value) => getSortLabel(value, getUiText(uiLanguageSelect.value)),
      onChange: () => {
        if (isFlashcardOpen()) {
          resetFlashcardSession(0);
        }
        renderReviewItems();
      },
    });
    renderUiText(savedUiLanguage);
    updateReviewModeUi();

    reviewModeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (button.dataset.reviewMode === 'flashcards') {
          openFlashcards();
        } else {
          closeFlashcards();
        }
      });
    });

    flashcardClose?.addEventListener('click', closeFlashcards);
    flashcardOverlay?.addEventListener('click', (event) => {
      if (event.target === flashcardOverlay) {
        closeFlashcards();
      }
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isFlashcardOpen()) {
        closeFlashcards();
      }
    });

    sortSelect.addEventListener('change', () => {
      sortDropdown.update();
      if (isFlashcardOpen()) {
        resetFlashcardSession(0);
      }
      renderReviewItems();
    });
    statusFilterButton.addEventListener('click', () => {
      if (statusFilterMenu.hidden) {
        openStatusFilter();
      } else {
        closeStatusFilter();
      }
    });
    statusFilterButton.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openStatusFilter();
      }
    });
    statusFilterOptions.forEach((option, index) => {
      option.addEventListener('click', () => {
        setStatusFilter(option.dataset.reviewFilterOption);
      });
      option.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          setStatusFilter(option.dataset.reviewFilterOption);
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          closeStatusFilter();
          statusFilterButton.focus();
        }
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          statusFilterOptions[(index + 1) % statusFilterOptions.length].focus();
        }
        if (event.key === 'ArrowUp') {
          event.preventDefault();
          statusFilterOptions[(index - 1 + statusFilterOptions.length) % statusFilterOptions.length].focus();
        }
      });
    });
    document.addEventListener('click', (event) => {
      if (!statusFilterButton.contains(event.target) && !statusFilterMenu.contains(event.target)) {
        closeStatusFilter();
      }
    });
    targetLanguageSelect.addEventListener('change', (event) => {
      const lang = normalizeTargetLanguageValue(event.target.value);
      safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, lang);
      targetLanguageSelect.value = lang;
      targetLanguageDropdown.update();
      if (isFlashcardOpen()) {
        resetFlashcardSession(0);
      }
      renderReviewItems();
    });

    uiLanguageSelect.addEventListener('change', (event) => {
      const lang = event.target.value;
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      renderUiText(lang);
    });
  });
`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{uiText[defaultUiLang].reviewPageTitle} · Polyglotyping</title>
  </head>
  <body>
    <SiteHeader active="review" basePath={import.meta.env.BASE_URL} />
    <main class="page-shell page-layout text-page">
      <section class="hero-card page-top page-hero page-hero--review">
        <div>
          <span class="section-kicker">Review</span>
          <h1 class="text-title page-hero__title" id="review-title" data-i18n="reviewPageTitle">{uiText[defaultUiLang].reviewPageTitle}</h1>
          <p class="page-hero__subtitle" data-i18n="usefulExpressions">{uiText[defaultUiLang].usefulExpressions}</p>
        </div>
        <dl class="page-hero-meta review-hero-meta" aria-label="Review summary">
          <div>
            <dt data-i18n="reviewSummaryTotal">{uiText[defaultUiLang].reviewSummaryTotal}</dt>
            <dd id="review-summary-total-value">0</dd>
          </div>
          <div>
            <dt data-i18n="reviewSummaryStatus">{uiText[defaultUiLang].reviewSummaryStatus}</dt>
            <dd id="review-summary-status-value">{uiText[defaultUiLang].expressionStatusReview}</dd>
          </div>
          <div>
            <dt data-i18n="reviewSummarySort">{uiText[defaultUiLang].reviewSummarySort}</dt>
            <dd id="review-summary-sort-value">{uiText[defaultUiLang].sortMostPracticed}</dd>
          </div>
        </dl>
      </section>

      <section class="expressions-card">
        <div class="review-controls">
          <div class="filter-group">
            <label id="review-target-language-label" for="review-target-language-button" data-i18n="practiceLanguage">{uiText[defaultUiLang].practiceLanguage}</label>
            <select id="review-target-language" class="native-filter-select" aria-hidden="true" tabindex="-1">
              <option value="all" data-i18n-target-language="all">{uiText[defaultUiLang].allLanguages}</option>
              {uiLanguages.map((lang) => (
                <option value={lang} data-i18n-target-language={lang}>
                  {lang === 'no' ? 'Norsk' : lang === 'en' ? 'English' : '日本語'}
                </option>
              ))}
            </select>
            <div class="status-filter-dropdown">
              <button
                id="review-target-language-button"
                class="status-filter-button"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="review-target-language-label review-target-language-button-label"
              >
                <span id="review-target-language-button-label">{uiText[defaultUiLang].allLanguages}</span>
              </button>
              <div id="review-target-language-menu" class="status-filter-menu" role="listbox" aria-labelledby="review-target-language-label" hidden>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-target-language-option data-dropdown-value="all" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].allLanguages}</span>
                </button>
                {uiLanguages.map((lang) => (
                  <button class="status-filter-option" type="button" role="option" tabindex="-1" data-target-language-option data-dropdown-value={lang} aria-selected="false">
                    <span data-filter-option-label>{lang === 'no' ? 'Norsk' : lang === 'en' ? 'English' : '日本語'}</span>
                  </button>
                ))}
              </div>
            </div>
          </div>
          <div class="filter-group">
            <label id="review-filter-label" for="review-filter-button" data-i18n="filterLabel">{uiText[defaultUiLang].filterLabel}</label>
            <div class="status-filter-dropdown">
              <button
                id="review-filter-button"
                class="status-filter-button"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="review-filter-label review-filter-button-label review-filter-button-count"
              >
                <span id="review-filter-button-label">{uiText[defaultUiLang].expressionStatusReview}</span>
                <span id="review-filter-button-count" class="status-filter-count">0</span>
              </button>
              <div id="review-filter-menu" class="status-filter-menu" role="listbox" aria-labelledby="review-filter-label" hidden>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="review" aria-selected="true">
                  <span data-filter-option-label>{uiText[defaultUiLang].expressionStatusReview}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="learned" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].expressionStatusLearned}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="new" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].expressionStatusNew}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="all" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].filterAll}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
              </div>
            </div>
          </div>
          <div class="filter-group">
            <label id="review-sort-label" for="review-sort-button" data-i18n="sortLabel">{uiText[defaultUiLang].sortLabel}</label>
            <select id="review-sort" class="native-filter-select" aria-hidden="true" tabindex="-1">
              <option value="most-practiced" data-i18n="sortMostPracticed">{uiText[defaultUiLang].sortMostPracticed}</option>
              <option value="least-practiced" data-i18n="sortLeastPracticed">{uiText[defaultUiLang].sortLeastPracticed}</option>
              <option value="recently-practiced" data-i18n="sortRecentlyPracticed">{uiText[defaultUiLang].sortRecentlyPracticed}</option>
              <option value="easiest" data-i18n="sortEasiestFirst">{uiText[defaultUiLang].sortEasiestFirst}</option>
              <option value="hardest" data-i18n="sortHardestFirst">{uiText[defaultUiLang].sortHardestFirst}</option>
              <option value="az" data-i18n="sortAlphabetical">{uiText[defaultUiLang].sortAlphabetical}</option>
            </select>
            <div class="status-filter-dropdown">
              <button
                id="review-sort-button"
                class="status-filter-button"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="review-sort-label review-sort-button-label"
              >
                <span id="review-sort-button-label">{uiText[defaultUiLang].sortMostPracticed}</span>
              </button>
              <div id="review-sort-menu" class="status-filter-menu" role="listbox" aria-labelledby="review-sort-label" hidden>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="most-practiced" aria-selected="true">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortMostPracticed}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="least-practiced" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortLeastPracticed}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="recently-practiced" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortRecentlyPracticed}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="easiest" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortEasiestFirst}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="hardest" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortHardestFirst}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="az" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortAlphabetical}</span>
                </button>
              </div>
            </div>
          </div>
        </div>
        <div class="review-mode-switch" role="group" aria-label="Review mode">
          <button
            class="typing-mode-button active"
            type="button"
            data-review-mode="list"
            aria-pressed="true"
          >
            <span class="review-mode-switch__label" data-review-mode-label>{uiText[defaultUiLang].reviewModeCardList}</span>
            <span class="review-mode-switch__hint" data-review-mode-hint>{reviewModeDescriptions[defaultUiLang].cardList}</span>
          </button>
          <button
            class="typing-mode-button"
            type="button"
            data-review-mode="flashcards"
            aria-pressed="false"
          >
            <span class="review-mode-switch__label" data-review-mode-label>{uiText[defaultUiLang].reviewModeFlashcards}</span>
            <span class="review-mode-switch__hint" data-review-mode-hint>{reviewModeDescriptions[defaultUiLang].flashcards}</span>
          </button>
        </div>
        <div id="review-list-panel">
          <div id="review-grid" class="expressions-grid"></div>
          <p id="review-empty-state" class="empty-state" data-i18n="noReviewItems">{uiText[defaultUiLang].noReviewItems}</p>
        </div>
      </section>
    </main>
    <div class="flashcard-overlay" id="flashcard-overlay" hidden>
      <section
        class="review-flashcard-modal"
        role="dialog"
        aria-modal="true"
        aria-label={uiText[defaultUiLang].reviewModeFlashcards}
      >
        <div class="flashcard-toolbar">
          <span class="flashcard-progress" id="flashcard-progress">0 / 0</span>
          <button
            class="flashcard-close"
            type="button"
            id="flashcard-close"
            aria-label={uiText[defaultUiLang].flashcardClose}
            title={uiText[defaultUiLang].flashcardClose}
          >
            ×
          </button>
        </div>
        <div id="flashcard-stage" class="flashcard-stage"></div>
        <p id="flashcard-empty-state" class="empty-state" data-i18n="noReviewItems" hidden>{uiText[defaultUiLang].noReviewItems}</p>
      </section>
    </div>

    <script type="module" set:html={clientScript}></script>
  </body>
</html>
