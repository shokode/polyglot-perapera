---
import '../styles/global.scss';
import texts from '../data/texts.json' assert { type: 'json' };
import {
  uiLanguages,
  uiLanguageNames,
  uiText,
  languageNames,
  type UILang,
} from '../i18n/ui';

const defaultUiLang: UILang = 'en';
type ReviewExpression = {
  phrase: string;
  storageKey?: string;
  formInText?: string;
  ja: string;
  en: string;
  no?: string;
  example?: string;
  exampleJa?: string;
  exampleEn?: string;
  exampleNo?: string;
  language: string;
  textId: string;
  level: string;
};

const expressions = Array.from(
  texts.reduce((map, item) => {
    item.expressions.forEach((expression) => {
      const expressionKey = `${item.language}::${expression.phrase}`;
      if (!map.has(expressionKey)) {
        map.set(expressionKey, { ...expression, language: item.language, textId: item.id, level: item.level });
      }
    });
    return map;
  }, new Map<string, ReviewExpression>())
  .values()
);

const clientScript = `
  const expressions = ${JSON.stringify(expressions)};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = {
    no: 'NO',
    en: 'EN',
    ja: 'JA',
  };
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const TARGET_LANGUAGE_STORAGE_KEY = 'typingSiteTargetLanguage';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const EXPRESSION_PROGRESS_KEY = 'expressionProgress';
  const EXPRESSION_STATUSES = ['new', 'review', 'learned'];
  const levelSortRank = {
    a1: 0,
    a2: 1,
    b1: 2,
    b2: 3,
    c1: 4,
    natural: 5,
  };
  const legacyLevelMap = {
    basic: 'a1',
    useful: 'a2',
    daily: 'b1',
    advanced: 'b2',
    natural: 'natural',
  };

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveExpressionStatuses(data) {
    safeWriteStorage(EXPRESSION_STATUS_KEY, JSON.stringify(data));
  }

  function loadExpressionProgress() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_PROGRESS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return typeof stored === 'string' && uiLanguages.includes(stored) ? stored : 'en';
  }

  function normalizeTargetLanguageValue(value) {
    if (value === 'all') {
      return 'all';
    }
    if (typeof value !== 'string') {
      return 'no';
    }
    const normalized = value.toLowerCase();
    return uiLanguages.includes(normalized) ? normalized : 'no';
  }

  function getSavedTargetLanguage() {
    const stored = safeReadStorage(TARGET_LANGUAGE_STORAGE_KEY);
    return normalizeTargetLanguageValue(stored);
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function getLanguageTitle(value, lang) {
    return languageNames[value]?.[lang] || value;
  }

  function getLanguageBadgeHtml(value, lang) {
    const label = targetLanguageBadges[value] || value;
    const title = getLanguageTitle(value, lang);
    return '<span class="language-badge language-badge--' + escapeHtml(value) + '" data-target-language="' + escapeHtml(value) + '" title="' + escapeHtml(title) + '" aria-label="' + escapeHtml(title) + '">' + escapeHtml(label) + '</span>';
  }

  function normalizeLevelKey(level) {
    if (legacyLevelMap[level]) {
      return legacyLevelMap[level];
    }
    return levelSortRank[level] !== undefined ? level : 'natural';
  }

  function getExpressionStorageKey(expression) {
    return expression.language + '::' + (expression.storageKey || expression.phrase);
  }

  function getExpressionStatus(expression) {
    const all = loadExpressionStatuses();
    const stored = all[getExpressionStorageKey(expression)] || all[expression.storageKey] || all[expression.language + '::' + expression.phrase] || all[expression.phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getExpressionStatusLabel(status, labels) {
    if (status === 'review') {
      return labels.expressionStatusReview;
    }
    if (status === 'learned') {
      return labels.expressionStatusLearned;
    }
    return labels.expressionStatusNew;
  }

  function getExpressionPractice(expression) {
    const progress = loadExpressionProgress();
    const entry = progress[getExpressionStorageKey(expression)] || progress[expression.storageKey] || progress[expression.language + '::' + expression.phrase] || progress[expression.phrase] || {};
    const practiceCount = Number.isFinite(entry.practiceCount) ? entry.practiceCount : 0;
    return {
      practiceCount,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : '',
    };
  }

  function getPracticeLevel(count) {
    if (count >= 5) {
      return '3';
    }
    if (count >= 3) {
      return '2';
    }
    if (count >= 1) {
      return '1';
    }
    return '0';
  }

  function getPracticeLabel(count, labels) {
    if (count <= 0) {
      return labels.expressionNotPracticed;
    }
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function getExplanationLanguageOrder(lang) {
    return [lang, ...uiLanguages.filter((item) => item !== lang)];
  }

  function getLocalizedExpressionMeanings(expression, lang) {
    return getExplanationLanguageOrder(lang)
      .map((language) => ({ language, value: expression[language] }))
      .filter((entry) => typeof entry.value === 'string' && entry.value.trim());
  }

  function getExpressionExampleMap(expression) {
    return {
      default: typeof expression.example === 'string' ? expression.example : '',
      ja: typeof expression.exampleJa === 'string' ? expression.exampleJa : '',
      en: typeof expression.exampleEn === 'string' ? expression.exampleEn : '',
      no: typeof expression.exampleNo === 'string' ? expression.exampleNo : '',
    };
  }

  function getLocalizedExpressionExamples(expression) {
    const examples = getExpressionExampleMap(expression);
    const order = ['default', ...uiLanguages.filter((language) => language !== expression.language)];
    return order
      .map((language) => ({ language, value: examples[language] }))
      .filter((entry, index, array) => typeof entry.value === 'string' && entry.value.trim() && array.findIndex((item) => item.value === entry.value) === index);
  }

  function renderReviewExampleSection(expression, labels, uiLang) {
    const examples = getLocalizedExpressionExamples(expression);
    if (!examples.length) {
      return '';
    }

    return ''
      + '<div class="review-card-examples" data-review-examples>'
      + '<button class="example-toggle" type="button" data-review-example-toggle aria-expanded="false" aria-label="' + escapeHtml(labels.showExpressionExample) + '" data-show-label="' + escapeHtml(labels.showExpressionExample) + '" data-hide-label="' + escapeHtml(labels.hideExpressionExample) + '"><span>' + escapeHtml(labels.expressionExample) + '</span><span class="example-toggle__icon" aria-hidden="true">⌄</span></button>'
      + '<div class="expression-example-list review-example-list example-section" hidden>'
      + '<span class="expression-example-label">' + escapeHtml(labels.expressionExample) + '</span>'
      + examples.map((entry) => '<p>' + (entry.language !== 'default' ? getLanguageBadgeHtml(entry.language, uiLang) + ' ' : '') + escapeHtml(entry.value) + '</p>').join('')
      + '</div>'
      + '</div>';
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  document.addEventListener('DOMContentLoaded', () => {
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const reviewTitle = document.getElementById('review-title');
    const reviewGrid = document.getElementById('review-grid');
    const emptyState = document.getElementById('review-empty-state');
    const sortSelect = document.getElementById('review-sort');
    const statusFilterButton = document.getElementById('review-filter-button');
    const statusFilterMenu = document.getElementById('review-filter-menu');
    const statusFilterOptions = Array.from(document.querySelectorAll('[data-review-filter-option]'));
    const statusFilterButtonLabel = document.getElementById('review-filter-button-label');
    const statusFilterButtonCount = document.getElementById('review-filter-button-count');
    const targetLanguageSelect = document.getElementById('review-target-language');
    const targetLanguageButton = document.getElementById('review-target-language-button');
    const targetLanguageMenu = document.getElementById('review-target-language-menu');
    const targetLanguageOptions = Array.from(document.querySelectorAll('[data-target-language-option]'));
    const targetLanguageButtonLabel = document.getElementById('review-target-language-button-label');
    const sortButton = document.getElementById('review-sort-button');
    const sortMenu = document.getElementById('review-sort-menu');
    const sortOptions = Array.from(document.querySelectorAll('[data-sort-option]'));
    const sortButtonLabel = document.getElementById('review-sort-button-label');
    let selectedFilter = 'review';

    function getTargetLanguageLabel(value, lang) {
      const labels = getUiText(lang);
      return value === 'all' ? labels.allLanguages : targetLanguageBadges[value] || value;
    }

    function getSortLabel(value, labels) {
      if (value === 'least-practiced') {
        return labels.sortLeastPracticed;
      }
      if (value === 'recently-practiced') {
        return labels.sortRecentlyPracticed;
      }
      if (value === 'easiest') {
        return labels.sortEasiestFirst;
      }
      if (value === 'hardest') {
        return labels.sortHardestFirst;
      }
      if (value === 'az') {
        return labels.sortAlphabetical;
      }
      return labels.sortMostPracticed;
    }

    function updateSelectDropdownUi(select, options, buttonLabel, getLabel) {
      const selectedValue = select.value;
      options.forEach((option) => {
        const value = option.dataset.dropdownValue;
        const isSelected = value === selectedValue;
        option.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        option.querySelector('[data-filter-option-label]').textContent = getLabel(value);
      });
      buttonLabel.textContent = getLabel(selectedValue);
    }

    function closeSelectDropdown(button, menu) {
      button.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
    }

    function openSelectDropdown(button, menu, options, selectedValue) {
      button.setAttribute('aria-expanded', 'true');
      menu.hidden = false;
      const selectedOption = options.find((option) => option.dataset.dropdownValue === selectedValue) || options[0];
      selectedOption?.focus();
    }

    function setupSelectDropdown({ select, button, menu, options, buttonLabel, getLabel, onChange }) {
      const close = () => closeSelectDropdown(button, menu);
      const update = () => updateSelectDropdownUi(select, options, buttonLabel, getLabel);
      const chooseValue = (value) => {
        select.value = value;
        close();
        update();
        onChange(value);
      };

      button.addEventListener('click', () => {
        if (menu.hidden) {
          openSelectDropdown(button, menu, options, select.value);
        } else {
          close();
        }
      });
      button.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openSelectDropdown(button, menu, options, select.value);
        }
      });
      options.forEach((option, index) => {
        option.addEventListener('click', () => {
          chooseValue(option.dataset.dropdownValue);
        });
        option.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            chooseValue(option.dataset.dropdownValue);
          }
          if (event.key === 'Escape') {
            event.preventDefault();
            close();
            button.focus();
          }
          if (event.key === 'ArrowDown') {
            event.preventDefault();
            options[(index + 1) % options.length].focus();
          }
          if (event.key === 'ArrowUp') {
            event.preventDefault();
            options[(index - 1 + options.length) % options.length].focus();
          }
        });
      });
      document.addEventListener('click', (event) => {
        if (!button.contains(event.target) && !menu.contains(event.target)) {
          close();
        }
      });

      return { update, close };
    }

    function renderUiText(lang) {
      const labels = getUiText(lang);
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n;
        const value = labels[key];
        if (typeof value === 'string') {
          el.textContent = value;
        }
      });
      document.querySelectorAll('[data-i18n-target-language]').forEach((option) => {
        const value = option.dataset.i18nTargetLanguage;
        option.textContent = getTargetLanguageLabel(value, lang);
      });

      uiLanguageSelect.value = lang;
      reviewTitle.textContent = labels.reviewPageTitle;
      targetLanguageDropdown.update();
      sortDropdown.update();
      renderReviewItems();
    }

    function getStatusFilterLabel(status, labels) {
      if (status === 'all') {
        return labels.filterAll;
      }
      return getExpressionStatusLabel(status, labels);
    }

    function getExpressionsForSelectedTargetLanguage() {
      const selectedTargetLanguage = targetLanguageSelect.value;
      return expressions.filter((expression) => selectedTargetLanguage === 'all' || expression.language === selectedTargetLanguage);
    }

    function getStatusCounts() {
      const counts = { new: 0, review: 0, learned: 0, all: 0 };
      getExpressionsForSelectedTargetLanguage().forEach((expression) => {
        const status = getExpressionStatus(expression);
        if (counts[status] !== undefined) {
          counts[status] += 1;
        }
        counts.all += 1;
      });
      return counts;
    }

    function closeStatusFilter() {
      statusFilterButton.setAttribute('aria-expanded', 'false');
      statusFilterMenu.hidden = true;
    }

    function openStatusFilter() {
      statusFilterButton.setAttribute('aria-expanded', 'true');
      statusFilterMenu.hidden = false;
      const selectedOption = statusFilterOptions.find((option) => option.dataset.reviewFilterOption === selectedFilter) || statusFilterOptions[0];
      selectedOption?.focus();
    }

    function updateStatusFilterUi() {
      const labels = getUiText(uiLanguageSelect.value);
      const counts = getStatusCounts();
      statusFilterOptions.forEach((option) => {
        const status = option.dataset.reviewFilterOption;
        const isSelected = status === selectedFilter;
        option.setAttribute('aria-selected', isSelected ? 'true' : 'false');
        option.querySelector('[data-filter-option-label]').textContent = getStatusFilterLabel(status, labels);
        option.querySelector('[data-filter-option-count]').textContent = counts[status] || 0;
      });
      statusFilterButtonLabel.textContent = getStatusFilterLabel(selectedFilter, labels);
      statusFilterButtonCount.textContent = counts[selectedFilter] || 0;
    }

    function setStatusFilter(status) {
      selectedFilter = ['review', 'learned', 'new', 'all'].includes(status) ? status : 'review';
      closeStatusFilter();
      renderReviewItems();
    }

    function saveExpressionStatus(expression, status) {
      const all = loadExpressionStatuses();
      all[getExpressionStorageKey(expression)] = status;
      saveExpressionStatuses(all);
    }

    function getNextExpressionStatus(status) {
      if (status === 'new') {
        return 'review';
      }
      if (status === 'review') {
        return 'learned';
      }
      return 'new';
    }

    function updateReviewCardStatus(card, expression, status) {
      const labels = getUiText(uiLanguageSelect.value);
      const { practiceCount } = getExpressionPractice(expression);
      const statusPill = card.querySelector('.status-pill');
      card.dataset.status = status;
      card.dataset.highRepetition = status === 'review' && practiceCount >= 10 ? 'true' : 'false';
      if (statusPill) {
        statusPill.dataset.status = status;
        statusPill.textContent = getExpressionStatusLabel(status, labels);
      }
      updateStatusFilterUi();
    }

    function cycleExpressionStatus(expression, card) {
      const nextStatus = getNextExpressionStatus(getExpressionStatus(expression));
      saveExpressionStatus(expression, nextStatus);
      updateReviewCardStatus(card, expression, nextStatus);
    }

    function renderReviewItems() {
      const labels = getUiText(uiLanguageSelect.value);
      const selectedSort = sortSelect.value;
      const selectedTargetLanguage = targetLanguageSelect.value;
      updateStatusFilterUi();
      const reviewItems = expressions
        .filter((expression) => selectedTargetLanguage === 'all' || expression.language === selectedTargetLanguage)
        .filter((expression) => selectedFilter === 'all' || getExpressionStatus(expression) === selectedFilter)
        .sort((a, b) => {
          const aPractice = getExpressionPractice(a);
          const bPractice = getExpressionPractice(b);
          if (selectedSort === 'least-practiced') {
            return aPractice.practiceCount - bPractice.practiceCount || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'recently-practiced') {
            return Date.parse(bPractice.lastPracticedAt || '1970-01-01') - Date.parse(aPractice.lastPracticedAt || '1970-01-01') || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'easiest') {
            return levelSortRank[normalizeLevelKey(a.level)] - levelSortRank[normalizeLevelKey(b.level)] || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'hardest') {
            return levelSortRank[normalizeLevelKey(b.level)] - levelSortRank[normalizeLevelKey(a.level)] || a.phrase.localeCompare(b.phrase);
          }
          if (selectedSort === 'az') {
            return a.phrase.localeCompare(b.phrase);
          }
          return bPractice.practiceCount - aPractice.practiceCount || a.phrase.localeCompare(b.phrase);
        });

      reviewGrid.innerHTML = reviewItems.map((expression) => {
        const status = getExpressionStatus(expression);
        const label = getExpressionStatusLabel(status, labels);
        const { practiceCount } = getExpressionPractice(expression);
        const isHighRepetition = status === 'review' && practiceCount >= 10;
        const expressionKey = getExpressionStorageKey(expression);
        const meanings = getLocalizedExpressionMeanings(expression, uiLanguageSelect.value);
        const examples = renderReviewExampleSection(expression, labels, uiLanguageSelect.value);
        return ''
          + '<article class="expression-card review-expression-card review-card" data-review-card data-expression-key="' + escapeHtml(expressionKey) + '" data-text-id="' + escapeHtml(expression.textId) + '" data-target-language="' + escapeHtml(expression.language) + '" data-status="' + status + '" data-practice-level="' + getPracticeLevel(practiceCount) + '" data-high-repetition="' + (isHighRepetition ? 'true' : 'false') + '">'
          + '<div class="review-card__body">'
          + '<div class="expression-header">'
          + '<div class="expression-title-stack"><strong>' + escapeHtml(expression.phrase) + '</strong></div>'
          + '<div class="review-card__status-area">'
          + '<span class="status-button status-pill review-card__status-badge" data-status="' + status + '">' + escapeHtml(label) + '</span>'
          + '<span class="review-card__practice-count">' + escapeHtml(getPracticeLabel(practiceCount, labels)) + '</span>'
          + '</div>'
          + '</div>'
          + '<div class="review-card-meta">'
          + (expression.formInText && expression.formInText !== expression.phrase ? '<span class="expression-text-form"><span>' + escapeHtml(labels.expressionTextForm) + '</span>: ' + escapeHtml(expression.formInText) + '</span>' : '')
          + '</div>'
          + '<div class="review-card-meaning">'
          + meanings.map((entry) => '<p>' + getLanguageBadgeHtml(entry.language, uiLanguageSelect.value) + ' ' + escapeHtml(entry.value) + '</p>').join('')
          + '</div>'
          + examples
          + '</div>'
          + '<div class="review-card-actions review-card__actions">'
          + '<button class="secondary-button" type="button" data-review-open-text data-text-id="' + escapeHtml(expression.textId) + '">' + escapeHtml(labels.practiceThisText) + '</button>'
          + '</div>'
          + '</article>';
      }).join('');

      emptyState.hidden = reviewItems.length > 0;

      reviewGrid.querySelectorAll('[data-review-card]').forEach((card) => {
        card.addEventListener('click', () => {
          const expression = expressions.find((item) => getExpressionStorageKey(item) === card.dataset.expressionKey);
          if (expression) {
            cycleExpressionStatus(expression, card);
          }
        });
      });

      reviewGrid.querySelectorAll('[data-review-examples]').forEach((section) => {
        section.addEventListener('click', (event) => {
          event.stopPropagation();
        });
      });

      reviewGrid.querySelectorAll('[data-review-example-toggle]').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          const exampleList = button.parentElement?.querySelector('.review-example-list');
          if (!exampleList) {
            return;
          }
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          button.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
          button.setAttribute('aria-label', isExpanded ? button.dataset.showLabel : button.dataset.hideLabel);
          button.classList.toggle('is-open', !isExpanded);
          const icon = button.querySelector('.example-toggle__icon');
          if (icon) {
            icon.textContent = isExpanded ? '⌄' : '⌃';
          }
          exampleList.hidden = isExpanded;
        });
      });

      reviewGrid.querySelectorAll('[data-review-open-text]').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          window.location.href = '/text/' + button.dataset.textId;
        });
      });
    }

    const savedUiLanguage = getSavedUiLanguage();
    const savedTargetLanguage = getSavedTargetLanguage();
    targetLanguageSelect.value = savedTargetLanguage;
    const targetLanguageDropdown = setupSelectDropdown({
      select: targetLanguageSelect,
      button: targetLanguageButton,
      menu: targetLanguageMenu,
      options: targetLanguageOptions,
      buttonLabel: targetLanguageButtonLabel,
      getLabel: (value) => getTargetLanguageLabel(value, uiLanguageSelect.value),
      onChange: (value) => {
        const lang = normalizeTargetLanguageValue(value);
        safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, lang);
        targetLanguageSelect.value = lang;
        targetLanguageDropdown.update();
        renderReviewItems();
      },
    });
    const sortDropdown = setupSelectDropdown({
      select: sortSelect,
      button: sortButton,
      menu: sortMenu,
      options: sortOptions,
      buttonLabel: sortButtonLabel,
      getLabel: (value) => getSortLabel(value, getUiText(uiLanguageSelect.value)),
      onChange: renderReviewItems,
    });
    renderUiText(savedUiLanguage);

    sortSelect.addEventListener('change', () => {
      sortDropdown.update();
      renderReviewItems();
    });
    statusFilterButton.addEventListener('click', () => {
      if (statusFilterMenu.hidden) {
        openStatusFilter();
      } else {
        closeStatusFilter();
      }
    });
    statusFilterButton.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openStatusFilter();
      }
    });
    statusFilterOptions.forEach((option, index) => {
      option.addEventListener('click', () => {
        setStatusFilter(option.dataset.reviewFilterOption);
      });
      option.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          setStatusFilter(option.dataset.reviewFilterOption);
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          closeStatusFilter();
          statusFilterButton.focus();
        }
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          statusFilterOptions[(index + 1) % statusFilterOptions.length].focus();
        }
        if (event.key === 'ArrowUp') {
          event.preventDefault();
          statusFilterOptions[(index - 1 + statusFilterOptions.length) % statusFilterOptions.length].focus();
        }
      });
    });
    document.addEventListener('click', (event) => {
      if (!statusFilterButton.contains(event.target) && !statusFilterMenu.contains(event.target)) {
        closeStatusFilter();
      }
    });
    targetLanguageSelect.addEventListener('change', (event) => {
      const lang = normalizeTargetLanguageValue(event.target.value);
      safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, lang);
      targetLanguageSelect.value = lang;
      targetLanguageDropdown.update();
      renderReviewItems();
    });

    uiLanguageSelect.addEventListener('change', (event) => {
      const lang = event.target.value;
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      renderUiText(lang);
    });
  });
`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{uiText[defaultUiLang].reviewPageTitle} · Read & Type</title>
  </head>
  <body>
    <main class="page-shell text-page">
      <section class="hero-card page-top">
        <div>
          <h1 class="text-title" id="review-title" data-i18n="reviewPageTitle">{uiText[defaultUiLang].reviewPageTitle}</h1>
          <p data-i18n="usefulExpressions">{uiText[defaultUiLang].usefulExpressions}</p>
        </div>
        <div class="top-actions">
          <a class="nav-link" href="/" data-i18n="title">{uiText[defaultUiLang].title}</a>
          <a class="nav-link" href="/starred" data-i18n="starredPageTitle">{uiText[defaultUiLang].starredPageTitle}</a>
          <div class="language-switcher">
            <label for="ui-language-select" data-i18n="language">{uiText[defaultUiLang].language}</label>
            <select id="ui-language-select">
              {uiLanguages.map((lang) => (
                <option value={lang}>{uiLanguageNames[lang]}</option>
              ))}
            </select>
          </div>
        </div>
      </section>

      <section class="expressions-card">
        <div class="review-controls">
          <div class="filter-group">
            <label id="review-target-language-label" for="review-target-language-button" data-i18n="practiceLanguage">{uiText[defaultUiLang].practiceLanguage}</label>
            <select id="review-target-language" class="native-filter-select" aria-hidden="true" tabindex="-1">
              <option value="all" data-i18n-target-language="all">{uiText[defaultUiLang].allLanguages}</option>
              {uiLanguages.map((lang) => (
                <option value={lang} data-i18n-target-language={lang}>{lang.toUpperCase()}</option>
              ))}
            </select>
            <div class="status-filter-dropdown">
              <button
                id="review-target-language-button"
                class="status-filter-button"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="review-target-language-label review-target-language-button-label"
              >
                <span id="review-target-language-button-label">{uiText[defaultUiLang].allLanguages}</span>
              </button>
              <div id="review-target-language-menu" class="status-filter-menu" role="listbox" aria-labelledby="review-target-language-label" hidden>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-target-language-option data-dropdown-value="all" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].allLanguages}</span>
                </button>
                {uiLanguages.map((lang) => (
                  <button class="status-filter-option" type="button" role="option" tabindex="-1" data-target-language-option data-dropdown-value={lang} aria-selected="false">
                    <span data-filter-option-label>{lang.toUpperCase()}</span>
                  </button>
                ))}
              </div>
            </div>
          </div>
          <div class="filter-group">
            <label id="review-filter-label" for="review-filter-button" data-i18n="filterLabel">{uiText[defaultUiLang].filterLabel}</label>
            <div class="status-filter-dropdown">
              <button
                id="review-filter-button"
                class="status-filter-button"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="review-filter-label review-filter-button-label review-filter-button-count"
              >
                <span id="review-filter-button-label">{uiText[defaultUiLang].expressionStatusReview}</span>
                <span id="review-filter-button-count" class="status-filter-count">0</span>
              </button>
              <div id="review-filter-menu" class="status-filter-menu" role="listbox" aria-labelledby="review-filter-label" hidden>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="review" aria-selected="true">
                  <span data-filter-option-label>{uiText[defaultUiLang].expressionStatusReview}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="learned" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].expressionStatusLearned}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="new" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].expressionStatusNew}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-review-filter-option="all" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].filterAll}</span>
                  <span class="status-filter-count" data-filter-option-count>0</span>
                </button>
              </div>
            </div>
          </div>
          <div class="filter-group">
            <label id="review-sort-label" for="review-sort-button" data-i18n="sortLabel">{uiText[defaultUiLang].sortLabel}</label>
            <select id="review-sort" class="native-filter-select" aria-hidden="true" tabindex="-1">
              <option value="most-practiced" data-i18n="sortMostPracticed">{uiText[defaultUiLang].sortMostPracticed}</option>
              <option value="least-practiced" data-i18n="sortLeastPracticed">{uiText[defaultUiLang].sortLeastPracticed}</option>
              <option value="recently-practiced" data-i18n="sortRecentlyPracticed">{uiText[defaultUiLang].sortRecentlyPracticed}</option>
              <option value="easiest" data-i18n="sortEasiestFirst">{uiText[defaultUiLang].sortEasiestFirst}</option>
              <option value="hardest" data-i18n="sortHardestFirst">{uiText[defaultUiLang].sortHardestFirst}</option>
              <option value="az" data-i18n="sortAlphabetical">{uiText[defaultUiLang].sortAlphabetical}</option>
            </select>
            <div class="status-filter-dropdown">
              <button
                id="review-sort-button"
                class="status-filter-button"
                type="button"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="review-sort-label review-sort-button-label"
              >
                <span id="review-sort-button-label">{uiText[defaultUiLang].sortMostPracticed}</span>
              </button>
              <div id="review-sort-menu" class="status-filter-menu" role="listbox" aria-labelledby="review-sort-label" hidden>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="most-practiced" aria-selected="true">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortMostPracticed}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="least-practiced" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortLeastPracticed}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="recently-practiced" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortRecentlyPracticed}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="easiest" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortEasiestFirst}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="hardest" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortHardestFirst}</span>
                </button>
                <button class="status-filter-option" type="button" role="option" tabindex="-1" data-sort-option data-dropdown-value="az" aria-selected="false">
                  <span data-filter-option-label>{uiText[defaultUiLang].sortAlphabetical}</span>
                </button>
              </div>
            </div>
          </div>
        </div>
        <div id="review-grid" class="expressions-grid"></div>
        <p id="review-empty-state" class="empty-state" data-i18n="noReviewItems">{uiText[defaultUiLang].noReviewItems}</p>
      </section>
    </main>

    <script type="module" set:html={clientScript}></script>
  </body>
</html>
