      updatePinButton();
      updateTranslationPracticePinButtons();
      updateExpressionMiniCardText();
      updateTypingModeControls();
    }

    function updateTypingModeControls() {
      typingModeButtons.forEach((button) => {
        const selected = button.dataset.typingMode === currentTypingMode;
        button.classList.toggle('active', selected);
        button.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });
      if (typingModeDescription) {
        typingModeDescription.hidden = currentTypingMode !== 'flow';
      }
    }

    function updatePinButton() {
      if (!pinButton) {
        return;
      }
      const labels = getUiText(uiLanguageSelect.value);
      const pinned = isPracticeTargetPinned(getCurrentPracticeTarget());
      pinButton.classList.toggle('is-pinned', pinned);
      pinButton.textContent = pinned ? '★' : '☆';
      pinButton.title = pinned ? labels.unpinText : labels.pinText;
      pinButton.setAttribute('aria-label', pinned ? labels.unpinText : labels.pinText);
      pinButton.setAttribute('aria-pressed', pinned ? 'true' : 'false');
    }

    function updateTranslationPracticePinButtons() {
      const labels = getUiText(uiLanguageSelect.value);
      translationPracticePinButtons.forEach((button) => {
        const practiceTranslation = button.dataset.translationPracticePin;
        const target = { textId: text.id, practiceType: 'translation', practiceTranslation };
        const pinned = isPracticeTargetPinned(target);
        button.classList.toggle('is-pinned', pinned);
        button.textContent = pinned ? '★' : '☆';
        button.title = pinned ? labels.unpinText : labels.pinText;
        button.setAttribute('aria-label', pinned ? labels.unpinText : labels.pinText);
        button.setAttribute('aria-pressed', pinned ? 'true' : 'false');
      });
    }

    function updateTargetTextProgress(typed) {
      targetCharacters.forEach((char) => {
        const index = Number(char.dataset.charIndex);
        char.classList.remove('correct', 'incorrect', 'current');
        if (!Number.isFinite(index)) {
          return;
        }
        if (index < typed.length) {
          char.classList.add(typingCharactersMatch(typed[index], activeTypingTarget[index]) ? 'correct' : 'incorrect');
        } else if (index === typed.length && typed.length < activeTypingTarget.length) {
          char.classList.add('current');
        }
      });
    }

    function getCompletionTitle(labels, completionState) {
      return completionState === 'finishedWithMistakes'
        ? labels.completionFinishedMessage
        : labels.completionPerfectMessage;
    }

    function getTypingInputLabel(labels) {
      return activeTypingTargetLanguage === 'ja'
        ? labels.japaneseTypingInputLabel
        : labels.typingInputLabel;
    }

    function updateTypingInputOverlay(compositionText = currentCompositionText) {
      if (!typingInputOverlay || !typingInputOverlayText || activeTypingTargetLanguage !== 'ja') {
        return;
      }
      const value = compositionText || '';
      typingInputOverlayText.textContent = value;
      typingInputOverlay.hidden = !value;
    }

    function showCompletionPanel(accuracy, speed, mistakes, completionState) {
      const labels = getUiText(uiLanguageSelect.value);
      currentCompletionState = completionState;
      completionPanel.hidden = false;
      if (completionTitle) {
        completionTitle.textContent = getCompletionTitle(labels, completionState);
      }
      if (completionStatusNote) {
        completionStatusNote.textContent = completionState === 'finishedWithMistakes'
          ? labels.completionFinishedNote
          : '';
        completionStatusNote.hidden = completionState !== 'finishedWithMistakes';
      }
      if (completionAccuracyValue) {
        completionAccuracyValue.textContent = accuracy + '%';
      }
      if (completionSpeedTitle) {
        completionSpeedTitle.textContent = getSpeedMetricLabel(labels);
      }
      if (completionSpeedValue) {
        completionSpeedValue.textContent = '' + speed;
      }
      if (completionMistakesValue) {
        completionMistakesValue.textContent = '' + mistakes;
      }
      if (completionTranslations) {
        completionTranslations.hidden = activeIsTranslationPractice;
      }
      if (assessmentPanel) {
        assessmentPanel.hidden = false;
      }
      if (assessmentFeedback && assessmentFeedback.dataset.saved !== 'true') {
        assessmentFeedback.textContent = '';
        assessmentFeedback.hidden = true;
      }
      if (assessmentPrompt && assessmentFeedback?.dataset.saved !== 'true') {
        assessmentPrompt.hidden = false;
      }
      if (assessmentActions && assessmentFeedback?.dataset.saved !== 'true') {
        assessmentActions.hidden = false;
      }
    }

    function closeCompletionModal() {
      completionPanel.hidden = true;
      if (closeCompletionTimer) {
        window.clearTimeout(closeCompletionTimer);
        closeCompletionTimer = null;
      }
    }

    function prefersReducedMotion() {
      return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    }

    function scrollToSection(section) {
      if (!section) {
        return;
      }
      section.scrollIntoView({
        behavior: prefersReducedMotion() ? 'auto' : 'smooth',
        block: 'start',
      });
    }

    function getPostAssessmentScrollTarget(level) {
      if (activeIsTranslationPractice) {
        return (completionTranslations && !completionTranslations.hidden ? completionTranslations : null) || postCompletionActions;
      }
      if (level === 'good' || level === 'shaky') {
        return document.getElementById('learning-section');
      }
      return (completionTranslations && !completionTranslations.hidden ? completionTranslations : null) || postCompletionActions;
    }

    function resetPractice() {
      if (closeCompletionTimer) {
        window.clearTimeout(closeCompletionTimer);
        closeCompletionTimer = null;
      }
      input.value = '';
      flowAcceptedValue = '';
      flowMistakes = 0;
      currentCompositionText = '';
      startTime = null;
      hasRecordedCompletion = false;
      hasShownCompletion = false;
      currentCompletionState = null;
      completionPanel.hidden = true;
      if (!activeIsTranslationPractice) {
        expressionsPanel.hidden = true;
        grammarPanel.hidden = true;
      }
      progressValue.textContent = '0%';
      accuracyValue.textContent = '100%';
      wpmValue.textContent = '0';
      if (assessmentFeedback) {
        assessmentFeedback.dataset.saved = 'false';
        assessmentFeedback.textContent = '';
        assessmentFeedback.hidden = true;
      }
      if (assessmentPrompt) {
        assessmentPrompt.hidden = false;
      }
      if (assessmentActions) {
        assessmentActions.hidden = false;
      }
      if (completionTranslations) {
        completionTranslations.hidden = true;
      }
      postCompletionActionSections.forEach((section) => {
        section.hidden = true;
      });
      updateTargetTextProgress('');
      updateTypingInputOverlay('');
      input.focus();
    }

    function getAssessmentPriority(level) {
      if (level === 'again') {
        return 3;
      }
      if (level === 'shaky') {
        return 2;
      }
      if (level === 'good') {
        return 1;
      }
      return 0;
    }

    function saveSelfAssessment(level) {
      const now = new Date().toISOString();
      const assessments = loadProgress(SELF_ASSESSMENT_KEY);
      const finishedWithMistakes = currentCompletionState === 'finishedWithMistakes';
      assessments[getCurrentAssessmentStorageKey()] = {
        textId: text.id,
        mode: activeIsTranslationPractice ? 'translation' : 'text',
        targetLanguage: activeTypingTargetLanguage,
        level,
        priority: getAssessmentPriority(level),
        reviewTarget: level !== 'perfect' || finishedWithMistakes,
        assessedAt: now,
      };
      saveProgress(SELF_ASSESSMENT_KEY, assessments);
      if (assessmentFeedback) {
        assessmentFeedback.dataset.saved = 'true';
        assessmentFeedback.textContent = getUiText(uiLanguageSelect.value).assessmentSaved;
        assessmentFeedback.hidden = false;
      }
      if (assessmentPrompt) {
        assessmentPrompt.hidden = true;
      }
      if (assessmentActions) {
        assessmentActions.hidden = true;
      }
      postCompletionActionSections.forEach((section) => {
        section.hidden = false;
      });
      if (closeCompletionTimer) {
        window.clearTimeout(closeCompletionTimer);
        closeCompletionTimer = null;
      }
    }

    function handleSelfAssessment(level) {
      saveSelfAssessment(level);
      if (level === 'again') {
        resetPractice();
        return;
      }
      closeCompletionModal();
      window.setTimeout(() => {
        scrollToSection(getPostAssessmentScrollTarget(level));
      }, 0);
    }

    function goToRecommendedText() {
      const recommended = getRecommendedText();
      if (!recommended) {
        return;
      }
      window.location.href = getRecommendedHref(recommended);
    }

    function getTypingStats(typed) {
      const target = activeTypingTarget;
      let correct = 0;
      for (let i = 0; i < typed.length; i += 1) {
        if (typingCharactersMatch(typed[i], target[i])) {
          correct += 1;
        }
      }
      const progress = Math.min(100, Math.round((correct / target.length) * 100));
      const attempts = currentTypingMode === 'flow' ? typed.length + flowMistakes : typed.length;
      const accuracy = attempts ? Math.round((correct / attempts) * 100) : 100;
      const elapsedMinutes = startTime ? Math.max((performance.now() - startTime) / 60000, 0.001) : 0;
      let speed = 0;
      if (startTime && elapsedMinutes > 0) {
        if (activeTypingTargetLanguage === 'ja') {
          speed = Math.round(correct / elapsedMinutes);
        } else {
          const words = typed.trim().split(/\\s+/).filter(Boolean).length;
          const rawWpm = Math.round(words / elapsedMinutes);
          speed = Math.min(rawWpm, 200);
        }
      }
      const mistakes = currentTypingMode === 'flow' ? flowMistakes : typed.length - correct;
      return { accuracy, correct, mistakes, progress, speed };
    }

    function getTypingCompletionState(typed, accuracy, mistakes) {
      if (typed.length < activeTypingTarget.length) {
        return null;
      }
      return typingStringsMatch(typed, activeTypingTarget) && accuracy === 100 && mistakes === 0
        ? 'perfectComplete'
        : 'finishedWithMistakes';
    }

    function updateMetrics() {
      const typed = input.value;
      const { accuracy, mistakes, progress, speed } = getTypingStats(typed);
      progressValue.textContent = progress + '%';
      accuracyValue.textContent = accuracy + '%';
      wpmValue.textContent = '' + speed;
      updateTargetTextProgress(typed);
      const completionState = getTypingCompletionState(typed, accuracy, mistakes);
      if (completionState && !hasShownCompletion) {
        hasShownCompletion = true;
        showCompletionPanel(accuracy, speed, mistakes, completionState);
        if (!activeIsTranslationPractice) {
          expressionsPanel.hidden = false;
          grammarPanel.hidden = false;
        }
        if (!activeIsTranslationPractice && !hasRecordedCompletion) {
          hasRecordedCompletion = true;
          recordCompletion(accuracy, speed);
        }
      }
    }

    let startTime = null;
    let hasRecordedCompletion = false;
    let hasShownCompletion = false;
    let isComposing = false;

    function flashCurrentMistake(index) {
      const currentChar = Array.from(targetCharacters).find((char) => Number(char.dataset.charIndex) === index);
      if (!currentChar) {
        return;
      }
      currentChar.classList.remove('flow-mistake');
      void currentChar.offsetWidth;
      currentChar.classList.add('flow-mistake');
      window.setTimeout(() => {
        currentChar.classList.remove('flow-mistake');
      }, 280);
    }

    function processFlowInput() {
      const target = activeTypingTarget;
      const rawValue = input.value;
      if (rawValue.length < flowAcceptedValue.length) {
        flowAcceptedValue = rawValue.slice(0, Math.min(rawValue.length, target.length));
        input.value = flowAcceptedValue;
        return;
      }

      let nextAccepted = flowAcceptedValue;
      const pending = rawValue.slice(flowAcceptedValue.length);
      for (const char of Array.from(pending)) {
        if (nextAccepted.length >= target.length) {
          break;
        }
        if (typingCharactersMatch(char, target[nextAccepted.length])) {
          nextAccepted += char;
        } else {
          flowMistakes += 1;
          flashCurrentMistake(nextAccepted.length);
        }
      }
      flowAcceptedValue = nextAccepted;
      input.value = nextAccepted;
    }

    input.addEventListener('input', (event) => {
      if (event.isComposing || isComposing) {
        updateTypingInputOverlay(currentCompositionText);
        return;
      }
      if (!startTime) {
        startTime = performance.now();
      }
      if (currentTypingMode === 'flow') {
        processFlowInput();
      }
      updateMetrics();
      updateTypingInputOverlay('');
    });

    input.addEventListener('compositionstart', () => {
      isComposing = true;
      currentCompositionText = '';
      updateTypingInputOverlay('');
    });

    input.addEventListener('compositionupdate', (event) => {
      currentCompositionText = event.data || '';
      updateTypingInputOverlay(currentCompositionText);
    });

    input.addEventListener('compositionend', () => {
      isComposing = false;
      currentCompositionText = '';
      if (!startTime) {
        startTime = performance.now();
      }
      if (currentTypingMode === 'flow') {
        processFlowInput();
      }
      updateMetrics();
      updateTypingInputOverlay('');
    });

    typingModeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        saveTypingMode(button.dataset.typingMode);
        input.focus();
      });
    });

    statusButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        cycleExpressionStatus(button.dataset.expressionStatus);
      });
    });

    expressionCards.forEach((card) => {
      card.addEventListener('click', () => {
        const selectedText = window.getSelection()?.toString();
        if (selectedText) {
          return;
        }
        cycleExpressionStatus(card.dataset.expressionCard);
      });
    });

    bindExpressionHighlights(expressionHighlights);

    if (miniCardDetails) {
      const activateMiniCardDetails = (event) => {
        event.preventDefault();
        event.stopPropagation();
        if (activeMiniCardPhrase) {
          focusFullExpressionCard(activeMiniCardPhrase);
          closeExpressionMiniCard();
        }
      };
      miniCardDetails.addEventListener('pointerdown', (event) => {
        if (event.pointerType === 'mouse') {
          return;
        }
        activateMiniCardDetails(event);
      });
      miniCardDetails.addEventListener('click', (event) => {
        activateMiniCardDetails(event);
      });
    }

    if (expressionMiniCard) {
      expressionMiniCard.addEventListener('pointerdown', (event) => {
        event.stopPropagation();
      });
      expressionMiniCard.addEventListener('click', (event) => {
        event.stopPropagation();
      });
    }

    if (textContent && input) {
      textContent.addEventListener('click', () => {
        focusTypingInput();
      });
      textContent.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          focusTypingInput();
        }
      });
      input.addEventListener('focus', () => {
        textContent.classList.add('is-focused');
      });
      input.addEventListener('blur', () => {
        textContent.classList.remove('is-focused');
      });
    }

    assessmentButtons.forEach((button) => {
      button.addEventListener('click', () => {
        handleSelfAssessment(button.dataset.assessmentLevel);
      });
    });

    postCompletionPracticeAgainButtons.forEach((button) => {
      button.addEventListener('click', resetPractice);
    });

    postCompletionNextButtons.forEach((button) => {
      button.addEventListener('click', goToRecommendedText);
    });

    postCompletionHomeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        window.location.href = getAppHref('');
      });
    });

    if (pinButton) {
      pinButton.addEventListener('click', () => {
        togglePinnedPracticeTarget(getCurrentPracticeTarget());
        updatePinButton();
        updateTranslationPracticePinButtons();
      });
    }

    translationPracticePinButtons.forEach((button) => {
      button.addEventListener('click', () => {
        togglePinnedPracticeTarget({
          textId: text.id,
          practiceType: 'translation',
          practiceTranslation: button.dataset.translationPracticePin,
        });
        updatePinButton();
        updateTranslationPracticePinButtons();
      });
    });

    document.addEventListener('click', () => {
      closeExpressionMiniCard();
    });

    applyPracticeModePresentation();
    const savedUiLanguage = getSavedUiLanguage();
    renderUiText(savedUiLanguage);
    updateExpressionStatusButtons();
    updateExpressionPracticeLabels();
    updatePinButton();
    updateTranslationPracticePinButtons();
    updateTargetTextProgress(input.value);

    uiLanguageSelect.addEventListener('change', (event) => {
      const lang = event.target.value;
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      renderUiText(lang);
    });
  });
`;

if (!text) {
  throw new Error("Text not found");
