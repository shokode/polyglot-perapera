        highlight.dataset.expressionHighlightBound = 'true';
        highlight.addEventListener('click', (event) => {
          event.stopPropagation();
          focusTypingInput();
          const phrase = highlight.dataset.expressionPhrase;
          if (phrase) {
            showExpressionMiniCard(phrase, true, highlight);
          }
        });
        const markerId = highlight.dataset.markerId;
        if (!markerId) {
          return;
        }
        highlight.addEventListener('mouseenter', () => {
          setMarkerHoverState(markerId, true);
          const phrase = highlight.dataset.expressionPhrase;
          if (phrase) {
            showExpressionMiniCard(phrase, false, highlight);
          }
        });
        highlight.addEventListener('mouseleave', () => {
          setMarkerHoverState(markerId, false);
          if (!miniCardPinned) {
            closeExpressionMiniCard();
          }
        });
        highlight.addEventListener('focusin', () => {
          setMarkerHoverState(markerId, true);
          const phrase = highlight.dataset.expressionPhrase;
          if (phrase) {
            showExpressionMiniCard(phrase, false, highlight);
          }
        });
        highlight.addEventListener('focusout', () => {
