---
import texts from "../../data/texts.json" assert { type: "json" };
import "../../styles/global.scss";
import SiteHeader from "../../components/SiteHeader.astro";
import {
  levels as levelKeys,
  uiLanguages,
  uiLanguageNames,
  uiText,
  categoryLabels,
  levelLabels,
  languageNames,
  normalizeLevelKey,
  type UILang,
} from "../../i18n/ui";

export function getStaticPaths() {
  return texts.map((item) => ({ params: { id: item.id } }));
}

const text = texts.find((item) => item.id === Astro.params.id);
const defaultUiLang: UILang = "en";
const appBasePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const appHref = (path: string) => `${appBasePath}${path.replace(/^\//, "")}`;
const targetLanguageBadges: Record<UILang, string> = {
  no: "NO",
  en: "EN",
  ja: "JA",
};

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function escapeRegExp(value: string) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function getTextForm(expression: { phrase: string; formInText?: string }) {
  return expression.formInText || expression.phrase;
}

const learningFocusExpressions =
  text?.expressions.map((item) => item.phrase) ?? [];
const learningFocusGrammar = text?.grammar.map((item) => item.title) ?? [];
const explanationLanguageOrder: UILang[] = ["ja", "en", "no"];

type ExpressionRange = {
  start: number;
  end: number;
  phrase: string;
  markerId: string;
};

function getExpressionRanges(
  value: string,
  expressionsArray: Array<{ phrase: string; formInText?: string }>,
) {
  return expressionsArray.flatMap((expression, expressionIndex) => {
    const textForm = getTextForm(expression);
    const ranges: ExpressionRange[] = [];
    let start = value.indexOf(textForm);
    let occurrence = 0;
    while (start !== -1) {
      ranges.push({
        start,
        end: start + textForm.length,
        phrase: expression.phrase,
        markerId: `expression-${expressionIndex}-${occurrence}`,
      });
      start = value.indexOf(textForm, start + textForm.length);
      occurrence += 1;
    }
    return ranges;
  });
}

function getExpressionRangeAtIndex(index: number, ranges: ExpressionRange[]) {
  return ranges.find((range) => index >= range.start && index < range.end);
}

function renderCharacter(
  value: string,
  index: number,
  ranges: ExpressionRange[],
) {
  const classes = ["target-char"];
  const expressionRange = getExpressionRangeAtIndex(index, ranges);
  const expressionAttribute = expressionRange
    ? ` data-expression-phrase="${escapeHtml(expressionRange.phrase)}" data-marker-id="${escapeHtml(expressionRange.markerId)}"`
    : "";
  if (expressionRange) {
    classes.push("target-highlight", "learning-highlight", "expression");
  }
  return `<span class="${classes.join(" ")}" data-char-index="${index}"${expressionAttribute}>${escapeHtml(value)}</span>`;
}

function renderCharacters(
  value: string,
  startIndex: number,
  ranges: ExpressionRange[],
) {
  return Array.from(value)
    .map((char, offset) => renderCharacter(char, startIndex + offset, ranges))
    .join("");
}

function renderRubyProgressText(
  rubyText: Array<{ text: string; reading?: string }>,
  ranges: ExpressionRange[],
) {
  let index = 0;
  return `<p>${rubyText
    .map((part) => {
      const rendered = renderCharacters(part.text, index, ranges);
      index += Array.from(part.text).length;
      return part.reading
        ? `<ruby class="target-ruby">${rendered}<rt>${escapeHtml(part.reading)}</rt></ruby>`
        : rendered;
    })
    .join("")}</p>`;
}

function renderProgressParagraph(
  paragraph: string,
  paragraphStartIndex: number,
  ranges: ExpressionRange[],
) {
  let index = paragraphStartIndex;
  return paragraph
    .split(/(\s+)/)
    .map((part) => {
      const startIndex = index;
      index += part.length;
      if (!part) {
        return "";
      }
      if (/^\s+$/.test(part)) {
        return `<span class="target-space">${renderCharacters(part, startIndex, ranges)}</span>`;
      }
      return `<span class="target-word">${renderCharacters(part, startIndex, ranges)}</span>`;
    })
    .join("");
}

function renderProgressText(
  value: string,
  expressionsArray: Array<{ phrase: string; formInText?: string }>,
  rubyText?: Array<{ text: string; reading?: string }>,
) {
  const ranges = getExpressionRanges(value, expressionsArray);
  if (rubyText) {
    return renderRubyProgressText(rubyText, ranges);
  }

  let index = 0;
  return value
    .split("\n\n")
    .map((paragraph) => {
      const rendered = renderProgressParagraph(paragraph, index, ranges);
      index += paragraph.length + 2;
      return `<p>${rendered}</p>`;
    })
    .join("");
}

function getTranslationValue(item: Record<string, unknown>, lang: UILang) {
  const fieldByLanguage: Record<UILang, string> = {
    ja: "translationJa",
    en: "translationEn",
    no: "translationNo",
  };
  const value = item[fieldByLanguage[lang]];
  return typeof value === "string" && value.trim() ? value : null;
}

function getTranslationsToShow(item: Record<string, unknown>) {
  return explanationLanguageOrder
    .filter((lang) => lang !== item.language)
    .map((lang) => ({ lang, value: getTranslationValue(item, lang) }))
    .filter((translation): translation is { lang: UILang; value: string } =>
      Boolean(translation.value),
    );
}

function getTranslationPracticeButtonLabel(
  lang: UILang,
  labels: (typeof uiText)[UILang],
) {
  if (lang === "ja") {
    return labels.typeThisInJapanese;
  }
  if (lang === "no") {
    return labels.typeThisInNorwegian;
  }
  return labels.typeThisInEnglish;
}

function getLanguageBadgeClass(lang: UILang) {
  return `language-badge language-badge--${lang}`;
}

function getExplanationMap(item: Record<string, unknown>) {
  return {
    ja:
      typeof item.ja === "string"
        ? item.ja
        : typeof item.descriptionJa === "string"
          ? item.descriptionJa
          : "",
    en:
      typeof item.en === "string"
        ? item.en
        : typeof item.descriptionEn === "string"
          ? item.descriptionEn
          : "",
    no:
      typeof item.no === "string"
        ? item.no
        : typeof item.descriptionNo === "string"
          ? item.descriptionNo
          : "",
  };
}

function getExampleMap(item: Record<string, unknown>) {
  return {
    default: typeof item.example === "string" ? item.example : "",
    ja: typeof item.exampleJa === "string" ? item.exampleJa : "",
    en: typeof item.exampleEn === "string" ? item.exampleEn : "",
    no: typeof item.exampleNo === "string" ? item.exampleNo : "",
  };
}

function hasExample(item: Record<string, unknown>) {
  return Object.values(getExampleMap(item)).some((value) => value.trim());
}

function getOrderedExamples(
  item: Record<string, unknown>,
  uiLang: UILang,
  targetLang: UILang,
) {
  const examples = getExampleMap(item);
  return [
    { lang: "default", value: examples.default },
    ...explanationLanguageOrder
      .filter((lang) => lang !== targetLang)
      .map((lang) => ({ lang, value: examples[lang] })),
  ].filter(
    (entry, index, array) =>
      entry.value &&
      array.findIndex((item) => item.value === entry.value) === index,
  );
}

function getOrderedExplanations(item: Record<string, unknown>, uiLang: UILang) {
  const explanations = getExplanationMap(item);
  return [uiLang, ...explanationLanguageOrder.filter((lang) => lang !== uiLang)]
    .map((lang) => ({ lang, value: explanations[lang] }))
    .filter((entry) => entry.value);
}

// TODO: Future Japanese typing mode can support exact kanji mode and kana reading mode.
// For now, typing comparison intentionally uses the plain text field only.
const requestedPracticeTranslation = Astro.url.searchParams.get(
  "practiceTranslation",
);
const practiceTranslationLang =
  text &&
  uiLanguages.includes(requestedPracticeTranslation as UILang) &&
  requestedPracticeTranslation !== text.language &&
  getTranslationValue(text, requestedPracticeTranslation as UILang)
    ? (requestedPracticeTranslation as UILang)
    : null;
const isTranslationPractice = Boolean(practiceTranslationLang);
const typingTarget = text
  ? practiceTranslationLang
    ? (getTranslationValue(text, practiceTranslationLang) ?? text.text)
    : text.text
  : "";
const typingTargetLanguage = practiceTranslationLang ?? text?.language;
const highlightedTextHtml = text
  ? renderProgressText(
      typingTarget,
      isTranslationPractice ? [] : text.expressions,
      !isTranslationPractice &&
        text.language === "ja" &&
        "rubyText" in text &&
        Array.isArray(text.rubyText)
        ? text.rubyText
        : undefined,
    )
  : "";
const translationsToShow =
  text && !isTranslationPractice ? getTranslationsToShow(text) : [];
const translationPracticeHrefBase = text ? appHref(`text/${text.id}`) : "";
const recommendationTexts = texts.map((item) => ({
  id: item.id,
  language: item.language,
  title: item.title,
  expressions: item.expressions,
  translationJa: item.translationJa,
  translationEn: item.translationEn,
  translationNo: item.translationNo,
}));

const clientScript = `
  const text = ${JSON.stringify(text)};
  const BASE_PATH = ${JSON.stringify(import.meta.env.BASE_URL)};
  const allTexts = ${JSON.stringify(recommendationTexts)};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const uiLanguageNames = ${JSON.stringify(uiLanguageNames)};
  const categoryLabels = ${JSON.stringify(categoryLabels)};
  const levelLabels = ${JSON.stringify(levelLabels)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = ${JSON.stringify(targetLanguageBadges)};
  const levelKeys = ${JSON.stringify(levelKeys)};
  const legacyLevelMap = {
    basic: 'a1',
    useful: 'a2',
    daily: 'b1',
    advanced: 'b2',
    natural: 'natural',
  };
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const TEXT_PROGRESS_KEY = 'typingProgress';
  const EXPRESSION_PROGRESS_KEY = 'expressionProgress';
  const SELF_ASSESSMENT_KEY = 'typingSelfAssessment';
  const TYPING_MODE_KEY = 'typingMode';
  const PINNED_TEXTS_KEY = 'typingPinnedTexts';
  const PINNED_PRACTICE_TARGETS_KEY = 'typingPinnedPracticeTargets';
  const EXPRESSION_STATUSES = ['new', 'review', 'learned'];
  const translationFieldByLanguage = {
    ja: 'translationJa',
    en: 'translationEn',
    no: 'translationNo',
  };

  function getClientTranslationValue(lang) {
    const field = translationFieldByLanguage[lang];
    const value = field ? text[field] : null;
    return typeof value === 'string' && value.trim() ? value : null;
  }

  const requestedPracticeTranslation = new URLSearchParams(window.location.search).get('practiceTranslation');
  const activePracticeTranslationLang = uiLanguages.includes(requestedPracticeTranslation)
    && requestedPracticeTranslation !== text.language
    && getClientTranslationValue(requestedPracticeTranslation)
      ? requestedPracticeTranslation
      : null;
  const activeIsTranslationPractice = Boolean(activePracticeTranslationLang);
  const activeTypingTarget = activePracticeTranslationLang
    ? getClientTranslationValue(activePracticeTranslationLang)
    : text.text;
  const activeTypingTargetLanguage = activePracticeTranslationLang || text.language;
  const norwegianTypingPlaceholders = {
    'æ': '\uE000',
    'Æ': '\uE001',
    'ø': '\uE002',
    'Ø': '\uE003',
    'å': '\uE004',
    'Å': '\uE005',
  };
  const norwegianTypingPlaceholderPattern = /[æÆøØåÅ]/g;
  const norwegianTypingPlaceholderRestorePattern = /[\uE000-\uE005]/g;

  function normalizeForTyping(value, language) {
    if (language !== 'no' || typeof value !== 'string') {
      return value;
    }
    return value
      .replace(norwegianTypingPlaceholderPattern, (char) => norwegianTypingPlaceholders[char])
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(norwegianTypingPlaceholderRestorePattern, (char) => (
        Object.keys(norwegianTypingPlaceholders).find((key) => norwegianTypingPlaceholders[key] === char) || char
      ));
  }

  function typingCharactersMatch(typedChar, targetChar) {
    return normalizeForTyping(typedChar, activeTypingTargetLanguage)
      === normalizeForTyping(targetChar, activeTypingTargetLanguage);
  }

  function typingStringsMatch(typedValue, targetValue) {
    if (typedValue.length !== targetValue.length) {
      return false;
    }
    for (let index = 0; index < targetValue.length; index += 1) {
      if (!typingCharactersMatch(typedValue[index], targetValue[index])) {
        return false;
      }
    }
    return true;
  }

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function getAppHref(path) {
    const base = BASE_PATH || '/';
    const normalizedBase = base.endsWith('/') ? base : base + '/';
    const normalizedPath = String(path).replace(/^\\//, '');
    return normalizedBase + normalizedPath;
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function loadPinnedTextIds() {
    try {
      const parsed = JSON.parse(safeReadStorage(PINNED_TEXTS_KEY) || '[]');
      return Array.isArray(parsed) ? parsed.filter((id) => typeof id === 'string') : [];
    } catch {
      return [];
    }
  }

  function normalizePracticeTarget(target) {
    if (!target || typeof target !== 'object' || typeof target.textId !== 'string') {
      return null;
    }
    if (target.practiceType === 'translation' && uiLanguages.includes(target.practiceTranslation)) {
      return {
        textId: target.textId,
        practiceType: 'translation',
        practiceTranslation: target.practiceTranslation,
      };
    }
    return {
      textId: target.textId,
      practiceType: 'original',
      practiceTranslation: null,
    };
  }

  function getPracticeTargetKey(target) {
    return target.textId + '::' + target.practiceType + '::' + (target.practiceTranslation || '');
  }

  function getOriginalPracticeTarget(textId) {
    return { textId, practiceType: 'original', practiceTranslation: null };
  }

  function getCurrentPracticeTarget() {
    return activeIsTranslationPractice && activePracticeTranslationLang
      ? { textId: text.id, practiceType: 'translation', practiceTranslation: activePracticeTranslationLang }
      : getOriginalPracticeTarget(text.id);
  }

  function loadPinnedPracticeTargets() {
    const targets = loadPinnedTextIds().map(getOriginalPracticeTarget);
    try {
      const parsed = JSON.parse(safeReadStorage(PINNED_PRACTICE_TARGETS_KEY) || '[]');
      if (Array.isArray(parsed)) {
        parsed.forEach((item) => {
          const target = normalizePracticeTarget(item);
          if (target) {
            targets.push(target);
          }
        });
      }
    } catch {
      // ignore
    }
    const seen = new Set();
    return targets.filter((target) => {
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
  }

  function savePinnedPracticeTargets(targets) {
    const normalized = targets.map(normalizePracticeTarget).filter(Boolean);
    const seen = new Set();
    const deduped = normalized.filter((target) => {
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
    safeWriteStorage(PINNED_PRACTICE_TARGETS_KEY, JSON.stringify(deduped));
  }

  function savePinnedTextIds(ids) {
    safeWriteStorage(PINNED_TEXTS_KEY, JSON.stringify(Array.from(new Set(ids))));
  }

  function isPracticeTargetPinned(target) {
    const normalized = normalizePracticeTarget(target);
    if (!normalized) {
      return false;
    }
    const key = getPracticeTargetKey(normalized);
    return loadPinnedPracticeTargets().some((item) => getPracticeTargetKey(item) === key);
  }

  function togglePinnedPracticeTarget(target) {
    const normalized = normalizePracticeTarget(target);
    if (!normalized) {
      return;
    }
    const key = getPracticeTargetKey(normalized);
    const pinnedTargets = loadPinnedPracticeTargets();
    const wasPinned = pinnedTargets.some((item) => getPracticeTargetKey(item) === key);
    if (wasPinned) {
      savePinnedPracticeTargets(pinnedTargets.filter((item) => getPracticeTargetKey(item) !== key));
    } else {
      savePinnedPracticeTargets([...pinnedTargets, normalized]);
    }
    if (normalized.practiceType === 'original') {
      const pinned = loadPinnedTextIds();
      if (wasPinned) {
        savePinnedTextIds(pinned.filter((id) => id !== normalized.textId));
      } else {
        savePinnedTextIds([...pinned, normalized.textId]);
      }
    }
  }

  function saveExpressionStatuses(data) {
    safeWriteStorage(EXPRESSION_STATUS_KEY, JSON.stringify(data));
  }

  function loadProgress(key) {
    try {
      const parsed = JSON.parse(safeReadStorage(key) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveProgress(key, data) {
    safeWriteStorage(key, JSON.stringify(data));
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return typeof stored === 'string' && uiLanguages.includes(stored) ? stored : 'en';
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function getLanguageTitle(value, lang) {
    return languageNames[value]?.[lang] || value;
  }

  function getLanguageBadgeHtml(value, lang) {
    const label = targetLanguageBadges[value] || value;
    const title = getLanguageTitle(value, lang);
    return '<span class="language-badge language-badge--' + escapeHtmlClient(value) + '" data-target-language="' + escapeHtmlClient(value) + '" title="' + escapeHtmlClient(title) + '" aria-label="' + escapeHtmlClient(title) + '">' + escapeHtmlClient(label) + '</span>';
  }

  function normalizeLevelKey(level) {
    if (legacyLevelMap[level]) {
      return legacyLevelMap[level];
    }
    return levelKeys.includes(level) ? level : 'natural';
  }

  function getExpressionByPhrase(phrase) {
    return text.expressions.find((expression) => expression.phrase === phrase) || null;
  }

  function getExpressionLegacyKey(phrase) {
    const expression = getExpressionByPhrase(phrase);
    return expression?.storageKey || phrase;
  }

  function getExpressionStorageKey(phrase) {
    return text.language + '::' + getExpressionLegacyKey(phrase);
  }

  function getExpressionStorageKeyForItem(expression, language) {
    return language + '::' + (expression.storageKey || expression.phrase);
  }

  function getExpressionStatus(phrase) {
    const all = loadExpressionStatuses();
    const stored = all[getExpressionStorageKey(phrase)] || all[getExpressionLegacyKey(phrase)] || all[text.language + '::' + phrase] || all[phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getExpressionStatusForItem(expression, language, statuses) {
    const stored = statuses[getExpressionStorageKeyForItem(expression, language)]
      || statuses[expression.storageKey]
      || statuses[language + '::' + expression.phrase]
      || statuses[expression.phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getNextExpressionStatus(status) {
    const currentIndex = EXPRESSION_STATUSES.indexOf(status);
    return EXPRESSION_STATUSES[(currentIndex + 1) % EXPRESSION_STATUSES.length];
  }

  function getExpressionStatusLabel(status, labels) {
    if (status === 'review') {
      return labels.expressionStatusReview;
    }
    if (status === 'learned') {
      return labels.expressionStatusLearned;
    }
    return labels.expressionStatusNew;
  }

  function getExpressionPractice(phrase) {
    const progress = loadProgress(EXPRESSION_PROGRESS_KEY);
    const entry = progress[getExpressionStorageKey(phrase)] || progress[getExpressionLegacyKey(phrase)] || progress[text.language + '::' + phrase] || progress[phrase] || {};
    const practiceCount = Number.isFinite(entry.practiceCount) ? entry.practiceCount : 0;
    return {
      practiceCount,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : null,
    };
  }

  function getTextProgress(textId) {
    const entry = loadProgress(TEXT_PROGRESS_KEY)[textId] || {};
    return {
      completedCount: Number.isFinite(entry.completedCount) ? entry.completedCount : 0,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : '',
    };
  }

  function getAssessmentStorageKeyForText(textId, mode, targetLanguage) {
    return textId + '::' + mode + '::' + targetLanguage;
  }

  function getCurrentAssessmentStorageKey() {
    return getAssessmentStorageKeyForText(
      text.id,
      activeIsTranslationPractice ? 'translation' : 'text',
      activeTypingTargetLanguage
    );
  }

  function getReviewCountForText(item, statuses) {
    return item.expressions.reduce((count, expression) => {
      return count + (getExpressionStatusForItem(expression, item.language, statuses) === 'review' ? 1 : 0);
    }, 0);
  }

  function getTranslationValueForItem(item, lang) {
    const field = translationFieldByLanguage[lang];
    const value = field ? item[field] : null;
    return typeof value === 'string' && value.trim() ? value : null;
  }

  function getTranslationLanguagesForText(item) {
    return uiLanguages.filter((lang) => lang !== item.language && getTranslationValueForItem(item, lang));
  }

  function isTextLearned(item, statuses) {
    return item.expressions.length > 0
      && item.expressions.every((expression) => getExpressionStatusForItem(expression, item.language, statuses) === 'learned');
  }

  function getAssessmentEntryForPracticeTarget(target, item) {
    const assessments = loadProgress(SELF_ASSESSMENT_KEY);
    const mode = target.practiceType === 'translation' ? 'translation' : 'text';
    const targetLanguage = target.practiceType === 'translation' ? target.practiceTranslation : item.language;
    return assessments[getAssessmentStorageKeyForText(target.textId, mode, targetLanguage)] || {};
  }

  function getRecommendedHref(target) {
    if (target.practiceType === 'translation' && target.practiceTranslation) {
      return getAppHref('text/' + encodeURIComponent(target.textId) + '?practiceTranslation=' + encodeURIComponent(target.practiceTranslation));
    }
    return getAppHref('text/' + encodeURIComponent(target.textId));
  }

  function getPinnedPracticeTargets(items) {
    const itemIds = new Set(items.map((item) => item.id));
    const targets = loadPinnedPracticeTargets().filter((target) => itemIds.has(target.textId));
    const seen = new Set();
    return targets.filter((target) => {
      const item = allTexts.find((entry) => entry.id === target.textId);
      if (!item) {
        return false;
      }
      if (target.practiceType === 'translation' && !getTranslationLanguagesForText(item).includes(target.practiceTranslation)) {
        return false;
      }
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
  }

  function getRecommendationCandidates(items) {
    const candidates = new Map();
    const addCandidate = (item, target) => {
      const normalized = normalizePracticeTarget(target);
      if (!normalized) {
        return;
      }
      if (normalized.practiceType === 'translation' && !getTranslationLanguagesForText(item).includes(normalized.practiceTranslation)) {
        return;
      }
      candidates.set(getPracticeTargetKey(normalized), { item, target: normalized });
    };

    items.forEach((item) => {
      addCandidate(item, getOriginalPracticeTarget(item.id));
      getTranslationLanguagesForText(item).forEach((lang) => {
        const target = { textId: item.id, practiceType: 'translation', practiceTranslation: lang };
        const assessment = getAssessmentEntryForPracticeTarget(target, item);
        if (assessment.level === 'again' || assessment.level === 'shaky') {
          addCandidate(item, target);
        }
      });
    });

    getPinnedPracticeTargets(items).forEach((target) => {
      const item = allTexts.find((entry) => entry.id === target.textId);
      if (item) {
        addCandidate(item, target);
      }
    });

    return Array.from(candidates.values());
  }

  function scoreRecommendationCandidate(item, target, expressionStatuses, pinnedKeys) {
    const progress = getTextProgress(item.id);
    const reviewCount = getReviewCountForText(item, expressionStatuses);
    const assessment = getAssessmentEntryForPracticeTarget(target, item);
    const learned = isTextLearned(item, expressionStatuses);
    const pinned = pinnedKeys.has(getPracticeTargetKey(target));
    let group = 7;

    if (pinned) {
      group = 1;
    } else if (assessment.level === 'again') {
      group = 2;
    } else if (assessment.level === 'shaky') {
      group = 3;
    } else if (reviewCount > 0) {
      group = 4;
    } else if (learned) {
      group = 8;
    } else if (progress.completedCount > 0 && progress.completedCount < 3) {
      group = 5;
    } else if (progress.completedCount === 0) {
      group = 6;
    }

    return {
      item,
      target,
      group,
      assessmentPriority: Number.isFinite(assessment.priority) ? assessment.priority : 0,
      assessedAt: Date.parse(assessment.assessedAt || '') || 0,
      reviewCount,
      practiceCount: progress.completedCount,
      sameLanguage: (target.practiceType === 'translation' ? target.practiceTranslation : item.language) === activeTypingTargetLanguage,
      title: (item.title || item.id) + (target.practiceTranslation || ''),
    };
  }

  function randomItem(items) {
    return items[Math.floor(Math.random() * items.length)];
  }

  function getRecommendedText() {
    const baseItems = allTexts.filter((item) => item.id !== text.id);
    const fallbackItems = baseItems.length ? baseItems : allTexts;
    if (!fallbackItems.length) {
      return null;
    }

    const expressionStatuses = loadExpressionStatuses();
    const pinnedKeys = new Set(getPinnedPracticeTargets(fallbackItems).map(getPracticeTargetKey));
    const scored = getRecommendationCandidates(fallbackItems).map(({ item, target }) => {
      return scoreRecommendationCandidate(item, target, expressionStatuses, pinnedKeys);
    }).sort((a, b) => {
      return a.group - b.group
        || b.assessmentPriority - a.assessmentPriority
        || b.assessedAt - a.assessedAt
        || b.reviewCount - a.reviewCount
        || a.practiceCount - b.practiceCount
        || Number(b.sameLanguage) - Number(a.sameLanguage)
        || a.title.localeCompare(b.title);
    });
    const best = scored.filter((entry) => {
      const first = scored[0];
      return entry.group === first.group
        && entry.assessmentPriority === first.assessmentPriority
        && entry.assessedAt === first.assessedAt
        && entry.reviewCount === first.reviewCount
        && entry.practiceCount === first.practiceCount;
    });
    return randomItem(best).target;
  }

  function getPracticeLevel(count) {
    if (count >= 5) {
      return '3';
    }
    if (count >= 3) {
      return '2';
    }
    if (count >= 1) {
      return '1';
    }
    return '0';
  }

  function getPracticeLabel(count, labels) {
    if (count <= 0) {
      return labels.expressionNotPracticed;
    }
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function getTranslationTitle(lang, labels) {
    if (lang === 'ja') {
