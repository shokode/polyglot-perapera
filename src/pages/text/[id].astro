---
import texts from '../../data/texts.json' assert { type: 'json' };
import '../../styles/global.scss';
import {
  levels as levelKeys,
  uiLanguages,
  uiLanguageNames,
  uiText,
  categoryLabels,
  levelLabels,
  languageNames,
  normalizeLevelKey,
  type UILang,
} from '../../i18n/ui';

export function getStaticPaths() {
  return texts.map((item) => ({ params: { id: item.id } }));
}

const text = texts.find((item) => item.id === Astro.params.id);
const defaultUiLang: UILang = 'en';

function escapeHtml(value: string) {
  return value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function escapeRegExp(value: string) {
  return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

function getTextForm(expression: { phrase: string; formInText?: string }) {
  return expression.formInText || expression.phrase;
}

const learningFocusExpressions = text?.expressions.map((item) => item.phrase) ?? [];
const learningFocusGrammar = text?.grammar.map((item) => item.title) ?? [];
const explanationLanguageOrder: UILang[] = ['ja', 'en', 'no'];

function getExpressionRanges(value: string, expressionsArray: Array<{ phrase: string; formInText?: string }>) {
  return expressionsArray.flatMap((expression) => {
    const textForm = getTextForm(expression);
    const ranges: Array<{ start: number; end: number; phrase: string }> = [];
    let start = value.indexOf(textForm);
    while (start !== -1) {
      ranges.push({ start, end: start + textForm.length, phrase: expression.phrase });
      start = value.indexOf(textForm, start + textForm.length);
    }
    return ranges;
  });
}

function getExpressionRangeAtIndex(index: number, ranges: Array<{ start: number; end: number; phrase: string }>) {
  return ranges.find((range) => index >= range.start && index < range.end);
}

function renderCharacter(value: string, index: number, ranges: Array<{ start: number; end: number; phrase: string }>) {
  const classes = ['target-char'];
  const expressionRange = getExpressionRangeAtIndex(index, ranges);
  const expressionAttribute = expressionRange ? ` data-expression-phrase="${escapeHtml(expressionRange.phrase)}"` : '';
  if (expressionRange) {
    classes.push('target-highlight', 'learning-highlight', 'expression');
  }
  return `<span class="${classes.join(' ')}" data-char-index="${index}"${expressionAttribute}>${escapeHtml(value)}</span>`;
}

function renderCharacters(value: string, startIndex: number, ranges: Array<{ start: number; end: number; phrase: string }>) {
  return Array.from(value).map((char, offset) => renderCharacter(char, startIndex + offset, ranges)).join('');
}

function renderRubyProgressText(rubyText: Array<{ text: string; reading?: string }>, ranges: Array<{ start: number; end: number; phrase: string }>) {
  let index = 0;
  return `<p>${rubyText.map((part) => {
    const rendered = renderCharacters(part.text, index, ranges);
    index += Array.from(part.text).length;
    return part.reading
      ? `<ruby class="target-ruby">${rendered}<rt>${escapeHtml(part.reading)}</rt></ruby>`
      : rendered;
  }).join('')}</p>`;
}

function renderProgressParagraph(paragraph: string, paragraphStartIndex: number, ranges: Array<{ start: number; end: number; phrase: string }>) {
  let index = paragraphStartIndex;
  return paragraph.split(/(\s+)/).map((part) => {
    const startIndex = index;
    index += part.length;
    if (!part) {
      return '';
    }
    if (/^\s+$/.test(part)) {
      return `<span class="target-space">${renderCharacters(part, startIndex, ranges)}</span>`;
    }
    return `<span class="target-word">${renderCharacters(part, startIndex, ranges)}</span>`;
  }).join('');
}

function renderProgressText(value: string, expressionsArray: Array<{ phrase: string; formInText?: string }>, rubyText?: Array<{ text: string; reading?: string }>) {
  const ranges = getExpressionRanges(value, expressionsArray);
  if (rubyText) {
    return renderRubyProgressText(rubyText, ranges);
  }

  let index = 0;
  return value.split('\n\n').map((paragraph) => {
    const rendered = renderProgressParagraph(paragraph, index, ranges);
    index += paragraph.length + 2;
    return `<p>${rendered}</p>`;
  }).join('');
}

function getTranslationValue(item: Record<string, unknown>, lang: UILang) {
  const fieldByLanguage: Record<UILang, string> = {
    ja: 'translationJa',
    en: 'translationEn',
    no: 'translationNo',
  };
  const value = item[fieldByLanguage[lang]];
  return typeof value === 'string' && value.trim() ? value : null;
}

function getTranslationsToShow(item: Record<string, unknown>) {
  return explanationLanguageOrder
    .filter((lang) => lang !== item.language)
    .map((lang) => ({ lang, value: getTranslationValue(item, lang) }))
    .filter((translation): translation is { lang: UILang; value: string } => Boolean(translation.value));
}

function getTranslationPracticeButtonLabel(lang: UILang, labels: (typeof uiText)[UILang]) {
  if (lang === 'ja') {
    return labels.typeThisInJapanese;
  }
  if (lang === 'no') {
    return labels.typeThisInNorwegian;
  }
  return labels.typeThisInEnglish;
}

function getExplanationMap(item: Record<string, unknown>) {
  return {
    ja: typeof item.ja === 'string' ? item.ja : typeof item.descriptionJa === 'string' ? item.descriptionJa : '',
    en: typeof item.en === 'string' ? item.en : typeof item.descriptionEn === 'string' ? item.descriptionEn : '',
    no: typeof item.no === 'string' ? item.no : typeof item.descriptionNo === 'string' ? item.descriptionNo : '',
  };
}

function getExampleMap(item: Record<string, unknown>) {
  return {
    default: typeof item.example === 'string' ? item.example : '',
    ja: typeof item.exampleJa === 'string' ? item.exampleJa : '',
    en: typeof item.exampleEn === 'string' ? item.exampleEn : '',
    no: typeof item.exampleNo === 'string' ? item.exampleNo : '',
  };
}

function hasExample(item: Record<string, unknown>) {
  return Object.values(getExampleMap(item)).some((value) => value.trim());
}

function getOrderedExamples(item: Record<string, unknown>, uiLang: UILang, targetLang: UILang) {
  const examples = getExampleMap(item);
  return [
    { lang: 'default', value: examples.default },
    ...explanationLanguageOrder
      .filter((lang) => lang !== targetLang)
      .map((lang) => ({ lang, value: examples[lang] })),
  ].filter((entry, index, array) => entry.value && array.findIndex((item) => item.value === entry.value) === index);
}

function getOrderedExplanations(item: Record<string, unknown>, uiLang: UILang) {
  const explanations = getExplanationMap(item);
  return [uiLang, ...explanationLanguageOrder.filter((lang) => lang !== uiLang)]
    .map((lang) => ({ lang, value: explanations[lang] }))
    .filter((entry) => entry.value);
}

// TODO: Future Japanese typing mode can support exact kanji mode and kana reading mode.
// For now, typing comparison intentionally uses the plain text field only.
const requestedPracticeTranslation = Astro.url.searchParams.get('practiceTranslation');
const practiceTranslationLang = text
  && uiLanguages.includes(requestedPracticeTranslation as UILang)
  && requestedPracticeTranslation !== text.language
  && getTranslationValue(text, requestedPracticeTranslation as UILang)
  ? requestedPracticeTranslation as UILang
  : null;
const isTranslationPractice = Boolean(practiceTranslationLang);
const typingTarget = text
  ? practiceTranslationLang
    ? getTranslationValue(text, practiceTranslationLang) ?? text.text
    : text.text
  : '';
const highlightedTextHtml = text
  ? renderProgressText(
    typingTarget,
    isTranslationPractice ? [] : text.expressions,
    !isTranslationPractice && text.language === 'ja' && 'rubyText' in text && Array.isArray(text.rubyText) ? text.rubyText : undefined
  )
  : '';
const translationsToShow = text && !isTranslationPractice ? getTranslationsToShow(text) : [];
const translationPracticeHrefBase = text ? `/text/${text.id}` : '';

const clientScript = `
  const text = ${JSON.stringify(text)};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const uiLanguageNames = ${JSON.stringify(uiLanguageNames)};
  const categoryLabels = ${JSON.stringify(categoryLabels)};
  const levelLabels = ${JSON.stringify(levelLabels)};
  const languageNames = ${JSON.stringify(languageNames)};
  const levelKeys = ${JSON.stringify(levelKeys)};
  const legacyLevelMap = {
    basic: 'a1',
    useful: 'a2',
    daily: 'b1',
    advanced: 'b2',
    natural: 'natural',
  };
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const TEXT_PROGRESS_KEY = 'typingProgress';
  const EXPRESSION_PROGRESS_KEY = 'expressionProgress';
  const EXPRESSION_STATUSES = ['new', 'review', 'learned'];
  const translationFieldByLanguage = {
    ja: 'translationJa',
    en: 'translationEn',
    no: 'translationNo',
  };

  function getClientTranslationValue(lang) {
    const field = translationFieldByLanguage[lang];
    const value = field ? text[field] : null;
    return typeof value === 'string' && value.trim() ? value : null;
  }

  const requestedPracticeTranslation = new URLSearchParams(window.location.search).get('practiceTranslation');
  const activePracticeTranslationLang = uiLanguages.includes(requestedPracticeTranslation)
    && requestedPracticeTranslation !== text.language
    && getClientTranslationValue(requestedPracticeTranslation)
      ? requestedPracticeTranslation
      : null;
  const activeIsTranslationPractice = Boolean(activePracticeTranslationLang);
  const activeTypingTarget = activePracticeTranslationLang
    ? getClientTranslationValue(activePracticeTranslationLang)
    : text.text;
  const activeTypingTargetLanguage = activePracticeTranslationLang || text.language;

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveExpressionStatuses(data) {
    safeWriteStorage(EXPRESSION_STATUS_KEY, JSON.stringify(data));
  }

  function loadProgress(key) {
    try {
      const parsed = JSON.parse(safeReadStorage(key) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function saveProgress(key, data) {
    safeWriteStorage(key, JSON.stringify(data));
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return typeof stored === 'string' && uiLanguages.includes(stored) ? stored : 'en';
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function normalizeLevelKey(level) {
    if (legacyLevelMap[level]) {
      return legacyLevelMap[level];
    }
    return levelKeys.includes(level) ? level : 'natural';
  }

  function getExpressionByPhrase(phrase) {
    return text.expressions.find((expression) => expression.phrase === phrase) || null;
  }

  function getExpressionLegacyKey(phrase) {
    const expression = getExpressionByPhrase(phrase);
    return expression?.storageKey || phrase;
  }

  function getExpressionStorageKey(phrase) {
    return text.language + '::' + getExpressionLegacyKey(phrase);
  }

  function getExpressionStatus(phrase) {
    const all = loadExpressionStatuses();
    const stored = all[getExpressionStorageKey(phrase)] || all[getExpressionLegacyKey(phrase)] || all[text.language + '::' + phrase] || all[phrase];
    return EXPRESSION_STATUSES.includes(stored) ? stored : 'new';
  }

  function getNextExpressionStatus(status) {
    const currentIndex = EXPRESSION_STATUSES.indexOf(status);
    return EXPRESSION_STATUSES[(currentIndex + 1) % EXPRESSION_STATUSES.length];
  }

  function getExpressionStatusLabel(status, labels) {
    if (status === 'review') {
      return labels.expressionStatusReview;
    }
    if (status === 'learned') {
      return labels.expressionStatusLearned;
    }
    return labels.expressionStatusNew;
  }

  function getExpressionPractice(phrase) {
    const progress = loadProgress(EXPRESSION_PROGRESS_KEY);
    const entry = progress[getExpressionStorageKey(phrase)] || progress[getExpressionLegacyKey(phrase)] || progress[text.language + '::' + phrase] || progress[phrase] || {};
    const practiceCount = Number.isFinite(entry.practiceCount) ? entry.practiceCount : 0;
    return {
      practiceCount,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : null,
    };
  }

  function getPracticeLevel(count) {
    if (count >= 5) {
      return '3';
    }
    if (count >= 3) {
      return '2';
    }
    if (count >= 1) {
      return '1';
    }
    return '0';
  }

  function getPracticeLabel(count, labels) {
    if (count <= 0) {
      return labels.expressionNotPracticed;
    }
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function getTranslationTitle(lang, labels) {
    if (lang === 'ja') {
      return labels.japaneseTranslation;
    }
    if (lang === 'no') {
      return labels.norwegianTranslation;
    }
    return labels.englishTranslation;
  }

  function getTranslationPracticeButtonLabel(lang, labels) {
    if (lang === 'ja') {
      return labels.typeThisInJapanese;
    }
    if (lang === 'no') {
      return labels.typeThisInNorwegian;
    }
    return labels.typeThisInEnglish;
  }

  function getTranslationPracticeLabel(lang, labels) {
    return labels.translationPracticePrefix + (languageNames[lang]?.[uiLanguageSelect.value] || lang);
  }

  function getSpeedMetricLabel(labels) {
    return activeTypingTargetLanguage === 'ja' ? labels.cpm : labels.wpm;
  }

  function getExplanationLanguageOrder(lang) {
    return [lang, ...uiLanguages.filter((item) => item !== lang)];
  }

  function escapeHtmlClient(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getLocalizedExplanations(data, lang) {
    const order = getExplanationLanguageOrder(lang);
    return order
      .map((language) => ({ language, value: data[language] }))
      .filter((entry) => typeof entry.value === 'string' && entry.value.trim());
  }

  function renderLocalizedExplanations(lang) {
    document.querySelectorAll('[data-explanation-map]').forEach((container) => {
      let data = {};
      try {
        data = JSON.parse(container.dataset.explanationMap || '{}');
      } catch {
        data = {};
      }
      container.innerHTML = getLocalizedExplanations(data, lang).map((entry) => {
        const label = languageNames[entry.language]?.[lang] || entry.language;
        return '<div class="localized-explanation"><span class="grammar-language-label">' + escapeHtmlClient(label) + ':</span><p>' + escapeHtmlClient(entry.value) + '</p></div>';
      }).join('');
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const statusButtons = document.querySelectorAll('[data-expression-status]');
    const expressionCards = document.querySelectorAll('[data-expression-card]');
    const input = document.getElementById('typing-input');
    const progressValue = document.getElementById('progress-value');
    const accuracyValue = document.getElementById('accuracy-value');
    const wpmValue = document.getElementById('wpm-value');
    const completionPanel = document.getElementById('completion-panel');
    const expressionsPanel = document.getElementById('expressions-panel');
    const grammarPanel = document.getElementById('grammar-panel');
    const learningFocusCard = document.getElementById('learning-focus-card');
    const translationPracticeInfo = document.getElementById('translation-practice-info');
    const translationPracticeChip = document.getElementById('translation-practice-chip');
    const translationPracticeNote = document.getElementById('translation-practice-note');
    const originalTextTitle = document.getElementById('original-text-title');
    const targetText = document.getElementById('target-text');
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const languageChip = document.getElementById('language-chip');
    const categoryChip = document.getElementById('category-chip');
    const levelChip = document.getElementById('level-chip');
    const readHeading = document.getElementById('read-heading');
    const readDescription = document.getElementById('read-description');
    const typingHeading = document.getElementById('typing-heading');
    const progressTitle = document.getElementById('progress-title');
    const accuracyTitle = document.getElementById('accuracy-title');
    const wpmTitle = document.getElementById('wpm-title');
    const expressionsTitle = document.getElementById('expressions-title');
    const grammarTitle = document.getElementById('grammar-title');
    let targetCharacters = document.querySelectorAll('[data-char-index]');
    const textContent = document.querySelector('.text-content');
    const expressionHighlights = document.querySelectorAll('[data-expression-phrase]');
    const expressionMiniCard = document.getElementById('expression-mini-card');
    const miniCardPhrase = document.getElementById('mini-card-phrase');
    const miniCardMeaning = document.getElementById('mini-card-meaning');
    const miniCardFallback = document.getElementById('mini-card-fallback');
    const miniCardDetails = document.getElementById('mini-card-details');
    let activeMiniCardPhrase = null;

    function renderClientCharacter(value, index) {
      return '<span class="target-char" data-char-index="' + index + '">' + escapeHtmlClient(value) + '</span>';
    }

    function renderClientCharacters(value, startIndex) {
      return Array.from(value).map((char, offset) => renderClientCharacter(char, startIndex + offset)).join('');
    }

    function renderClientProgressParagraph(paragraph, paragraphStartIndex) {
      let index = paragraphStartIndex;
      return paragraph.split(/(\\s+)/).map((part) => {
        const startIndex = index;
        index += part.length;
        if (!part) {
          return '';
        }
        if (/^\\s+$/.test(part)) {
          return '<span class="target-space">' + renderClientCharacters(part, startIndex) + '</span>';
        }
        return '<span class="target-word">' + renderClientCharacters(part, startIndex) + '</span>';
      }).join('');
    }

    function renderClientProgressText(value) {
      let index = 0;
      return value.split('\\n\\n').map((paragraph) => {
        const rendered = renderClientProgressParagraph(paragraph, index);
        index += paragraph.length + 2;
        return '<p>' + rendered + '</p>';
      }).join('');
    }

    function applyPracticeModePresentation() {
      if (!activeIsTranslationPractice) {
        if (translationPracticeChip) {
          translationPracticeChip.hidden = true;
        }
        return;
      }

      if (targetText) {
        targetText.innerHTML = renderClientProgressText(activeTypingTarget);
        targetCharacters = document.querySelectorAll('[data-char-index]');
      }
      if (textContent) {
        textContent.dataset.targetLanguage = activePracticeTranslationLang;
        textContent.dataset.practiceMode = 'translation';
      }
      if (learningFocusCard) {
        learningFocusCard.hidden = true;
      }
      if (translationPracticeInfo) {
        translationPracticeInfo.hidden = false;
      }
      if (translationPracticeChip) {
        translationPracticeChip.hidden = false;
      }
    }

    function updateExpressionStatusButtons() {
      const labels = getUiText(uiLanguageSelect.value);
      statusButtons.forEach((button) => {
        const phrase = button.dataset.expressionStatus;
        const status = getExpressionStatus(phrase);
        const label = getExpressionStatusLabel(status, labels);
        const card = button.closest('[data-expression-card]');
        button.dataset.status = status;
        button.textContent = label;
        button.title = labels.expressionStatusAction;
        button.setAttribute('aria-label', phrase + ': ' + label + '. ' + labels.expressionStatusAction);
        if (card) {
          card.dataset.status = status;
          card.title = labels.expressionStatusAction;
        }
      });
    }

    function updateExpressionPracticeLabels() {
      const labels = getUiText(uiLanguageSelect.value);
      expressionCards.forEach((card) => {
        const phrase = card.dataset.expressionCard;
        const status = getExpressionStatus(phrase);
        const { practiceCount } = getExpressionPractice(phrase);
        const practiceLabel = card.querySelector('[data-expression-practice]');
        const highRepetitionLabel = card.querySelector('[data-high-repetition-label]');
        card.dataset.practiceLevel = getPracticeLevel(practiceCount);
        card.dataset.highRepetition = status === 'review' && practiceCount >= 10 ? 'true' : 'false';
        if (practiceLabel) {
          practiceLabel.textContent = getPracticeLabel(practiceCount, labels);
        }
        if (highRepetitionLabel) {
          highRepetitionLabel.textContent = labels.highRepetition;
        }
      });
    }

    function recordCompletion(accuracy, wpm) {
      const now = new Date().toISOString();
      const textProgress = loadProgress(TEXT_PROGRESS_KEY);
      const existingTextProgress = textProgress[text.id] || {};
      textProgress[text.id] = {
        completedCount: (existingTextProgress.completedCount || 0) + 1,
        bestAccuracy: Math.max(existingTextProgress.bestAccuracy || 0, accuracy),
        bestWpm: Math.max(existingTextProgress.bestWpm || 0, wpm),
        lastPracticedAt: now,
      };
      saveProgress(TEXT_PROGRESS_KEY, textProgress);

      const expressionProgress = loadProgress(EXPRESSION_PROGRESS_KEY);
      const phrases = Array.from(new Set(text.expressions.map((expression) => expression.phrase)));
      phrases.forEach((phrase) => {
        const expressionKey = getExpressionStorageKey(phrase);
        const existingExpressionProgress = expressionProgress[expressionKey] || expressionProgress[phrase] || {};
        expressionProgress[expressionKey] = {
          practiceCount: (existingExpressionProgress.practiceCount || 0) + 1,
          lastPracticedAt: now,
        };
      });
      saveProgress(EXPRESSION_PROGRESS_KEY, expressionProgress);
      updateExpressionPracticeLabels();
    }

    function cycleExpressionStatus(phrase) {
      const all = loadExpressionStatuses();
      all[getExpressionStorageKey(phrase)] = getNextExpressionStatus(getExpressionStatus(phrase));
      saveExpressionStatuses(all);
      updateExpressionStatusButtons();
    }

  function getExpressionExplanationMap(expression) {
    return {
      ja: typeof expression.ja === 'string' ? expression.ja : typeof expression.descriptionJa === 'string' ? expression.descriptionJa : '',
      en: typeof expression.en === 'string' ? expression.en : typeof expression.descriptionEn === 'string' ? expression.descriptionEn : '',
      no: typeof expression.no === 'string' ? expression.no : typeof expression.descriptionNo === 'string' ? expression.descriptionNo : '',
    };
  }

  function getExpressionExampleMap(expression) {
    return {
      default: typeof expression.example === 'string' ? expression.example : '',
      ja: typeof expression.exampleJa === 'string' ? expression.exampleJa : '',
      en: typeof expression.exampleEn === 'string' ? expression.exampleEn : '',
      no: typeof expression.exampleNo === 'string' ? expression.exampleNo : '',
    };
  }

  function getLocalizedExamples(data) {
    const order = ['default', ...uiLanguages.filter((item) => item !== text.language)];
    return order
      .map((language) => ({ language, value: data[language] }))
      .filter((entry, index, array) => typeof entry.value === 'string' && entry.value.trim() && array.findIndex((item) => item.value === entry.value) === index);
  }

  function renderLocalizedExamples(lang) {
    document.querySelectorAll('[data-example-map]').forEach((container) => {
      let data = {};
      try {
        data = JSON.parse(container.dataset.exampleMap || '{}');
      } catch {
        data = {};
      }
      const examples = getLocalizedExamples(data);
      const labels = getUiText(lang);
      container.innerHTML = examples.length
        ? '<span class="expression-example-label">' + escapeHtmlClient(labels.expressionExample) + '</span>' + examples.map((entry) => {
          const label = entry.language === 'default' ? '' : '<span class="grammar-language-label">' + escapeHtmlClient(languageNames[entry.language]?.[lang] || entry.language) + ':</span> ';
          return '<p>' + label + escapeHtmlClient(entry.value) + '</p>';
        }).join('')
        : '';
      container.hidden = !examples.length;
    });
  }

    function closeExpressionMiniCard() {
      activeMiniCardPhrase = null;
      if (expressionMiniCard) {
        expressionMiniCard.hidden = true;
      }
    }

    function updateExpressionMiniCardText() {
      if (!activeMiniCardPhrase || !expressionMiniCard || expressionMiniCard.hidden) {
        return;
      }
      const labels = getUiText(uiLanguageSelect.value);
      const expression = getExpressionByPhrase(activeMiniCardPhrase);
      if (!expression) {
        closeExpressionMiniCard();
        return;
      }
      const explanations = getLocalizedExplanations(getExpressionExplanationMap(expression), uiLanguageSelect.value);
      const primary = explanations[0];
      const fallback = explanations.find((entry) => entry.language !== primary?.language);
      miniCardPhrase.textContent = expression.phrase;
      miniCardMeaning.textContent = primary?.value || '';
      miniCardFallback.textContent = fallback ? fallback.value : '';
      miniCardFallback.hidden = !fallback;
      miniCardDetails.textContent = labels.expressionDetails;
    }

    function positionExpressionMiniCard(event) {
      if (!expressionMiniCard || !textContent) {
        return;
      }
      const containerRect = textContent.getBoundingClientRect();
      const cardRect = expressionMiniCard.getBoundingClientRect();
      const left = Math.max(12, Math.min(event.clientX - containerRect.left, containerRect.width - cardRect.width - 12));
      const top = Math.max(12, event.clientY - containerRect.top + 22);
      expressionMiniCard.style.left = left + 'px';
      expressionMiniCard.style.top = top + 'px';
    }

    function showExpressionMiniCard(phrase, event) {
      if (!expressionMiniCard) {
        return;
      }
      activeMiniCardPhrase = phrase;
      expressionMiniCard.hidden = false;
      updateExpressionMiniCardText();
      requestAnimationFrame(() => positionExpressionMiniCard(event));
    }

    function focusFullExpressionCard(phrase) {
      const card = Array.from(expressionCards).find((item) => item.dataset.expressionCard === phrase);
      if (!card) {
        return;
      }
      expressionsPanel.hidden = false;
      card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      card.classList.add('expression-card-focus');
      window.setTimeout(() => {
        card.classList.remove('expression-card-focus');
      }, 2400);
    }

    function renderUiText(lang) {
      const labels = getUiText(lang);
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n;
        const value = labels[key];
        if (typeof value === 'string') {
          el.textContent = value;
        }
      });

      uiLanguageSelect.value = lang;
      readHeading.textContent = labels.readTypeUnderstand;
      readDescription.textContent = labels.focusNaturalMeaning;
      typingHeading.textContent = activeIsTranslationPractice && activePracticeTranslationLang
        ? getTranslationPracticeLabel(activePracticeTranslationLang, labels)
        : labels.typingPractice;
      input.placeholder = labels.typingPlaceholder;
      progressTitle.textContent = labels.progress;
      accuracyTitle.textContent = labels.accuracy;
      wpmTitle.textContent = getSpeedMetricLabel(labels);
      document.querySelectorAll('[data-translation-title]').forEach((el) => {
        el.textContent = getTranslationTitle(el.dataset.translationTitle, labels);
      });
      document.querySelectorAll('[data-translation-practice-button]').forEach((el) => {
        el.textContent = getTranslationPracticeButtonLabel(el.dataset.translationPracticeButton, labels);
      });
      if (translationPracticeChip && activePracticeTranslationLang) {
        translationPracticeChip.textContent = getTranslationPracticeLabel(activePracticeTranslationLang, labels);
      }
      if (translationPracticeNote) {
        translationPracticeNote.textContent = labels.translationPracticeNoCards;
      }
      if (originalTextTitle) {
        originalTextTitle.textContent = labels.originalText;
      }
      if (expressionsTitle) {
        expressionsTitle.textContent = labels.usefulExpressions;
      }
      if (grammarTitle) {
        grammarTitle.textContent = labels.grammarFromText;
      }
      document.querySelectorAll('[data-expression-form-label]').forEach((el) => {
        el.textContent = labels.expressionTextForm;
      });
      if (miniCardDetails) {
        miniCardDetails.textContent = labels.expressionDetails;
      }
      languageChip.textContent = languageNames[text.language]?.[lang] || text.language;
      categoryChip.textContent = categoryLabels[text.category]?.[lang] || text.category;
      levelChip.textContent = labels.levelLabel + ': ' + (levelLabels[normalizeLevelKey(text.level)]?.[lang] || text.level);
      updateExpressionStatusButtons();
      updateExpressionPracticeLabels();
      renderLocalizedExplanations(lang);
      renderLocalizedExamples(lang);
      updateExpressionMiniCardText();
    }

    function updateTargetTextProgress(typed) {
      targetCharacters.forEach((char) => {
        const index = Number(char.dataset.charIndex);
        char.classList.remove('correct', 'incorrect', 'current');
        if (!Number.isFinite(index)) {
          return;
        }
        if (index < typed.length) {
          char.classList.add(typed[index] === activeTypingTarget[index] ? 'correct' : 'incorrect');
        } else if (index === typed.length && typed.length < activeTypingTarget.length) {
          char.classList.add('current');
        }
      });
    }

    function updateMetrics() {
      const target = activeTypingTarget;
      const typed = input.value;
      let correct = 0;
      for (let i = 0; i < typed.length; i += 1) {
        if (typed[i] === target[i]) {
          correct += 1;
        }
      }
      const progress = Math.min(100, Math.round((correct / target.length) * 100));
      const accuracy = typed.length ? Math.round((correct / typed.length) * 100) : 100;
      const elapsedMinutes = startTime ? Math.max((performance.now() - startTime) / 60000, 0.001) : 0;
      let speed = 0;
      if (startTime && elapsedMinutes > 0) {
        if (activeTypingTargetLanguage === 'ja') {
          speed = Math.round(correct / elapsedMinutes);
        } else {
          const words = typed.trim().split(/\\s+/).filter(Boolean).length;
          const rawWpm = Math.round(words / elapsedMinutes);
          speed = Math.min(rawWpm, 200);
        }
      }
      progressValue.textContent = progress + '%';
      accuracyValue.textContent = accuracy + '%';
      wpmValue.textContent = '' + speed;
      updateTargetTextProgress(typed);
      if (typed === target) {
        if (!activeIsTranslationPractice) {
          completionPanel.hidden = false;
          expressionsPanel.hidden = false;
          grammarPanel.hidden = false;
        }
        if (!activeIsTranslationPractice && !hasRecordedCompletion) {
          hasRecordedCompletion = true;
          recordCompletion(accuracy, speed);
        }
      }
    }

    let startTime = null;
    let hasRecordedCompletion = false;
    let isComposing = false;

    input.addEventListener('input', (event) => {
      if (event.isComposing || isComposing) {
        return;
      }
      if (!startTime) {
        startTime = performance.now();
      }
      updateMetrics();
    });

    input.addEventListener('compositionstart', () => {
      isComposing = true;
    });

    input.addEventListener('compositionend', () => {
      isComposing = false;
      if (!startTime) {
        startTime = performance.now();
      }
      updateMetrics();
    });

    statusButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        cycleExpressionStatus(button.dataset.expressionStatus);
      });
    });

    expressionCards.forEach((card) => {
      card.addEventListener('click', () => {
        const selectedText = window.getSelection()?.toString();
        if (selectedText) {
          return;
        }
        cycleExpressionStatus(card.dataset.expressionCard);
      });
    });

    expressionHighlights.forEach((highlight) => {
      highlight.addEventListener('click', (event) => {
        event.stopPropagation();
        const phrase = highlight.dataset.expressionPhrase;
        if (phrase) {
          showExpressionMiniCard(phrase, event);
        }
      });
    });

    if (miniCardDetails) {
      miniCardDetails.addEventListener('click', (event) => {
        event.stopPropagation();
        if (activeMiniCardPhrase) {
          focusFullExpressionCard(activeMiniCardPhrase);
          closeExpressionMiniCard();
        }
      });
    }

    if (expressionMiniCard) {
      expressionMiniCard.addEventListener('click', (event) => {
        event.stopPropagation();
      });
    }

    document.addEventListener('click', () => {
      closeExpressionMiniCard();
    });

    applyPracticeModePresentation();
    const savedUiLanguage = getSavedUiLanguage();
    renderUiText(savedUiLanguage);
    updateExpressionStatusButtons();
    updateExpressionPracticeLabels();
    updateTargetTextProgress(input.value);

    uiLanguageSelect.addEventListener('change', (event) => {
      const lang = event.target.value;
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      renderUiText(lang);
    });
  });
`;

if (!text) {
  throw new Error('Text not found');
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{text.title} · Read & Type</title>
  </head>
  <body>
    <main class="page-shell text-page">
      <section class="hero-card page-top">
        <div>
          <h1 class="text-title">{text.title}</h1>
          <div class="meta-strip">
            <span class="meta-chip" id="language-chip">{languageNames[text.language as keyof typeof languageNames][defaultUiLang]}</span>
            <span class="meta-chip" id="category-chip">{categoryLabels[text.category as keyof typeof categoryLabels][defaultUiLang]}</span>
            <span class="meta-chip" id="level-chip">{uiText[defaultUiLang].levelLabel}: {levelLabels[normalizeLevelKey(text.level)][defaultUiLang]}</span>
            <span class="meta-chip" id="translation-practice-chip" hidden={!isTranslationPractice}>
              {practiceTranslationLang
                ? `${uiText[defaultUiLang].translationPracticePrefix}${languageNames[practiceTranslationLang][defaultUiLang]}`
                : uiText[defaultUiLang].translationPracticePrefix}
            </span>
          </div>
        </div>
        <div class="top-actions">
          <a class="nav-link" href="/review" data-i18n="reviewPageTitle">{uiText[defaultUiLang].reviewPageTitle}</a>
          <div class="language-switcher">
            <label for="ui-language-select" data-i18n="language">{uiText[defaultUiLang].language}</label>
            <select id="ui-language-select">
              {uiLanguages.map((lang) => (
                <option value={lang}>{uiLanguageNames[lang]}</option>
              ))}
            </select>
          </div>
        </div>
      </section>

      <section class="note-card">
        <h3 id="read-heading" data-i18n="readTypeUnderstand">{uiText[defaultUiLang].readTypeUnderstand}</h3>
        <p id="read-description" data-i18n="focusNaturalMeaning">{uiText[defaultUiLang].focusNaturalMeaning}</p>
      </section>

      <section class="learning-focus-card translation-practice-info-card" id="translation-practice-info" hidden={!isTranslationPractice}>
        <h3 id="original-text-title">{uiText[defaultUiLang].originalText}</h3>
        <p class="translation-practice-original">{text.text}</p>
        <p class="translation-practice-note" id="translation-practice-note">{uiText[defaultUiLang].translationPracticeNoCards}</p>
      </section>

      <section class="learning-focus-card" id="learning-focus-card" hidden={isTranslationPractice}>
        <h3>Learning Focus</h3>
        <div class="learning-focus-row">
          <div>
            <strong>Expressions</strong>
            <ul>
              {learningFocusExpressions.map((phrase) => (
                <li>{phrase}</li>
              ))}
            </ul>
          </div>
          <div>
            <strong>Grammar</strong>
            <ul>
              {learningFocusGrammar.map((title) => (
                <li>{title}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="text-content" data-target-language={practiceTranslationLang ?? text.language} data-practice-mode={isTranslationPractice ? 'translation' : 'text'}>
        <div id="target-text" set:html={highlightedTextHtml}></div>
        <aside class="expression-mini-card" id="expression-mini-card" hidden>
          <strong id="mini-card-phrase"></strong>
          <p id="mini-card-meaning"></p>
          <p class="mini-card-fallback" id="mini-card-fallback"></p>
          <button class="mini-card-details" id="mini-card-details" type="button">{uiText[defaultUiLang].expressionDetails}</button>
        </aside>
      </section>

      <section class="note-card">
        <h3 id="typing-heading" data-i18n="typingPractice">
          {practiceTranslationLang
            ? `${uiText[defaultUiLang].translationPracticePrefix}${languageNames[practiceTranslationLang][defaultUiLang]}`
            : uiText[defaultUiLang].typingPractice}
        </h3>
        <textarea id="typing-input" class="type-area" placeholder={uiText[defaultUiLang].typingPlaceholder} spellcheck="false"></textarea>
        <div class="stat-grid">
          <div class="stat-card"><strong id="progress-title" data-i18n="progress">{uiText[defaultUiLang].progress}</strong><p id="progress-value">0%</p></div>
          <div class="stat-card"><strong id="accuracy-title" data-i18n="accuracy">{uiText[defaultUiLang].accuracy}</strong><p id="accuracy-value">100%</p></div>
          <div class="stat-card"><strong id="wpm-title" data-i18n="wpm">{uiText[defaultUiLang].wpm}</strong><p id="wpm-value">0</p></div>
        </div>
      </section>

      <section class="translation-card" id="completion-panel" hidden>
        {translationsToShow.map((translation) => (
          <div>
            <h3 data-translation-title={translation.lang}>
              {translation.lang === 'ja'
                ? uiText[defaultUiLang].japaneseTranslation
                : translation.lang === 'no'
                  ? uiText[defaultUiLang].norwegianTranslation
                  : uiText[defaultUiLang].englishTranslation}
            </h3>
            <p>{translation.value}</p>
            <a
              class="translation-practice-link"
              href={`${translationPracticeHrefBase}?practiceTranslation=${translation.lang}`}
              data-translation-practice-button={translation.lang}
            >
              {getTranslationPracticeButtonLabel(translation.lang, uiText[defaultUiLang])}
            </a>
          </div>
        ))}
      </section>

      <section class="expressions-card" id="expressions-panel" hidden>
        <h3 id="expressions-title" data-i18n="usefulExpressions">{uiText[defaultUiLang].usefulExpressions}</h3>
        <div class="expressions-grid">
          {text.expressions.map((item) => (
            <article class="expression-card" data-expression-card={item.phrase}>
              <div class="expression-header">
                <strong>{item.phrase}</strong>
                <button class="status-button" type="button" data-expression-status={item.phrase}>{uiText[defaultUiLang].expressionStatusNew}</button>
              </div>
              {item.formInText && item.formInText !== item.phrase && (
                <p class="expression-text-form"><span data-expression-form-label>{uiText[defaultUiLang].expressionTextForm}</span>: {item.formInText}</p>
              )}
              <p class="expression-practice"><span data-expression-practice>{uiText[defaultUiLang].expressionNotPracticed}</span><span class="high-repetition-label" data-high-repetition-label>{uiText[defaultUiLang].highRepetition}</span></p>
              <div class="explanation-list" data-explanation-map={JSON.stringify(getExplanationMap(item))}>
                {getOrderedExplanations(item, defaultUiLang).map((entry) => (
                  <div class="localized-explanation">
                    <span class="grammar-language-label">{languageNames[entry.lang][defaultUiLang]}:</span>
                    <p>{entry.value}</p>
                  </div>
                ))}
              </div>
              {hasExample(item) && (
                <div class="expression-example-list" data-example-map={JSON.stringify(getExampleMap(item))}>
                  <span class="expression-example-label">{uiText[defaultUiLang].expressionExample}</span>
                  {getOrderedExamples(item, defaultUiLang, text.language as UILang).map((entry) => (
                    <p>
                      {entry.lang !== 'default' && <span class="grammar-language-label">{languageNames[entry.lang as UILang][defaultUiLang]}: </span>}
                      {entry.value}
                    </p>
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>

      <section class="grammar-card" id="grammar-panel" hidden>
        <h3 id="grammar-title" data-i18n="grammarFromText">{uiText[defaultUiLang].grammarFromText}</h3>
        <div class="grammar-grid">
          {text.grammar.map((item) => (
            <article class="grammar-card-item">
              <strong>{item.title}</strong>
              <div class="explanation-list" data-explanation-map={JSON.stringify(getExplanationMap(item))}>
                {getOrderedExplanations(item, defaultUiLang).map((entry) => (
                  <div class="localized-explanation">
                    <span class="grammar-language-label">{languageNames[entry.lang][defaultUiLang]}:</span>
                    <p>{entry.value}</p>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <script type="module" set:html={clientScript}></script>
  </body>
</html>
