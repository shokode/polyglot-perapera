            <h3 id="completion-title" data-i18n="completionMessage">
              {uiText[defaultUiLang].completionMessage}
            </h3>
            <div class="completion-stat-grid">
              <div class="completion-stat">
                <strong id="completion-accuracy-title"
                  >{uiText[defaultUiLang].accuracy}</strong
                >
                <p id="completion-accuracy-value">100%</p>
              </div>
              <div class="completion-stat">
                <strong id="completion-speed-title"
                  >{
                    typingTargetLanguage === "ja"
                      ? uiText[defaultUiLang].cpm
                      : uiText[defaultUiLang].wpm
                  }</strong
                >
                <p id="completion-speed-value">0</p>
              </div>
              <div class="completion-stat">
                <strong id="completion-mistakes-title"
                  >{uiText[defaultUiLang].mistakes}</strong
                >
                <p id="completion-mistakes-value">0</p>
              </div>
            </div>
            <p
              class="completion-note"
              id="completion-status-note"
              hidden
            >
            </p>
            <div
              class="completion-modal__assessment self-assessment-panel"
              id="self-assessment-panel"
              hidden
            >
              <strong id="self-assessment-prompt"
                >{uiText[defaultUiLang].selfAssessmentPrompt}</strong
              >
              <div class="assessment-actions" id="self-assessment-actions">
                <button
                  class="secondary-button"
                  type="button"
                  data-assessment-level="perfect"
                  >{uiText[defaultUiLang].assessmentPerfect}</button
                >
                <button
                  class="secondary-button"
                  type="button"
                  data-assessment-level="good"
                  >{uiText[defaultUiLang].assessmentMostly}</button
                >
                <button
                  class="secondary-button"
                  type="button"
                  data-assessment-level="shaky"
                  >{uiText[defaultUiLang].assessmentUnsure}</button
                >
                <button
                  class="secondary-button"
                  type="button"
                  data-assessment-level="again"
                  >{uiText[defaultUiLang].assessmentAgain}</button
                >
              </div>
              <p
                class="completion-note"
                id="self-assessment-feedback"
                data-saved="false"
                hidden
              >
              </p>
            </div>
          </div>
        </div>
      </section>

      <section
        class="translation-card completion-translations-card"
        id="translations-section"
        hidden
      >
        {
          translationsToShow.map((translation) => (
            <div>
              <h3 data-translation-title={translation.lang}>
                <span
                  class={getLanguageBadgeClass(translation.lang)}
                  data-target-language={translation.lang}
                  title={languageNames[translation.lang][defaultUiLang]}
                  aria-label={languageNames[translation.lang][defaultUiLang]}
                >
                  {targetLanguageBadges[translation.lang]}
                </span>
              </h3>
              <p>{translation.value}</p>
              <div class="translation-practice-actions">
                <a
                  class="translation-practice-link"
                  href={`${translationPracticeHrefBase}?practiceTranslation=${translation.lang}`}
                  data-translation-practice-button={translation.lang}
                >
                  {getTranslationPracticeButtonLabel(
                    translation.lang,
                    uiText[defaultUiLang],
                  )}
                </a>
                <button
                  class="pin-button translation-practice-pin"
                  type="button"
                  data-translation-practice-pin={translation.lang}
                  aria-label={uiText[defaultUiLang].pinText}
                  title={uiText[defaultUiLang].pinText}
                  aria-pressed="false"
                >
                  ☆
                </button>
              </div>
            </div>
          ))
        }
      </section>

      <div id="learning-section">
        <section class="expressions-card" id="expressions-panel" hidden>
          <h3 id="expressions-title" data-i18n="usefulExpressions">
            {uiText[defaultUiLang].usefulExpressions}
          </h3>
          <div class="expressions-grid">
            {
              text.expressions.map((item) => (
                <article
                  class="expression-card"
                  data-expression-card={item.phrase}
                >
                  <div class="expression-header">
                    <strong>{item.phrase}</strong>
                    <div class="expression-header-actions">
                      <button
                        class="status-button"
                        type="button"
                        data-expression-status={item.phrase}
                      >
                        {uiText[defaultUiLang].expressionStatusNew}
                      </button>
                    </div>
                  </div>
                  {item.formInText && item.formInText !== item.phrase && (
                    <p class="expression-text-form">
                      <span data-expression-form-label>
                        {uiText[defaultUiLang].expressionTextForm}
                      </span>
                      : {item.formInText}
                    </p>
                  )}
                  <p class="expression-practice">
                    <>
                      <span data-expression-practice>
                        {uiText[defaultUiLang].expressionNotPracticed}
                      </span>
                      <span
                        class="high-repetition-label"
                        data-high-repetition-label
                      >
                        {uiText[defaultUiLang].highRepetition}
                      </span>
                    </>
                  </p>
                  <div
                    class="explanation-list"
                    data-explanation-map={JSON.stringify(
                      getExplanationMap(item),
                    )}
                  >
                    {getOrderedExplanations(item, defaultUiLang).map(
                      (entry) => (
                        <div class="localized-explanation">
                          <span
                            class={getLanguageBadgeClass(entry.lang as UILang)}
                            data-target-language={entry.lang}
                            title={
                              languageNames[entry.lang as UILang][defaultUiLang]
                            }
                            aria-label={
                              languageNames[entry.lang as UILang][defaultUiLang]
                            }
                          >
                            {targetLanguageBadges[entry.lang as UILang]}
                          </span>
                          <p>{entry.value}</p>
                        </div>
                      ),
                    )}
                  </div>
                  {hasExample(item) && (
                    <div
                      class="expression-example-list"
                      data-example-map={JSON.stringify(getExampleMap(item))}
                    >
                      <span class="expression-example-label">
                        {uiText[defaultUiLang].expressionExample}
                      </span>
                      {getOrderedExamples(
                        item,
                        defaultUiLang,
                        text.language as UILang,
                      ).map((entry) => (
                        <p>
                          {entry.lang !== "default" && (
                            <span
                              class={getLanguageBadgeClass(
                                entry.lang as UILang,
                              )}
                              data-target-language={entry.lang}
                              title={
                                languageNames[entry.lang as UILang][
                                  defaultUiLang
                                ]
                              }
                              aria-label={
                                languageNames[entry.lang as UILang][
                                  defaultUiLang
                                ]
                              }
                            >
                              {targetLanguageBadges[entry.lang as UILang]}
                            </span>
                          )}
                          {entry.lang !== "default" && " "}
                          {entry.value}
                        </p>
                      ))}
                    </div>
                  )}
                </article>
              ))
            }
          </div>
        </section>

        <section class="grammar-card" id="grammar-panel" hidden>
          <h3 id="grammar-title" data-i18n="grammarFromText">
            {uiText[defaultUiLang].grammarFromText}
          </h3>
          <div class="grammar-grid">
            {
              text.grammar.map((item) => (
                <article class="grammar-card-item">
                  <strong>{item.title}</strong>
                  <div
                    class="explanation-list"
                    data-explanation-map={JSON.stringify(
                      getExplanationMap(item),
                    )}
                  >
                    {getOrderedExplanations(item, defaultUiLang).map(
                      (entry) => (
                        <div class="localized-explanation">
                          <span
                            class={getLanguageBadgeClass(entry.lang as UILang)}
                            data-target-language={entry.lang}
                            title={
                              languageNames[entry.lang as UILang][defaultUiLang]
                            }
                            aria-label={
                              languageNames[entry.lang as UILang][defaultUiLang]
                            }
                          >
                            {targetLanguageBadges[entry.lang as UILang]}
                          </span>
                          <p>{entry.value}</p>
                        </div>
                      ),
                    )}
                  </div>
                </article>
              ))
            }
          </div>
        </section>
      </div>

      <section
        class="post-completion-actions post-completion-actions--bottom"
        data-post-completion-actions
        hidden
      >
        <button
          class="secondary-button"
          type="button"
          data-post-completion-practice-again
          >{uiText[defaultUiLang].practiceAgain}</button
        >
        <button class="primary-button" type="button" data-post-completion-next
          >{uiText[defaultUiLang].nextRecommended}</button
        >
        <button class="secondary-button" type="button" data-post-completion-home
          >{uiText[defaultUiLang].backHome}</button
        >
      </section>
    </main>

    <script type="module" set:html={clientScript} />
  </body>
</html>
