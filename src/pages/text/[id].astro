    }

    function getCorrectPrefix(value) {
      let prefix = '';
      for (let index = 0; index < value.length && index < activeTypingTarget.length; index += 1) {
        if (!typingCharactersMatch(value[index], activeTypingTarget[index])) {
          break;
        }
        prefix += value[index];
      }
      return prefix;
    }

    function saveTypingMode(mode) {
      currentTypingMode = mode === 'flow' ? 'flow' : 'strict';
      try {
        localStorage.setItem(TYPING_MODE_KEY, currentTypingMode);
      } catch {
        // Keep the in-memory mode even if storage is unavailable.
      }
      if (currentTypingMode === 'flow') {
        flowAcceptedValue = getCorrectPrefix(input.value);
        input.value = flowAcceptedValue;
        flowMistakes = 0;
      }
      updateTypingModeControls();
      updateMetrics();
    }

    function renderClientCharacter(value, index) {
      return '<span class="target-char" data-char-index="' + index + '">' + escapeHtmlClient(value) + '</span>';
    }

    function renderClientCharacters(value, startIndex) {
      return Array.from(value).map((char, offset) => renderClientCharacter(char, startIndex + offset)).join('');
    }

    function renderClientProgressParagraph(paragraph, paragraphStartIndex) {
      let index = paragraphStartIndex;
      return paragraph.split(/(\\s+)/).map((part) => {
        const startIndex = index;
        index += part.length;
        if (!part) {
          return '';
        }
        if (/^\\s+$/.test(part)) {
          return '<span class="target-space">' + renderClientCharacters(part, startIndex) + '</span>';
        }
        return '<span class="target-word">' + renderClientCharacters(part, startIndex) + '</span>';
      }).join('');
    }

    function renderClientProgressText(value) {
      let index = 0;
      return value.split('\\n\\n').map((paragraph) => {
        const rendered = renderClientProgressParagraph(paragraph, index);
        index += paragraph.length + 2;
        return '<p>' + rendered + '</p>';
      }).join('');
    }

    function setMarkerHoverState(markerId, isHovered) {
      document.querySelectorAll('[data-marker-id]').forEach((marker) => {
