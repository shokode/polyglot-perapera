---
import "../styles/global.scss";
import SiteHeader from "../components/SiteHeader.astro";
import texts from "../data/texts.json" assert { type: "json" };
import {
    categories as categoryKeys,
    levels as levelKeys,
    uiLanguages,
    uiText,
    categoryLabels,
    levelLabels,
    languageNames,
    type UILang,
} from "../i18n/ui";

const defaultUiLang: UILang = "en";
const appBasePath = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
const appHref = (path: string) => `${appBasePath}${path.replace(/^\//, "")}`;
const clientScript = `
  const BASE_PATH = ${JSON.stringify(import.meta.env.BASE_URL)};
  const texts = ${JSON.stringify(texts)};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const categoryLabels = ${JSON.stringify(categoryLabels)};
  const levelLabels = ${JSON.stringify(levelLabels)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = {
    no: 'NO',
    en: 'EN',
    ja: 'JA',
  };
  const targetLanguageOptionLabels = {
    no: 'Norsk',
    en: 'English',
    ja: '日本語',
  };
  const levelKeys = ${JSON.stringify(levelKeys)};
  const levelSortRank = {
    a1: 0,
    a2: 1,
    b1: 2,
    b2: 3,
    c1: 4,
    natural: 5,
  };
  const legacyLevelMap = {
    basic: 'a1',
    useful: 'a2',
    daily: 'b1',
    advanced: 'b2',
    natural: 'natural',
  };
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const TARGET_LANGUAGE_STORAGE_KEY = 'typingSiteTargetLanguage';
  const TEXT_PROGRESS_KEY = 'typingProgress';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';
  const SELF_ASSESSMENT_KEY = 'typingSelfAssessment';
  const PINNED_TEXTS_KEY = 'typingPinnedTexts';
  const PINNED_PRACTICE_TARGETS_KEY = 'typingPinnedPracticeTargets';

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function getAppHref(path) {
    const base = BASE_PATH || '/';
    const normalizedBase = base.endsWith('/') ? base : base + '/';
    const normalizedPath = String(path).replace(/^\\//, '');
    return normalizedBase + normalizedPath;
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return uiLanguages.includes(stored) ? stored : 'en';
  }

  function getSavedTargetLanguage() {
    const stored = safeReadStorage(TARGET_LANGUAGE_STORAGE_KEY);
    return stored === 'all' || uiLanguages.includes(stored) ? stored : 'no';
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function getLanguageLabel(value, lang) {
    return value === 'all' ? getUiText(lang).allLanguages : targetLanguageOptionLabels[value] || value;
  }

  function getCategoryLabel(value, lang) {
    return value === 'all' ? getUiText(lang).allCategories : categoryLabels[value]?.[lang] || value;
  }

  function getLevelLabel(value, lang) {
    const level = value === 'all' ? value : normalizeLevelKey(value);
    return level === 'all' ? getUiText(lang).allLevels : levelLabels[level]?.[lang] || value;
  }

  function getSortLabel(value, labels) {
    if (value === 'most-practiced') {
      return labels.sortMostPracticed;
    }
    if (value === 'least-practiced') {
      return labels.sortLeastPracticed;
    }
    if (value === 'recently-practiced') {
      return labels.sortRecentlyPracticed;
    }
    if (value === 'easiest') {
      return labels.sortEasiestFirst;
    }
    if (value === 'hardest') {
      return labels.sortHardestFirst;
    }
    if (value === 'az') {
      return labels.sortAlphabetical;
    }
    return labels.sortNewestDefault;
  }

  function getLanguageTitle(value, lang) {
    return languageNames[value]?.[lang] || value;
  }

  function getLanguageBadgeHtml(value, lang) {
    const label = targetLanguageBadges[value] || value;
    const title = getLanguageTitle(value, lang);
    return '<span class="language-badge language-badge--' + escapeHtml(value) + '" data-target-language="' + escapeHtml(value) + '" title="' + escapeHtml(title) + '" aria-label="' + escapeHtml(title) + '">' + escapeHtml(label) + '</span>';
  }

  function normalizeLevelKey(level) {
    if (legacyLevelMap[level]) {
      return legacyLevelMap[level];
    }
    return levelKeys.includes(level) ? level : 'natural';
  }

  function loadTextProgress() {
    try {
      const parsed = JSON.parse(safeReadStorage(TEXT_PROGRESS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function loadSelfAssessments() {
    try {
      const parsed = JSON.parse(safeReadStorage(SELF_ASSESSMENT_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function loadPinnedTextIds() {
    try {
      const parsed = JSON.parse(safeReadStorage(PINNED_TEXTS_KEY) || '[]');
      return Array.isArray(parsed) ? parsed.filter((id) => typeof id === 'string') : [];
    } catch {
      return [];
    }
  }

  function normalizePracticeTarget(target) {
    if (!target || typeof target !== 'object' || typeof target.textId !== 'string') {
      return null;
    }
    if (target.practiceType === 'translation' && uiLanguages.includes(target.practiceTranslation)) {
      return {
        textId: target.textId,
        practiceType: 'translation',
        practiceTranslation: target.practiceTranslation,
      };
    }
    return {
      textId: target.textId,
      practiceType: 'original',
      practiceTranslation: null,
    };
  }

  function getPracticeTargetKey(target) {
    return target.textId + '::' + target.practiceType + '::' + (target.practiceTranslation || '');
  }

  function getOriginalPracticeTarget(textId) {
    return { textId, practiceType: 'original', practiceTranslation: null };
  }

  function loadPinnedPracticeTargets() {
    const targets = loadPinnedTextIds().map(getOriginalPracticeTarget);
    try {
      const parsed = JSON.parse(safeReadStorage(PINNED_PRACTICE_TARGETS_KEY) || '[]');
      if (Array.isArray(parsed)) {
        parsed.forEach((item) => {
          const target = normalizePracticeTarget(item);
          if (target) {
            targets.push(target);
          }
        });
      }
    } catch {
      // ignore
    }
    const seen = new Set();
    return targets.filter((target) => {
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
  }

  function savePinnedPracticeTargets(targets) {
    const normalized = targets.map(normalizePracticeTarget).filter(Boolean);
    const seen = new Set();
    const deduped = normalized.filter((target) => {
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
    safeWriteStorage(PINNED_PRACTICE_TARGETS_KEY, JSON.stringify(deduped));
  }

  function savePinnedTextIds(ids) {
    safeWriteStorage(PINNED_TEXTS_KEY, JSON.stringify(Array.from(new Set(ids))));
  }

  function isPracticeTargetPinned(target) {
    const key = getPracticeTargetKey(normalizePracticeTarget(target));
    return loadPinnedPracticeTargets().some((item) => getPracticeTargetKey(item) === key);
  }

  function isTextPinned(textId) {
    return isPracticeTargetPinned(getOriginalPracticeTarget(textId));
  }

  function togglePinnedPracticeTarget(target) {
    const normalized = normalizePracticeTarget(target);
    if (!normalized) {
      return;
    }
    const key = getPracticeTargetKey(normalized);
    const pinnedTargets = loadPinnedPracticeTargets();
    const wasPinned = pinnedTargets.some((item) => getPracticeTargetKey(item) === key);
    if (wasPinned) {
      savePinnedPracticeTargets(pinnedTargets.filter((item) => getPracticeTargetKey(item) !== key));
    } else {
      savePinnedPracticeTargets([...pinnedTargets, normalized]);
    }
    if (normalized.practiceType === 'original') {
      const pinned = loadPinnedTextIds();
      if (wasPinned) {
        savePinnedTextIds(pinned.filter((id) => id !== normalized.textId));
      } else {
        savePinnedTextIds([...pinned, normalized.textId]);
      }
    }
  }

  function togglePinnedText(textId) {
    togglePinnedPracticeTarget(getOriginalPracticeTarget(textId));
  }

  function getExpressionStorageKey(expression, language) {
    return language + '::' + (expression.storageKey || expression.phrase);
  }

  function getExpressionStatus(expression, language, statuses) {
    const stored = statuses[getExpressionStorageKey(expression, language)]
      || statuses[expression.storageKey]
      || statuses[language + '::' + expression.phrase]
      || statuses[expression.phrase];
    return ['new', 'review', 'learned'].includes(stored) ? stored : 'new';
  }

  function getTextProgress(textId) {
    const entry = loadTextProgress()[textId] || {};
    return {
      completedCount: Number.isFinite(entry.completedCount) ? entry.completedCount : 0,
      bestAccuracy: Number.isFinite(entry.bestAccuracy) ? entry.bestAccuracy : 0,
      bestWpm: Number.isFinite(entry.bestWpm) ? entry.bestWpm : 0,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : '',
    };
  }

  function getPracticeLabel(count, labels) {
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getLastPracticedLabel(isoDate, labels, lang) {
    if (!isoDate) {
      return '';
    }
    const date = new Date(isoDate);
    if (Number.isNaN(date.getTime())) {
      return '';
    }
    const today = new Date();
    const isToday = date.getFullYear() === today.getFullYear()
      && date.getMonth() === today.getMonth()
      && date.getDate() === today.getDate();
    if (isToday) {
      return labels.lastPracticedPrefix + labels.lastPracticedToday;
    }
    return labels.lastPracticedPrefix + new Intl.DateTimeFormat(lang, { month: 'short', day: 'numeric' }).format(date);
  }

  function translateUiLabels(lang) {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.dataset.i18n;
      const text = getUiText(lang)[key];
      if (typeof text === 'string') {
        el.textContent = text;
      }
    });

    document.querySelectorAll('[data-i18n-target-language]').forEach((option) => {
      const value = option.dataset.i18nTargetLanguage;
      option.textContent = getLanguageLabel(value, lang);
    });

    document.querySelectorAll('[data-i18n-category]').forEach((option) => {
      const value = option.dataset.i18nCategory;
      option.textContent = categoryLabels[value]?.[lang] || value;
    });

    document.querySelectorAll('[data-i18n-level]').forEach((option) => {
      const value = normalizeLevelKey(option.dataset.i18nLevel);
      option.textContent = levelLabels[value]?.[lang] || value;
    });
  }

  function updateSelectDropdownUi(select, options, buttonLabel, getLabel) {
    const selectedValue = select.value;
    options.forEach((option) => {
      const value = option.dataset.dropdownValue;
      const isSelected = value === selectedValue;
      option.setAttribute('aria-selected', isSelected ? 'true' : 'false');
      option.querySelector('[data-filter-option-label]').textContent = getLabel(value);
    });
    buttonLabel.textContent = getLabel(selectedValue);
  }

  function closeSelectDropdown(button, menu) {
    button.setAttribute('aria-expanded', 'false');
    menu.hidden = true;
  }

  function openSelectDropdown(button, menu, options, selectedValue) {
    button.setAttribute('aria-expanded', 'true');
    menu.hidden = false;
    const selectedOption = options.find((option) => option.dataset.dropdownValue === selectedValue) || options[0];
    selectedOption?.focus();
  }

  function setupSelectDropdown({ select, button, menu, options, buttonLabel, getLabel, onChange }) {
    const close = () => closeSelectDropdown(button, menu);
    const update = () => updateSelectDropdownUi(select, options, buttonLabel, getLabel);
    const chooseValue = (value) => {
      select.value = value;
      close();
      update();
      onChange(value);
    };

    button.addEventListener('click', () => {
      if (menu.hidden) {
        openSelectDropdown(button, menu, options, select.value);
      } else {
        close();
      }
    });
    button.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown' || event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openSelectDropdown(button, menu, options, select.value);
      }
    });
    options.forEach((option, index) => {
      option.addEventListener('click', () => {
        chooseValue(option.dataset.dropdownValue);
      });
      option.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          chooseValue(option.dataset.dropdownValue);
        }
        if (event.key === 'Escape') {
          event.preventDefault();
          close();
          button.focus();
        }
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          options[(index + 1) % options.length].focus();
        }
        if (event.key === 'ArrowUp') {
          event.preventDefault();
          options[(index - 1 + options.length) % options.length].focus();
        }
      });
    });
    document.addEventListener('click', (event) => {
      if (!button.contains(event.target) && !menu.contains(event.target)) {
        close();
      }
    });

    return { update, close };
  }

  function getExpressionStats() {
    const statuses = loadExpressionStatuses();
    const seen = new Set();
    const counts = { new: 0, review: 0, learned: 0 };
    texts.forEach((text) => {
      text.expressions.forEach((expression) => {
        const key = getExpressionStorageKey(expression, text.language);
        if (seen.has(key)) {
          return;
        }
        seen.add(key);
        const status = getExpressionStatus(expression, text.language, statuses);
        counts[status] += 1;
      });
    });
    return counts;
  }

  function getReviewCountForText(text, statuses) {
    return text.expressions.reduce((count, expression) => {
      return count + (getExpressionStatus(expression, text.language, statuses) === 'review' ? 1 : 0);
    }, 0);
  }

  function getTextById(textId) {
    return texts.find((item) => item.id === textId) || null;
  }

  function getValidSpeedForLanguage(entry, language) {
    const speed = Number(entry.bestWpm);
    if (!Number.isFinite(speed) || speed <= 0) {
      return null;
    }
    if (language === 'ja') {
      return speed <= 1000 ? speed : null;
    }
    return speed <= 250 ? speed : null;
  }

  function getDaysPracticedCount() {
    const cutoff = Date.now() - 30 * 24 * 60 * 60 * 1000;
    const activeDays = new Set();
    function addDay(isoDate) {
      const d = new Date(isoDate || '');
      if (!Number.isNaN(d.getTime()) && d.getTime() >= cutoff) {
        activeDays.add(d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'));
      }
    }
    Object.values(loadSelfAssessments()).forEach((entry) => {
      if (entry && typeof entry === 'object') {
        addDay(entry.assessedAt);
      }
    });
    Object.values(loadTextProgress()).forEach((entry) => {
      if (entry && typeof entry === 'object') {
        addDay(entry.lastPracticedAt);
      }
    });
    return activeDays.size;
  }

  function getAverageSpeedValues() {
    const values = { wpm: [], cpm: [] };
    Object.entries(loadTextProgress()).forEach(([textId, entry]) => {
      if (!entry || typeof entry !== 'object' || !Number.isFinite(entry.completedCount) || entry.completedCount <= 0) {
        return;
      }
      const textItem = getTextById(textId);
      if (!textItem) {
        return;
      }
      const speed = getValidSpeedForLanguage(entry, textItem.language);
      if (speed === null) {
        return;
      }
      if (textItem.language === 'ja') {
        values.cpm.push(speed);
      } else {
        values.wpm.push(speed);
      }
    });
    return {
      wpm: values.wpm.length ? Math.round(values.wpm.reduce((sum, value) => sum + value, 0) / values.wpm.length) : null,
      cpm: values.cpm.length ? Math.round(values.cpm.reduce((sum, value) => sum + value, 0) / values.cpm.length) : null,
    };
  }

  function isTextLearned(text, statuses) {
    return text.expressions.length > 0
      && text.expressions.every((expression) => getExpressionStatus(expression, text.language, statuses) === 'learned');
  }

  function getTranslationLanguagesForText(textItem) {
    return uiLanguages.filter((lang) => {
      const field = lang === 'ja' ? 'translationJa' : lang === 'en' ? 'translationEn' : 'translationNo';
      return lang !== textItem.language && typeof textItem[field] === 'string' && textItem[field].trim();
    });
  }

  function getRecommendedHref(target) {
    if (target.practiceType === 'translation' && target.practiceTranslation) {
      return getAppHref('text/' + encodeURIComponent(target.textId) + '?practiceTranslation=' + encodeURIComponent(target.practiceTranslation));
    }
    return getAppHref('text/' + encodeURIComponent(target.textId));
  }

  function getPracticeTargetLanguage(target, textItem) {
    return target.practiceType === 'translation' && target.practiceTranslation ? target.practiceTranslation : textItem.language;
  }

  function getTextForPracticeTarget(target) {
    return texts.find((item) => item.id === target.textId) || null;
  }

  function getPinnedPracticeTargets(filtered) {
    const filteredTextIds = new Set(filtered.map((item) => item.id));
    const targets = loadPinnedPracticeTargets().filter((target) => filteredTextIds.has(target.textId));
    const seen = new Set();
    return targets.filter((target) => {
      const item = getTextForPracticeTarget(target);
      if (!item) {
        return false;
      }
      if (target.practiceType === 'translation' && !getTranslationLanguagesForText(item).includes(target.practiceTranslation)) {
        return false;
      }
      const key = getPracticeTargetKey(target);
      if (seen.has(key)) {
        return false;
      }
      seen.add(key);
      return true;
    });
  }

  function getAssessmentEntryForPracticeTarget(target, textItem) {
    const assessments = loadSelfAssessments();
    const mode = target.practiceType === 'translation' ? 'translation' : 'text';
    const targetLanguage = target.practiceType === 'translation' ? target.practiceTranslation : textItem.language;
    return assessments[target.textId + '::' + mode + '::' + targetLanguage] || {};
  }

  function getRecommendationReasonLabel(reason, labels) {
    if (reason === 'pinned') {
      return labels.recommendationReasonPinned;
    }
    if (reason === 'again') {
      return labels.recommendationReasonAgain;
    }
    if (reason === 'shaky') {
      return labels.recommendationReasonShaky;
    }
    if (reason === 'review') {
      return labels.recommendationReasonReview;
    }
    if (reason === 'low-practice') {
      return labels.recommendationReasonLowPractice;
    }
    if (reason === 'learned') {
      return labels.recommendationReasonLearned;
    }
    return labels.recommendationReasonUnpracticed;
  }

  function getRecommendationCandidates(filtered) {
    const candidates = new Map();
    const addCandidate = (item, target) => {
      const normalized = normalizePracticeTarget(target);
      if (!normalized) {
        return;
      }
      if (normalized.practiceType === 'translation' && !getTranslationLanguagesForText(item).includes(normalized.practiceTranslation)) {
        return;
      }
      candidates.set(getPracticeTargetKey(normalized), { item, target: normalized });
    };

    filtered.forEach((item) => {
      addCandidate(item, getOriginalPracticeTarget(item.id));
      getTranslationLanguagesForText(item).forEach((lang) => {
        const target = { textId: item.id, practiceType: 'translation', practiceTranslation: lang };
        const assessment = getAssessmentEntryForPracticeTarget(target, item);
        if (assessment.level === 'again' || assessment.level === 'shaky') {
          addCandidate(item, target);
        }
      });
    });

    getPinnedPracticeTargets(filtered).forEach((target) => {
      const item = getTextForPracticeTarget(target);
      if (item) {
        addCandidate(item, target);
      }
    });

    return Array.from(candidates.values());
  }

  function scoreRecommendationCandidate(item, target, expressionStatuses, pinnedKeys) {
    const progress = getTextProgress(item.id);
    const reviewCount = getReviewCountForText(item, expressionStatuses);
    const assessment = getAssessmentEntryForPracticeTarget(target, item);
    const learned = isTextLearned(item, expressionStatuses);
    const pinned = pinnedKeys.has(getPracticeTargetKey(target));
    let group = 7;
    let reason = 'unpracticed';

    if (pinned) {
      group = 1;
      reason = 'pinned';
    } else if (assessment.level === 'again') {
      group = 2;
      reason = 'again';
    } else if (assessment.level === 'shaky') {
      group = 3;
      reason = 'shaky';
    } else if (reviewCount > 0) {
      group = 4;
      reason = 'review';
    } else if (learned) {
      group = 8;
      reason = 'learned';
    } else if (progress.completedCount > 0 && progress.completedCount < 3) {
      group = 5;
      reason = 'low-practice';
    } else if (progress.completedCount === 0) {
      group = 6;
      reason = 'unpracticed';
    }

    return {
      item,
      target,
      group,
      reason,
      assessmentPriority: Number.isFinite(assessment.priority) ? assessment.priority : 0,
      assessedAt: Date.parse(assessment.assessedAt || '') || 0,
      reviewCount,
      practiceCount: progress.completedCount,
      title: item.title + (target.practiceTranslation || ''),
    };
  }

  function getPinButtonLabel(textId, labels) {
    return isTextPinned(textId) ? labels.unpinText : labels.pinText;
  }

  function renderDashboard(uiLanguageSelect) {
    const labels = getUiText(uiLanguageSelect.value);
    const progressEntries = Object.values(loadTextProgress());
    const totalSessions = progressEntries.reduce((sum, entry) => {
      return sum + (Number.isFinite(entry.completedCount) ? entry.completedCount : 0);
    }, 0);
    const averageSpeeds = getAverageSpeedValues();
    const expressionStats = getExpressionStats();

    document.getElementById('dashboard-title').textContent = labels.todayPractice;
    document.getElementById('total-sessions-label').textContent = labels.totalSessions;
    document.getElementById('total-sessions-value').textContent = totalSessions;
    document.getElementById('learned-expressions-label').textContent = labels.learnedExpressions;
    document.getElementById('learned-expressions-value').textContent = expressionStats.learned;
    document.getElementById('reviewing-expressions-label').textContent = labels.reviewingExpressions;
    document.getElementById('reviewing-expressions-value').textContent = expressionStats.review;
    document.getElementById('new-expressions-label').textContent = labels.newExpressions;
    document.getElementById('new-expressions-value').textContent = expressionStats.new;
    document.getElementById('average-wpm-label').textContent = labels.averageWpm;
    document.getElementById('average-wpm-value').textContent = averageSpeeds.wpm === null ? '—' : averageSpeeds.wpm;
    document.getElementById('average-cpm-label').textContent = labels.averageCpm;
    document.getElementById('average-cpm-value').textContent = averageSpeeds.cpm === null ? '—' : averageSpeeds.cpm;

    const heroLearnedCount = document.getElementById('hero-learned-count');
    const heroTotalCount = document.getElementById('hero-total-count');
    const heroReviewCount = document.getElementById('hero-review-count');
    const totalExpressions = expressionStats.new + expressionStats.review + expressionStats.learned;
    if (heroLearnedCount) heroLearnedCount.textContent = expressionStats.learned;
    if (heroTotalCount) heroTotalCount.textContent = totalExpressions;
    if (heroReviewCount) heroReviewCount.textContent = expressionStats.review;
  }

  function getFilteredTexts(targetLanguageSelect, categorySelect, levelSelect, sortSelect) {
    const selectedTargetLanguage = targetLanguageSelect.value;
    const selectedCat = categorySelect.value;
    const selectedLevel = levelSelect.value;
    const selectedSort = sortSelect.value;
    return texts.filter((item) => {
      return (selectedTargetLanguage === 'all' || item.language === selectedTargetLanguage)
        && (selectedCat === 'all' || item.category === selectedCat)
        && (selectedLevel === 'all' || normalizeLevelKey(item.level) === selectedLevel);
    }).sort((a, b) => {
      const aProgress = getTextProgress(a.id);
      const bProgress = getTextProgress(b.id);
      if (selectedSort === 'most-practiced') {
        return bProgress.completedCount - aProgress.completedCount || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'least-practiced') {
        return aProgress.completedCount - bProgress.completedCount || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'recently-practiced') {
        const aTime = Date.parse(aProgress.lastPracticedAt || '') || 0;
        const bTime = Date.parse(bProgress.lastPracticedAt || '') || 0;
        return bTime - aTime || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'easiest') {
        return levelSortRank[normalizeLevelKey(a.level)] - levelSortRank[normalizeLevelKey(b.level)] || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'hardest') {
        return levelSortRank[normalizeLevelKey(b.level)] - levelSortRank[normalizeLevelKey(a.level)] || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'az') {
        return a.title.localeCompare(b.title);
      }
      return 0;
    });
  }

  function renderList(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, onPinChange) {
    const uiLang = uiLanguageSelect.value;
    const labels = getUiText(uiLang);
    const expressionStatuses = loadExpressionStatuses();
    const pinnedTextIds = loadPinnedTextIds();
    const filtered = getFilteredTexts(targetLanguageSelect, categorySelect, levelSelect, sortSelect);

    results.innerHTML = filtered.map((item) => {
      const progress = getTextProgress(item.id);
      const isPinned = pinnedTextIds.includes(item.id);
      const lastPracticed = getLastPracticedLabel(progress.lastPracticedAt, labels, uiLang);
      const levelKey = normalizeLevelKey(item.level);
      const categoryLabel = categoryLabels[item.category]?.[uiLang] || item.category;
      const levelLabel = levelLabels[levelKey]?.[uiLang] || levelKey;
      const reviewCount = getReviewCountForText(item, expressionStatuses);
      const preview = item.text.slice(0, 110).replace(/\\n/g, ' ');
      return ''
        + '<article class="card text-list-card" data-text-id="' + escapeHtml(item.id) + '" data-target-language="' + escapeHtml(item.language) + '">'
        + '<button class="pin-button text-card__pin' + (isPinned ? ' is-pinned' : '') + '" type="button" data-pin-text-id="' + escapeHtml(item.id) + '" aria-label="' + escapeHtml(getPinButtonLabel(item.id, labels)) + '" title="' + escapeHtml(getPinButtonLabel(item.id, labels)) + '" aria-pressed="' + (isPinned ? 'true' : 'false') + '">' + (isPinned ? '★' : '☆') + '</button>'
        + '<div class="text-card-body">'
        + '<p class="meta">' + getLanguageBadgeHtml(item.language, uiLang) + '<span>' + escapeHtml(categoryLabel) + '</span><span>' + escapeHtml(levelLabel) + '</span></p>'
        + '<h2>' + escapeHtml(item.title) + '</h2>'
        + '<p class="text-card-progress">' + escapeHtml(getPracticeLabel(progress.completedCount, labels)) + (lastPracticed ? ' · ' + escapeHtml(lastPracticed) : '') + (reviewCount ? ' · ' + escapeHtml(labels.reviewingExpressions) + ': ' + reviewCount : '') + '</p>'
        + '<p class="snippet">' + escapeHtml(preview) + '…</p>'
        + '</div>'
        + '<a class="card-link" href="' + escapeHtml(getAppHref('text/' + encodeURIComponent(item.id))) + '">' + escapeHtml(labels.view) + '</a>'
        + '</article>';
    }).join('');

    emptyState.hidden = filtered.length > 0;
    results.querySelectorAll('[data-text-id]').forEach((card) => {
      card.addEventListener('click', () => {
        window.location.href = getAppHref('text/' + encodeURIComponent(card.dataset.textId));
      });
    });
    results.querySelectorAll('.card-link').forEach((link) => {
      link.addEventListener('click', (event) => {
        event.stopPropagation();
      });
    });
    results.querySelectorAll('[data-pin-text-id]').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.stopPropagation();
        togglePinnedText(button.dataset.pinTextId);
        if (typeof onPinChange === 'function') {
          onPinChange();
        } else {
          renderList(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState);
        }
      });
    });
    return filtered;
  }

  function randomItem(items) {
    return items[Math.floor(Math.random() * items.length)];
  }

  function getRecommendedEntry(filtered) {
    if (!filtered.length) {
      return null;
    }
    const expressionStatuses = loadExpressionStatuses();
    const pinnedKeys = new Set(getPinnedPracticeTargets(filtered).map(getPracticeTargetKey));
    const scored = getRecommendationCandidates(filtered).map(({ item, target }) => {
      return scoreRecommendationCandidate(item, target, expressionStatuses, pinnedKeys);
    }).sort((a, b) => {
      return a.group - b.group
        || b.assessmentPriority - a.assessmentPriority
        || b.assessedAt - a.assessedAt
        || b.reviewCount - a.reviewCount
        || a.practiceCount - b.practiceCount
        || a.title.localeCompare(b.title);
    });
    const best = scored.filter((entry) => {
      const first = scored[0];
      return entry.group === first.group
        && entry.assessmentPriority === first.assessmentPriority
        && entry.assessedAt === first.assessedAt
        && entry.reviewCount === first.reviewCount
        && entry.practiceCount === first.practiceCount;
    });
    return randomItem(best);
  }

  function renderTodayRecommendation(entry, uiLanguageSelect, recommendationCard) {
    if (!recommendationCard) {
      return;
    }
    if (!entry) {
      recommendationCard.hidden = true;
      recommendationCard.onclick = null;
      recommendationCard.onkeydown = null;
      return;
    }
    const labels = getUiText(uiLanguageSelect.value);
    const targetLanguage = getPracticeTargetLanguage(entry.target, entry.item);
    recommendationCard.hidden = false;
    recommendationCard.dataset.targetLanguage = targetLanguage;
    recommendationCard.innerHTML = ''
      + '<span class="recommendation-card__eyebrow">' + escapeHtml(labels.todayRecommendation) + '</span>'
      + '<div class="recommendation-card__main">'
      + '<h2>' + escapeHtml(entry.item.title) + '</h2>'
      + '<p>' + getLanguageBadgeHtml(targetLanguage, uiLanguageSelect.value) + '<span>' + escapeHtml(getRecommendationReasonLabel(entry.reason, labels)) + '</span></p>'
      + '</div>';
    recommendationCard.onclick = () => {
      window.location.href = getRecommendedHref(entry.target);
    };
    recommendationCard.onkeydown = (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        window.location.href = getRecommendedHref(entry.target);
      }
    };
  }

  function getRandomPracticeTarget(filtered) {
    if (!filtered.length) {
      return null;
    }
    const pinnedTargets = getPinnedPracticeTargets(filtered);
    if (pinnedTargets.length && Math.random() < 0.25) {
      return randomItem(pinnedTargets);
    }
    return getOriginalPracticeTarget(randomItem(filtered).id);
  }

  function updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, randomButton, recommendationCard) {
    renderDashboard(uiLanguageSelect);
    const filtered = renderList(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, () => {
      updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, randomButton, recommendationCard);
    });
    const recommendedEntry = getRecommendedEntry(filtered);
    renderTodayRecommendation(recommendedEntry, uiLanguageSelect, recommendationCard);
    const todayTypingButton = document.getElementById('today-typing-button');
    if (filtered.length > 0) {
      randomButton.disabled = false;
      randomButton.onclick = () => {
        const randomTarget = getRandomPracticeTarget(filtered);
        if (randomTarget) {
          window.location.href = getRecommendedHref(randomTarget);
        }
      };
      if (todayTypingButton) {
        todayTypingButton.disabled = false;
        todayTypingButton.onclick = () => {
          const recommended = getRecommendedEntry(filtered);
          if (recommended) {
            window.location.href = getRecommendedHref(recommended.target);
          }
        };
      }
    } else {
      randomButton.disabled = true;
      randomButton.onclick = null;
      if (todayTypingButton) {
        todayTypingButton.disabled = true;
        todayTypingButton.onclick = null;
      }
      renderTodayRecommendation(null, uiLanguageSelect, recommendationCard);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const targetLanguageSelect = document.getElementById('text-language');
    const categorySelect = document.getElementById('text-category');
    const levelSelect = document.getElementById('text-level');
    const sortSelect = document.getElementById('text-sort');
    const results = document.getElementById('results');
    const emptyState = document.getElementById('empty-state');
    const randomButton = document.getElementById('random-button');
    const recommendationCard = document.getElementById('today-recommendation-card');
    const targetLanguageButton = document.getElementById('text-language-button');
    const targetLanguageMenu = document.getElementById('text-language-menu');
    const targetLanguageOptions = Array.from(document.querySelectorAll('[data-home-target-language-option]'));
    const targetLanguageButtonLabel = document.getElementById('text-language-button-label');
    const categoryButton = document.getElementById('text-category-button');
    const categoryMenu = document.getElementById('text-category-menu');
    const categoryOptions = Array.from(document.querySelectorAll('[data-home-category-option]'));
    const categoryButtonLabel = document.getElementById('text-category-button-label');
    const levelButton = document.getElementById('text-level-button');
    const levelMenu = document.getElementById('text-level-menu');
    const levelOptions = Array.from(document.querySelectorAll('[data-home-level-option]'));
    const levelButtonLabel = document.getElementById('text-level-button-label');
    const sortButton = document.getElementById('text-sort-button');
    const sortMenu = document.getElementById('text-sort-menu');
    const sortOptions = Array.from(document.querySelectorAll('[data-home-sort-option]'));
    const sortButtonLabel = document.getElementById('text-sort-button-label');

    const updateFilters = () => updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, randomButton, recommendationCard);
    const dropdowns = [];

    dropdowns.push(setupSelectDropdown({
      select: targetLanguageSelect,
      button: targetLanguageButton,
      menu: targetLanguageMenu,
      options: targetLanguageOptions,
      buttonLabel: targetLanguageButtonLabel,
      getLabel: (value) => getLanguageLabel(value, uiLanguageSelect.value),
      onChange: applyTargetLanguage,
    }));
    dropdowns.push(setupSelectDropdown({
      select: categorySelect,
      button: categoryButton,
      menu: categoryMenu,
      options: categoryOptions,
      buttonLabel: categoryButtonLabel,
      getLabel: (value) => getCategoryLabel(value, uiLanguageSelect.value),
      onChange: updateFilters,
    }));
    dropdowns.push(setupSelectDropdown({
      select: levelSelect,
      button: levelButton,
      menu: levelMenu,
      options: levelOptions,
      buttonLabel: levelButtonLabel,
      getLabel: (value) => getLevelLabel(value, uiLanguageSelect.value),
      onChange: updateFilters,
    }));
    dropdowns.push(setupSelectDropdown({
      select: sortSelect,
      button: sortButton,
      menu: sortMenu,
      options: sortOptions,
      buttonLabel: sortButtonLabel,
      getLabel: (value) => getSortLabel(value, getUiText(uiLanguageSelect.value)),
      onChange: updateFilters,
    }));

    function applyUiLanguage(lang) {
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      translateUiLabels(lang);
      uiLanguageSelect.value = lang;
      dropdowns.forEach((dropdown) => dropdown.update());
      updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, randomButton, recommendationCard);
    }

    function applyTargetLanguage(lang) {
      const nextTargetLanguage = lang === 'all' || uiLanguages.includes(lang) ? lang : 'no';
      safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, nextTargetLanguage);
      targetLanguageSelect.value = nextTargetLanguage;
      dropdowns.forEach((dropdown) => dropdown.update());
      updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, randomButton, recommendationCard);
    }

    const savedUiLanguage = getSavedUiLanguage();
    const savedTargetLanguage = getSavedTargetLanguage();
    targetLanguageSelect.value = savedTargetLanguage;
    applyUiLanguage(savedUiLanguage);

    uiLanguageSelect.addEventListener('change', (event) => {
      applyUiLanguage(event.target.value);
    });
    targetLanguageSelect.addEventListener('change', (event) => {
      applyTargetLanguage(event.target.value);
    });
    categorySelect.addEventListener('change', () => {
      dropdowns.forEach((dropdown) => dropdown.update());
      updateFilters();
    });
    levelSelect.addEventListener('change', () => {
      dropdowns.forEach((dropdown) => dropdown.update());
      updateFilters();
    });
    sortSelect.addEventListener('change', () => {
      dropdowns.forEach((dropdown) => dropdown.update());
      updateFilters();
    });

    const flashcardButton = document.getElementById('flashcard-button');
    if (flashcardButton) {
      flashcardButton.addEventListener('click', () => {
        safeWriteStorage('typingSiteStartMode', 'flashcards');
        window.location.href = getAppHref('review');
      });
    }
  });
`;
