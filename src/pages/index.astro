                            tabindex="-1"
                            data-home-sort-option
                            data-dropdown-value="least-practiced"
                            aria-selected="false"
                        >
                            <span data-filter-option-label
                                >{
                                    uiText[defaultUiLang].sortLeastPracticed
                                }</span
                            >
                        </button>
                        <button
                            class="status-filter-option"
                            type="button"
                            role="option"
                            tabindex="-1"
                            data-home-sort-option
                            data-dropdown-value="recently-practiced"
                            aria-selected="false"
                        >
                            <span data-filter-option-label
                                >{
                                    uiText[defaultUiLang].sortRecentlyPracticed
                                }</span
                            >
                        </button>
                        <button
                            class="status-filter-option"
                            type="button"
                            role="option"
                            tabindex="-1"
                            data-home-sort-option
                            data-dropdown-value="easiest"
                            aria-selected="false"
                        >
                            <span data-filter-option-label
                                >{uiText[defaultUiLang].sortEasiestFirst}</span
                            >
                        </button>
                        <button
                            class="status-filter-option"
                            type="button"
                            role="option"
                            tabindex="-1"
                            data-home-sort-option
                            data-dropdown-value="hardest"
                            aria-selected="false"
                        >
                            <span data-filter-option-label
                                >{uiText[defaultUiLang].sortHardestFirst}</span
                            >
                        </button>
                        <button
                            class="status-filter-option"
                            type="button"
                            role="option"
                            tabindex="-1"
                            data-home-sort-option
                            data-dropdown-value="az"
                            aria-selected="false"
                        >
                            <span data-filter-option-label
                                >{uiText[defaultUiLang].sortAlphabetical}</span
                            >
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <section id="results" class="results-grid"></section>
        <p id="empty-state" class="empty-state" hidden data-i18n="noResults">
            {uiText[defaultUiLang].noResults}
        </p>

        <!-- 4. PROGRESS WIDGET -->
        <section
            class="dashboard-card progress-section"
            id="progress"
            aria-labelledby="dashboard-title"
        >
            <div class="dashboard-heading dashboard-heading--with-actions">
                <div>
                    <h2 id="dashboard-title">
                        {uiText[defaultUiLang].todayPractice}
                    </h2>
                </div>
                <div class="dashboard-actions">
                    <a
                        class="secondary-button progress-details-link"
                        href={appHref("progress")}
                        data-i18n="viewDetails"
                    >
                        {uiText[defaultUiLang].viewDetails}
                    </a>
                </div>
            </div>
            <div class="dashboard-grid">
                <article class="dashboard-stat">
                    <span id="total-sessions-label"
                        >{uiText[defaultUiLang].totalSessions}</span
                    >
                    <strong id="total-sessions-value">0</strong>
                </article>
                <article class="dashboard-stat" data-stat-kind="learned">
                    <span id="learned-expressions-label"
                        >{uiText[defaultUiLang].learnedExpressions}</span
                    >
                    <strong id="learned-expressions-value">0</strong>
                </article>
                <article class="dashboard-stat">
                    <span id="reviewing-expressions-label"
                        >{uiText[defaultUiLang].reviewingExpressions}</span
                    >
                    <strong id="reviewing-expressions-value">0</strong>
                </article>
                <article class="dashboard-stat">
                    <span id="new-expressions-label"
                        >{uiText[defaultUiLang].newExpressions}</span
                    >
                    <strong id="new-expressions-value">0</strong>
                </article>
                <article class="dashboard-stat">
                    <span id="average-wpm-label"
                        >{uiText[defaultUiLang].averageWpm}</span
                    >
                    <strong id="average-wpm-value">—</strong>
                </article>
                <article class="dashboard-stat">
                    <span id="average-cpm-label"
                        >{uiText[defaultUiLang].averageCpm}</span
                    >
                    <strong id="average-cpm-value">—</strong>
                </article>
            </div>
        </section>
    </main>

    <script type="module" set:html={clientScript} />
</body>

