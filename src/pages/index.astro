---
import '../styles/global.scss';
import texts from '../data/texts.json' assert { type: 'json' };
import {
  categories as categoryKeys,
  levels as levelKeys,
  uiLanguages,
  uiLanguageNames,
  uiText,
  categoryLabels,
  levelLabels,
  languageNames,
  type UILang,
} from '../i18n/ui';

const defaultUiLang: UILang = 'en';
const clientScript = `
  const texts = ${JSON.stringify(texts)};
  const ui = ${JSON.stringify(uiText)};
  const uiLanguages = ${JSON.stringify(uiLanguages)};
  const categoryLabels = ${JSON.stringify(categoryLabels)};
  const levelLabels = ${JSON.stringify(levelLabels)};
  const languageNames = ${JSON.stringify(languageNames)};
  const targetLanguageBadges = {
    no: '🇳🇴 Norsk',
    en: '🇬🇧 English',
    ja: '🇯🇵 日本語',
  };
  const levelKeys = ${JSON.stringify(levelKeys)};
  const levelSortRank = {
    a1: 0,
    a2: 1,
    b1: 2,
    b2: 3,
    c1: 4,
    natural: 5,
  };
  const legacyLevelMap = {
    basic: 'a1',
    useful: 'a2',
    daily: 'b1',
    advanced: 'b2',
    natural: 'natural',
  };
  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';
  const TARGET_LANGUAGE_STORAGE_KEY = 'typingSiteTargetLanguage';
  const TEXT_PROGRESS_KEY = 'typingProgress';
  const EXPRESSION_STATUS_KEY = 'typingSiteExpressionStatus';

  function safeReadStorage(key) {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function safeWriteStorage(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {
      // ignore
    }
  }

  function getSavedUiLanguage() {
    const stored = safeReadStorage(UI_LANGUAGE_STORAGE_KEY);
    return uiLanguages.includes(stored) ? stored : 'en';
  }

  function getSavedTargetLanguage() {
    const stored = safeReadStorage(TARGET_LANGUAGE_STORAGE_KEY);
    return stored === 'all' || uiLanguages.includes(stored) ? stored : 'no';
  }

  function getUiText(lang) {
    return ui[lang] || ui.en;
  }

  function normalizeLevelKey(level) {
    if (legacyLevelMap[level]) {
      return legacyLevelMap[level];
    }
    return levelKeys.includes(level) ? level : 'natural';
  }

  function loadTextProgress() {
    try {
      const parsed = JSON.parse(safeReadStorage(TEXT_PROGRESS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function loadExpressionStatuses() {
    try {
      const parsed = JSON.parse(safeReadStorage(EXPRESSION_STATUS_KEY) || '{}');
      return parsed && typeof parsed === 'object' ? parsed : {};
    } catch {
      return {};
    }
  }

  function getExpressionStorageKey(expression, language) {
    return language + '::' + (expression.storageKey || expression.phrase);
  }

  function getExpressionStatus(expression, language, statuses) {
    const stored = statuses[getExpressionStorageKey(expression, language)]
      || statuses[expression.storageKey]
      || statuses[language + '::' + expression.phrase]
      || statuses[expression.phrase];
    return ['new', 'review', 'learned'].includes(stored) ? stored : 'new';
  }

  function getTextProgress(textId) {
    const entry = loadTextProgress()[textId] || {};
    return {
      completedCount: Number.isFinite(entry.completedCount) ? entry.completedCount : 0,
      bestAccuracy: Number.isFinite(entry.bestAccuracy) ? entry.bestAccuracy : 0,
      bestWpm: Number.isFinite(entry.bestWpm) ? entry.bestWpm : 0,
      lastPracticedAt: typeof entry.lastPracticedAt === 'string' ? entry.lastPracticedAt : '',
    };
  }

  function getPracticeLabel(count, labels) {
    return labels.expressionPracticePrefix + count + labels.expressionPracticeSuffix;
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getLastPracticedLabel(isoDate, labels, lang) {
    if (!isoDate) {
      return '';
    }
    const date = new Date(isoDate);
    if (Number.isNaN(date.getTime())) {
      return '';
    }
    const today = new Date();
    const isToday = date.getFullYear() === today.getFullYear()
      && date.getMonth() === today.getMonth()
      && date.getDate() === today.getDate();
    if (isToday) {
      return labels.lastPracticedPrefix + labels.lastPracticedToday;
    }
    return labels.lastPracticedPrefix + new Intl.DateTimeFormat(lang, { month: 'short', day: 'numeric' }).format(date);
  }

  function translateUiLabels(lang) {
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.dataset.i18n;
      const text = getUiText(lang)[key];
      if (typeof text === 'string') {
        el.textContent = text;
      }
    });

    document.querySelectorAll('[data-i18n-target-language]').forEach((option) => {
      const value = option.dataset.i18nTargetLanguage;
      option.textContent = value === 'all' ? getUiText(lang).allLanguages : languageNames[value]?.[lang] || value;
    });

    document.querySelectorAll('[data-i18n-category]').forEach((option) => {
      const value = option.dataset.i18nCategory;
      option.textContent = categoryLabels[value]?.[lang] || value;
    });

    document.querySelectorAll('[data-i18n-level]').forEach((option) => {
      const value = normalizeLevelKey(option.dataset.i18nLevel);
      option.textContent = levelLabels[value]?.[lang] || value;
    });
  }

  function getExpressionStats() {
    const statuses = loadExpressionStatuses();
    const seen = new Set();
    const counts = { new: 0, review: 0, learned: 0 };
    texts.forEach((text) => {
      text.expressions.forEach((expression) => {
        const key = getExpressionStorageKey(expression, text.language);
        if (seen.has(key)) {
          return;
        }
        seen.add(key);
        const status = getExpressionStatus(expression, text.language, statuses);
        counts[status] += 1;
      });
    });
    return counts;
  }

  function getReviewCountForText(text, statuses) {
    return text.expressions.reduce((count, expression) => {
      return count + (getExpressionStatus(expression, text.language, statuses) === 'review' ? 1 : 0);
    }, 0);
  }

  function renderDashboard(uiLanguageSelect) {
    const labels = getUiText(uiLanguageSelect.value);
    const progressEntries = Object.values(loadTextProgress());
    const totalSessions = progressEntries.reduce((sum, entry) => {
      return sum + (Number.isFinite(entry.completedCount) ? entry.completedCount : 0);
    }, 0);
    const speedValues = progressEntries
      .map((entry) => Number.isFinite(entry.bestWpm) ? entry.bestWpm : 0)
      .filter((value) => value > 0);
    const averageSpeed = speedValues.length
      ? Math.round(speedValues.reduce((sum, value) => sum + value, 0) / speedValues.length)
      : null;
    const expressionStats = getExpressionStats();

    document.getElementById('dashboard-title').textContent = labels.todayPractice;
    document.getElementById('total-sessions-label').textContent = labels.totalSessions;
    document.getElementById('total-sessions-value').textContent = totalSessions;
    document.getElementById('learned-expressions-label').textContent = labels.learnedExpressions;
    document.getElementById('learned-expressions-value').textContent = expressionStats.learned;
    document.getElementById('reviewing-expressions-label').textContent = labels.reviewingExpressions;
    document.getElementById('reviewing-expressions-value').textContent = expressionStats.review;
    document.getElementById('new-expressions-label').textContent = labels.newExpressions;
    document.getElementById('new-expressions-value').textContent = expressionStats.new;
    document.getElementById('average-speed-label').textContent = labels.averageSpeed;
    document.getElementById('average-speed-value').textContent = averageSpeed === null ? '—' : averageSpeed;
  }

  function getFilteredTexts(targetLanguageSelect, categorySelect, levelSelect, sortSelect) {
    const selectedTargetLanguage = targetLanguageSelect.value;
    const selectedCat = categorySelect.value;
    const selectedLevel = levelSelect.value;
    const selectedSort = sortSelect.value;
    return texts.filter((item) => {
      return (selectedTargetLanguage === 'all' || item.language === selectedTargetLanguage)
        && (selectedCat === 'all' || item.category === selectedCat)
        && (selectedLevel === 'all' || normalizeLevelKey(item.level) === selectedLevel);
    }).sort((a, b) => {
      const aProgress = getTextProgress(a.id);
      const bProgress = getTextProgress(b.id);
      if (selectedSort === 'most-practiced') {
        return bProgress.completedCount - aProgress.completedCount || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'least-practiced') {
        return aProgress.completedCount - bProgress.completedCount || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'recently-practiced') {
        const aTime = Date.parse(aProgress.lastPracticedAt || '') || 0;
        const bTime = Date.parse(bProgress.lastPracticedAt || '') || 0;
        return bTime - aTime || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'easiest') {
        return levelSortRank[normalizeLevelKey(a.level)] - levelSortRank[normalizeLevelKey(b.level)] || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'hardest') {
        return levelSortRank[normalizeLevelKey(b.level)] - levelSortRank[normalizeLevelKey(a.level)] || a.title.localeCompare(b.title);
      }
      if (selectedSort === 'az') {
        return a.title.localeCompare(b.title);
      }
      return 0;
    });
  }

  function renderList(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState) {
    const uiLang = uiLanguageSelect.value;
    const labels = getUiText(uiLang);
    const expressionStatuses = loadExpressionStatuses();
    const filtered = getFilteredTexts(targetLanguageSelect, categorySelect, levelSelect, sortSelect);

    results.innerHTML = filtered.map((item) => {
      const progress = getTextProgress(item.id);
      const lastPracticed = getLastPracticedLabel(progress.lastPracticedAt, labels, uiLang);
      const levelKey = normalizeLevelKey(item.level);
      const categoryLabel = categoryLabels[item.category]?.[uiLang] || item.category;
      const levelLabel = levelLabels[levelKey]?.[uiLang] || levelKey;
      const reviewCount = getReviewCountForText(item, expressionStatuses);
      const preview = item.text.slice(0, 110).replace(/\\n/g, ' ');
      return ''
        + '<article class="card text-list-card" data-text-id="' + escapeHtml(item.id) + '" data-target-language="' + escapeHtml(item.language) + '">'
        + '<div class="text-card-body">'
        + '<p class="meta"><span class="language-badge" data-target-language="' + escapeHtml(item.language) + '">' + escapeHtml(targetLanguageBadges[item.language]) + '</span><span>' + escapeHtml(categoryLabel) + '</span><span>' + escapeHtml(levelLabel) + '</span></p>'
        + '<h2>' + escapeHtml(item.title) + '</h2>'
        + '<p class="text-card-progress">' + escapeHtml(getPracticeLabel(progress.completedCount, labels)) + (lastPracticed ? ' · ' + escapeHtml(lastPracticed) : '') + (reviewCount ? ' · ' + escapeHtml(labels.reviewingExpressions) + ': ' + reviewCount : '') + '</p>'
        + '<p class="snippet">' + escapeHtml(preview) + '…</p>'
        + '</div>'
        + '<a class="card-link" href="/text/' + escapeHtml(item.id) + '">' + escapeHtml(labels.view) + '</a>'
        + '</article>';
    }).join('');

    emptyState.hidden = filtered.length > 0;
    results.querySelectorAll('[data-text-id]').forEach((card) => {
      card.addEventListener('click', () => {
        window.location.href = '/text/' + card.dataset.textId;
      });
    });
    results.querySelectorAll('.card-link').forEach((link) => {
      link.addEventListener('click', (event) => {
        event.stopPropagation();
      });
    });
    return filtered;
  }

  function randomItem(items) {
    return items[Math.floor(Math.random() * items.length)];
  }

  function getRecommendedText(filtered) {
    if (!filtered.length) {
      return null;
    }
    const expressionStatuses = loadExpressionStatuses();
    const unpracticed = filtered.filter((item) => getTextProgress(item.id).completedCount === 0);
    if (unpracticed.length) {
      const maxReviewCount = Math.max(...unpracticed.map((item) => getReviewCountForText(item, expressionStatuses)));
      return randomItem(unpracticed.filter((item) => getReviewCountForText(item, expressionStatuses) === maxReviewCount));
    }
    const allPracticed = filtered.every((item) => getTextProgress(item.id).completedCount > 0);
    if (allPracticed) {
      return randomItem(filtered);
    }
    const minPracticeCount = Math.min(...filtered.map((item) => getTextProgress(item.id).completedCount));
    return randomItem(filtered.filter((item) => getTextProgress(item.id).completedCount === minPracticeCount));
  }

  function updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, startButton, randomButton) {
    renderDashboard(uiLanguageSelect);
    const filtered = renderList(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState);
    if (filtered.length > 0) {
      startButton.disabled = false;
      randomButton.disabled = false;
      startButton.onclick = () => {
        const recommended = getRecommendedText(filtered);
        if (recommended) {
          window.location.href = '/text/' + recommended.id;
        }
      };
      randomButton.onclick = () => {
        window.location.href = '/text/' + randomItem(filtered).id;
      };
    } else {
      startButton.disabled = true;
      randomButton.disabled = true;
      startButton.onclick = null;
      randomButton.onclick = null;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const uiLanguageSelect = document.getElementById('ui-language-select');
    const targetLanguageSelect = document.getElementById('text-language');
    const categorySelect = document.getElementById('text-category');
    const levelSelect = document.getElementById('text-level');
    const sortSelect = document.getElementById('text-sort');
    const results = document.getElementById('results');
    const emptyState = document.getElementById('empty-state');
    const startButton = document.getElementById('start-button');
    const randomButton = document.getElementById('random-button');

    function applyUiLanguage(lang) {
      safeWriteStorage(UI_LANGUAGE_STORAGE_KEY, lang);
      translateUiLabels(lang);
      uiLanguageSelect.value = lang;
      updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, startButton, randomButton);
    }

    function applyTargetLanguage(lang) {
      const nextTargetLanguage = lang === 'all' || uiLanguages.includes(lang) ? lang : 'no';
      safeWriteStorage(TARGET_LANGUAGE_STORAGE_KEY, nextTargetLanguage);
      targetLanguageSelect.value = nextTargetLanguage;
      updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, startButton, randomButton);
    }

    const savedUiLanguage = getSavedUiLanguage();
    const savedTargetLanguage = getSavedTargetLanguage();
    targetLanguageSelect.value = savedTargetLanguage;
    applyUiLanguage(savedUiLanguage);

    uiLanguageSelect.addEventListener('change', (event) => {
      applyUiLanguage(event.target.value);
    });
    targetLanguageSelect.addEventListener('change', (event) => {
      applyTargetLanguage(event.target.value);
    });
    categorySelect.addEventListener('change', () => updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, startButton, randomButton));
    levelSelect.addEventListener('change', () => updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, startButton, randomButton));
    sortSelect.addEventListener('change', () => updateHome(targetLanguageSelect, categorySelect, levelSelect, sortSelect, uiLanguageSelect, results, emptyState, startButton, randomButton));
  });
`;
---
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Read & Type</title>
  </head>
  <body>
    <main class="page-shell">
      <section class="hero-card">
        <div>
          <h1 id="page-title" data-i18n="title">{uiText[defaultUiLang].title}</h1>
          <p id="page-subtitle" data-i18n="subtitle">{uiText[defaultUiLang].subtitle}</p>
        </div>
        <div class="top-actions">
          <a class="nav-link" href="/review" data-i18n="reviewPageTitle">{uiText[defaultUiLang].reviewPageTitle}</a>
          <div class="language-switcher">
            <label for="ui-language-select" data-i18n="language">{uiText[defaultUiLang].language}</label>
            <select id="ui-language-select">
              {uiLanguages.map((lang) => (
                <option value={lang}>{uiLanguageNames[lang]}</option>
              ))}
            </select>
          </div>
        </div>
      </section>

      <section class="dashboard-card" aria-labelledby="dashboard-title">
        <div class="dashboard-heading">
          <h2 id="dashboard-title">{uiText[defaultUiLang].todayPractice}</h2>
        </div>
        <div class="dashboard-grid">
          <article class="dashboard-stat">
            <span id="total-sessions-label">{uiText[defaultUiLang].totalSessions}</span>
            <strong id="total-sessions-value">0</strong>
          </article>
          <article class="dashboard-stat">
            <span id="learned-expressions-label">{uiText[defaultUiLang].learnedExpressions}</span>
            <strong id="learned-expressions-value">0</strong>
          </article>
          <article class="dashboard-stat">
            <span id="reviewing-expressions-label">{uiText[defaultUiLang].reviewingExpressions}</span>
            <strong id="reviewing-expressions-value">0</strong>
          </article>
          <article class="dashboard-stat">
            <span id="new-expressions-label">{uiText[defaultUiLang].newExpressions}</span>
            <strong id="new-expressions-value">0</strong>
          </article>
          <article class="dashboard-stat">
            <span id="average-speed-label">{uiText[defaultUiLang].averageSpeed}</span>
            <strong id="average-speed-value">—</strong>
          </article>
        </div>
      </section>

      <section class="filters-card">
        <div class="filter-group">
          <label for="text-language" data-i18n="practiceLanguage">{uiText[defaultUiLang].practiceLanguage}</label>
          <select id="text-language">
            <option value="all" data-i18n-target-language="all">{uiText[defaultUiLang].allLanguages}</option>
            {uiLanguages.map((lang) => (
              <option value={lang} data-i18n-target-language={lang}>{languageNames[lang][defaultUiLang]}</option>
            ))}
          </select>
        </div>
        <div class="filter-group">
          <label for="text-category" data-i18n="category">{uiText[defaultUiLang].category}</label>
          <select id="text-category">
            <option value="all" data-i18n="allCategories">{uiText[defaultUiLang].allCategories}</option>
            {categoryKeys.map((category) => (
              <option value={category} data-i18n-category={category}>{categoryLabels[category][defaultUiLang]}</option>
            ))}
          </select>
        </div>
        <div class="filter-group">
          <label for="text-level" data-i18n="level">{uiText[defaultUiLang].level}</label>
          <select id="text-level">
            <option value="all" data-i18n="allLevels">{uiText[defaultUiLang].allLevels}</option>
            {levelKeys.map((level) => (
              <option value={level} data-i18n-level={level}>{levelLabels[level][defaultUiLang]}</option>
            ))}
          </select>
        </div>
        <div class="filter-group">
          <label for="text-sort" data-i18n="sortLabel">{uiText[defaultUiLang].sortLabel}</label>
          <select id="text-sort">
            <option value="default" data-i18n="sortNewestDefault">{uiText[defaultUiLang].sortNewestDefault}</option>
            <option value="most-practiced" data-i18n="sortMostPracticed">{uiText[defaultUiLang].sortMostPracticed}</option>
            <option value="least-practiced" data-i18n="sortLeastPracticed">{uiText[defaultUiLang].sortLeastPracticed}</option>
            <option value="recently-practiced" data-i18n="sortRecentlyPracticed">{uiText[defaultUiLang].sortRecentlyPracticed}</option>
            <option value="easiest" data-i18n="sortEasiestFirst">{uiText[defaultUiLang].sortEasiestFirst}</option>
            <option value="hardest" data-i18n="sortHardestFirst">{uiText[defaultUiLang].sortHardestFirst}</option>
            <option value="az" data-i18n="sortAlphabetical">{uiText[defaultUiLang].sortAlphabetical}</option>
          </select>
        </div>
      </section>

      <section class="actions-row">
        <button id="start-button" class="primary-button" data-i18n="startRecommended">{uiText[defaultUiLang].startRecommended}</button>
        <button id="random-button" class="secondary-button" type="button" data-i18n="randomPractice">{uiText[defaultUiLang].randomPractice}</button>
      </section>

      <section id="results" class="results-grid"></section>
      <p id="empty-state" class="empty-state" hidden data-i18n="noResults">{uiText[defaultUiLang].noResults}</p>
    </main>

    <script type="module" set:html={clientScript}></script>
  </body>
</html>
