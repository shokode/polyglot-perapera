    border: 1px solid var(--border);
    background: var(--surface);
  }
  .home-hero-row > *:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  /* Hero stat: learned / total */
  .home-hero-stat--fraction {
    display: flex;
