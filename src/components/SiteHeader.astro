---
import { uiLanguages, uiLanguageNames } from "../i18n/ui";

type ActivePage = "home" | "review" | "progress" | "text" | "none";

interface Props {
  active?: ActivePage;
  basePath?: string;
}

const { active = "none", basePath = "/" } = Astro.props;
const normalizedBase = basePath.endsWith("/") ? basePath : `${basePath}/`;
const appHref = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const links = [
  { key: "home", label: "Home", href: appHref("") },
  { key: "review", label: "Review", href: appHref("review") },
  { key: "progress", label: "Progress", href: appHref("progress") },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href={appHref("")} aria-label="Polyglotyping home">
      <span class="site-header__mark">Pg</span>
      <span class="site-header__brand-text">
        <strong>Polyglotyping</strong>
        <span>Language practice</span>
      </span>
    </a>
    <button type="button" class="site-header__menu-toggle" data-menu-toggle aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="site-header__menu" data-menu>
      <div class="site-header__actions">
      <nav class="site-nav" aria-label="Main navigation">
        {links.map((link) => (
          <a
            class:list={["site-nav__link", active === link.key && "is-active"]}
            href={link.href}
            aria-current={active === link.key ? "page" : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
      <div class="language-switcher site-language-switcher">
        <label for="ui-language-select" data-i18n="language">Language</label>
        <select id="ui-language-select">
          {uiLanguages.map((lang) => (
            <option value={lang}>{uiLanguageNames[lang]}</option>
          ))}
        </select>
      </div>
      <div class="site-auth" data-auth-root hidden>
        <button type="button" class="site-auth__button" data-auth-open data-i18n="authSignIn">
          Sign in
        </button>
        <div class="site-auth__user" data-auth-user hidden>
          <!-- Mobile inline account section (CSS-hidden on desktop, shown in hamburger menu) -->
          <div class="site-auth__inline">
            <div class="site-auth__inline-identity">
              <span class="site-auth__inline-avatar" data-auth-inline-initial></span>
              <span class="site-auth__inline-email" data-auth-inline-email></span>
            </div>
            <button type="button" class="site-auth__inline-signout" data-auth-inline-signout data-i18n="authSignOut">
              Sign out
            </button>
          </div>
          <!-- Desktop avatar + dropdown (CSS-hidden on mobile) -->
          <button type="button" class="site-auth__avatar" data-auth-avatar-toggle aria-label="Account menu" aria-expanded="false" aria-haspopup="menu">
            <span class="site-auth__avatar-initial" data-auth-initial>C</span>
          </button>
          <div class="site-auth__menu" data-auth-avatar-menu hidden role="menu">
            <div class="site-auth__menu-email" data-auth-email></div>
            <button type="button" class="site-auth__menu-signout" data-auth-signout role="menuitem" data-i18n="authSignOut">
              Sign out
            </button>
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>
</header>

<div class="auth-modal" data-auth-modal hidden>
  <div class="auth-modal__backdrop" data-auth-close></div>
  <div class="auth-modal__panel" role="dialog" aria-modal="true" aria-labelledby="auth-modal-title">
    <button type="button" class="auth-modal__close" data-auth-close aria-label="Close">×</button>
    <h2 class="auth-modal__title" id="auth-modal-title" data-i18n="authModalTitle">Sign in</h2>
    <form class="auth-modal__form" data-auth-form>
      <label class="auth-modal__field">
        <span data-i18n="authEmail">Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
      <label class="auth-modal__field">
        <span data-i18n="authPassword">Password</span>
        <input type="password" name="password" autocomplete="current-password" minlength="6" required />
      </label>
      <p class="auth-modal__message" data-auth-message hidden></p>
      <button type="submit" class="auth-modal__submit" data-auth-submit data-i18n="authSignIn">Sign in</button>
      <button type="button" class="auth-modal__signup" data-auth-signup data-i18n="authSignUp">Sign up</button>
    </form>
  </div>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-menu]');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('is-open');
    });

    const links = menu.querySelectorAll('a, button');
    links.forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
      });
    });
  }
</script>

<script>
  import { getSupabase, isSupabaseConfigured } from '../lib/supabase';
  import { syncOnSignIn, flushProgress, startAutoSync } from '../lib/progress-sync';
  import { uiText, type UILang } from '../i18n/ui';

  const UI_LANGUAGE_STORAGE_KEY = 'typingSiteUiLanguage';

  function currentLang(): UILang {
    try {
      const stored = localStorage.getItem(UI_LANGUAGE_STORAGE_KEY);
      if (stored && stored in uiText) return stored as UILang;
    } catch {}
    return 'en';
  }

  function t(key: keyof (typeof uiText)['en']): string {
    return uiText[currentLang()][key];
  }

  const supabase = getSupabase();
  const root = document.querySelector<HTMLElement>('[data-auth-root]');

  if (root && supabase && isSupabaseConfigured) {
    const client = supabase;
    root.hidden = false;

    const openButton = root.querySelector<HTMLButtonElement>('[data-auth-open]')!;
    const userBox = root.querySelector<HTMLElement>('[data-auth-user]')!;
    const emailLabel = root.querySelector<HTMLElement>('[data-auth-email]')!;
    const avatarToggle = root.querySelector<HTMLButtonElement>('[data-auth-avatar-toggle]')!;
    const avatarMenu = root.querySelector<HTMLElement>('[data-auth-avatar-menu]')!;
    const avatarInitial = root.querySelector<HTMLElement>('[data-auth-initial]')!;
    const signOutButton = root.querySelector<HTMLButtonElement>('[data-auth-signout]')!;
    const inlineInitial = root.querySelector<HTMLElement>('[data-auth-inline-initial]')!;
    const inlineEmail = root.querySelector<HTMLElement>('[data-auth-inline-email]')!;
    const inlineSignOut = root.querySelector<HTMLButtonElement>('[data-auth-inline-signout]')!;

    const modal = document.querySelector<HTMLElement>('[data-auth-modal]')!;
    const form = modal.querySelector<HTMLFormElement>('[data-auth-form]')!;
    const message = modal.querySelector<HTMLElement>('[data-auth-message]')!;
    const submitButton = modal.querySelector<HTMLButtonElement>('[data-auth-submit]')!;
    const signUpButton = modal.querySelector<HTMLButtonElement>('[data-auth-signup]')!;
    const closeEls = modal.querySelectorAll<HTMLElement>('[data-auth-close]');

    function openModal() {
      message.hidden = true;
      modal.hidden = false;
      form.querySelector<HTMLInputElement>('input[name="email"]')?.focus();
    }
    function closeModal() {
      modal.hidden = true;
    }
    function showMessage(text: string, isError = false) {
      message.textContent = text;
      message.hidden = false;
      message.classList.toggle('is-error', isError);
    }

    function renderSession(email: string | null) {
      if (email) {
        openButton.hidden = true;
        userBox.hidden = false;
        const initial = email.charAt(0).toUpperCase();
        emailLabel.textContent = email;
        avatarInitial.textContent = initial;
        inlineInitial.textContent = initial;
        inlineEmail.textContent = email;
        avatarMenu.hidden = true;
      } else {
        openButton.hidden = false;
        userBox.hidden = true;
        emailLabel.textContent = '';
        inlineEmail.textContent = '';
        avatarMenu.hidden = true;
      }
    }

    inlineSignOut.addEventListener('click', () => client.auth.signOut());

    avatarToggle.addEventListener('click', () => {
      const expanded = avatarToggle.getAttribute('aria-expanded') === 'true';
      avatarToggle.setAttribute('aria-expanded', String(!expanded));
      avatarMenu.hidden = expanded;
    });

    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (!userBox.contains(target) && avatarToggle.getAttribute('aria-expanded') === 'true') {
        avatarToggle.setAttribute('aria-expanded', 'false');
        avatarMenu.hidden = true;
      }
    });

    openButton.addEventListener('click', openModal);
    closeEls.forEach((el) => el.addEventListener('click', closeModal));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    async function authenticate(mode: 'signIn' | 'signUp') {
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const password = (form.elements.namedItem('password') as HTMLInputElement).value;
      submitButton.disabled = true;
      signUpButton.disabled = true;
      showMessage(t('authProcessing'));

      const result =
        mode === 'signIn'
          ? await client.auth.signInWithPassword({ email, password })
          : await client.auth.signUp({ email, password });

      submitButton.disabled = false;
      signUpButton.disabled = false;

      if (result.error) {
        showMessage(result.error.message, true);
        return;
      }
      if (mode === 'signUp' && !result.data.session) {
        showMessage(t('authCheckEmail'));
        return;
      }
      closeModal();
      form.reset();
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      authenticate('signIn');
    });
    signUpButton.addEventListener('click', () => authenticate('signUp'));
    signOutButton.addEventListener('click', () => client.auth.signOut());

    let currentUserId: string | null = null;
    let lastSession: import('@supabase/supabase-js').Session | null = null;

    function flushIfSignedIn() {
      const user = lastSession?.user;
      if (user) flushProgress(client, user);
    }

    // Push local progress to the cloud after a change (debounced), regardless
    // of which page made it. Idle time costs nothing — uploads happen only
    // when the progress actually changes, at most once per `minIntervalMs`.
    startAutoSync(client, () => lastSession?.user ?? null, {
      pollMs: 1000,
      minIntervalMs: 2000,
    });

    // Backstop: also flush when the user leaves or hides the tab.
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') flushIfSignedIn();
    });
    window.addEventListener('pagehide', flushIfSignedIn);

    client.auth.getSession().then(({ data }) => {
      lastSession = data.session;
      renderSession(data.session?.user?.email ?? null);
      if (data.session?.user) {
        currentUserId = data.session.user.id;
        syncOnSignIn(client, data.session.user);
      }
    });
    client.auth.onAuthStateChange((event, session) => {
      lastSession = session;
      renderSession(session?.user?.email ?? null);
      const user = session?.user;
      if (user && event === 'SIGNED_IN' && user.id !== currentUserId) {
        currentUserId = user.id;
        syncOnSignIn(client, user);
      }
      if (!user) {
        currentUserId = null;
      }
    });
  }
</script>
